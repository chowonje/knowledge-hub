<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.knowledge-hub.ops-report</string>

  <key>ProgramArguments</key>
  <array>
    <string><repo-root>/scripts/run_ops_report.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string><repo-root></string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>~/.khub/logs/launchd.ops_report.out.log</string>

  <key>StandardErrorPath</key>
  <string>~/.khub/logs/launchd.ops_report.err.log</string>
</dict>
</plist>
