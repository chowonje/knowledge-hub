      "description": "Green-baseline slice for packaging, canonical entrypoints, health semantics, and explicit event-integrity repair.",
      "patterns": [
        ".gitignore",
        "AGENTS.md",
        "README.md",
        "config.yaml.example",
        "package.json",
        "pyproject.toml",
        "requirements.txt",
        "docs/PROJECT_STATE.md",
        "ops/checkpoints/**",
        "scripts/repair_event_integrity.py",
        "scripts/report_checkpoint_split.py",
        "knowledge_hub/interfaces/__init__.py",
        "knowledge_hub/interfaces/cli/__init__.py",
        "knowledge_hub/interfaces/cli/main.py",
        "knowledge_hub/interfaces/cli/commands/health_cmd.py",
        "knowledge_hub/interfaces/mcp/__init__.py",
        "knowledge_hub/interfaces/mcp/server.py",
        "knowledge_hub/cli/main.py",
        "knowledge_hub/cli/health_cmd.py",
        "knowledge_hub/mcp_server.py",
