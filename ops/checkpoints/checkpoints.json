        "tests/test_interfaces_mcp_server.py",
        "tests/test_pyproject_metadata.py"
      ],
      "exclude_patterns": [
        "docs/status/*ask-tranche*",
        "ops/checkpoints/10-*"
      ]
    },
    {
      "order": 2,
      "slug": "cli-mcp-surface-migration",
      "title": "CLI/MCP surface migration",
      "description": "Legacy CLI/MCP command modules, command registration, and migration of public surfaces onto interfaces-backed modules.",
