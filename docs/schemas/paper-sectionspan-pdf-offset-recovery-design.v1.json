        "executedRows": { "const": 0 },
        "originalPdfOffsetRecoveredRows": { "const": 0 },
        "strictPromotionReadyRows": { "const": 0 },
        "runtimePromotionAllowedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "recommendedRecoveryOptionPresent": { "type": "integer", "minimum": 0, "maximum": 1 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "bySectionType": { "type": "object" },
        "byPaper": { "type": "object" },
        "byRecoveryStatus": { "type": "object" }
      },
      "additionalProperties": true
    },
