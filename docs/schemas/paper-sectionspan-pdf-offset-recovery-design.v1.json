          "section_level": { "type": "integer", "minimum": 0 },
          "canonical_span": { "type": "object" },
          "current_authority_status": { "type": "object" },
          "recovery_status": { "const": "planned_not_executed" },
          "recovery_strategy": { "type": "string" },
          "required_inputs": { "type": "array", "items": { "type": "string" } },
          "matching_requirements": { "type": "array", "items": { "type": "string" } },
          "stop_conditions": { "type": "array", "items": { "type": "string" } },
          "planned_output_contract": { "type": "object" },
          "evidence_tier": { "const": "sectionspan_pdf_offset_recovery_design_only" },
          "original_pdf_offset_recovered": { "const": false },
          "strict_promotion_ready": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
