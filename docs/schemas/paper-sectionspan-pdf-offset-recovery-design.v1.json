        "properties": {
          "recovery_plan_id": { "type": "string" },
          "source_design_id": { "type": "string" },
          "source_review_card_id": { "type": "string" },
          "source_sectionspan_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_text": { "type": "string" },
          "section_label": { "type": "string" },
          "section_title": { "type": "string" },
          "section_type": {
            "type": "string",
            "enum": ["numbered_section", "abstract", "backmatter", "named_section"]
