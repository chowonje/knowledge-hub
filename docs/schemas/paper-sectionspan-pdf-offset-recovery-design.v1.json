        "pdfOffsetRecoveryDesignReady",
        "pdfOffsetRecoveryImplemented",
        "originalPdfOffsetRecovered",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "unsafeUpstreamFlags",
