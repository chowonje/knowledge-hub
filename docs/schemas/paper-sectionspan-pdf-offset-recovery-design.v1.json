          "candidate_text",
          "section_label",
          "section_title",
          "section_type",
          "section_level",
          "canonical_span",
          "current_authority_status",
          "recovery_status",
          "recovery_strategy",
          "required_inputs",
          "matching_requirements",
          "stop_conditions",
          "planned_output_contract",
          "evidence_tier",
          "original_pdf_offset_recovered",
          "strict_promotion_ready",
          "runtime_promotion_allowed",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "strict_blockers",
          "non_strict_reason"
