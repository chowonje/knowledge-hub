{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.tex-figure-caption-candidate-report.v1",
  "title": "TeX FigureCaptionCandidate Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "policy",
    "promotionRules",
    "warnings",
    "candidates",
    "heldOut"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.tex-figure-caption-candidate-report.v1" },
    "status": { "type": "string", "enum": ["ok", "empty"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alignmentReportPath", "alignmentReportSchema", "paperIds"],
      "properties": {
        "alignmentReportPath": { "type": "string" },
        "alignmentReportSchema": { "type": "string" },
        "paperIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputRows",
        "figureCaptionRows",
        "genericCaptionRows",
        "figureCaptionCandidates",
        "heldOutCandidates",
        "strictEligibleCandidates",
        "citationGradeCandidates",
        "runtimeEvidenceCandidates",
        "figureRegionVerifiedCandidates",
        "byPaper",
        "heldOutByReason"
      ],
      "properties": {
        "inputRows": { "type": "integer", "minimum": 0 },
        "figureCaptionRows": { "type": "integer", "minimum": 0 },
        "genericCaptionRows": { "type": "integer", "minimum": 0 },
        "figureCaptionCandidates": { "type": "integer", "minimum": 0 },
        "heldOutCandidates": { "type": "integer", "minimum": 0 },
        "strictEligibleCandidates": { "const": 0 },
        "citationGradeCandidates": { "const": 0 },
        "runtimeEvidenceCandidates": { "const": 0 },
        "figureRegionVerifiedCandidates": { "const": 0 },
        "byPaper": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "heldOutByReason": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allCandidatesNonStrict",
        "reportOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "figureRegionVerificationRequired"
      ],
      "properties": {
        "allCandidatesNonStrict": { "const": true },
        "reportOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "figureRegionVerificationRequired": { "const": true }
      }
    },
    "promotionRules": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "candidate_type",
          "source_candidate_id",
          "paper_id",
          "source_parser",
          "source_file",
          "candidate_text",
          "caption_text",
          "caption_source",
          "figure_label",
          "canonical_alignment_status",
          "alignment_method",
          "chars_start",
          "chars_end",
          "page",
          "sourceContentHash",
          "sourceContentHashSource",
          "confidence",
          "source_span_locator",
          "tex_locator",
          "review",
          "figure_region_verified",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "candidate_id": { "type": "string" },
          "candidate_type": { "const": "figure_caption_candidate" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "source_parser": { "const": "arxiv_tex+pymupdf_alignment" },
          "source_file": { "type": "string" },
          "candidate_text": { "type": "string" },
          "caption_text": { "type": "string" },
          "caption_source": { "const": "tex_figure_caption" },
          "figure_label": { "type": "string" },
          "canonical_alignment_status": { "const": "aligned" },
          "alignment_method": { "const": "exact" },
          "chars_start": { "type": "integer", "minimum": 0 },
          "chars_end": { "type": "integer", "minimum": 0 },
          "page": { "type": "integer", "minimum": 1 },
          "sourceContentHash": { "type": "string", "minLength": 1 },
          "sourceContentHashSource": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_span_locator": { "type": "object" },
          "tex_locator": { "type": "object" },
          "review": { "type": "object" },
          "figure_region_verified": { "const": false },
          "evidence_tier": { "const": "figure_caption_candidate_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "heldOut": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceCandidateId",
          "paperId",
          "candidateText",
          "structureType",
          "alignmentStatus",
          "alignmentMethod",
          "reason",
          "strictEligible",
          "citationGrade",
          "runtimeEvidence"
        ],
        "properties": {
          "sourceCandidateId": { "type": "string" },
          "paperId": { "type": "string" },
          "candidateText": { "type": "string" },
          "structureType": { "type": "string" },
          "alignmentStatus": { "type": "string" },
          "alignmentMethod": { "type": "string" },
          "reason": { "type": "string" },
          "strictEligible": { "const": false },
          "citationGrade": { "const": false },
          "runtimeEvidence": { "const": false }
        }
      }
    }
  }
}
