{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.candidate-layer-blocker-backlog.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "backlog"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.candidate-layer-blocker-backlog.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "candidateLayerReviewGateReport",
        "structuredSummaryReport",
        "complexQaEvalDesignReport",
        "candidateLayerReviewGateSchema",
        "structuredSummarySchema",
        "complexQaEvalDesignSchema"
      ],
      "properties": {
        "candidateLayerReviewGateReport": { "type": "string" },
        "structuredSummaryReport": { "type": "string" },
        "complexQaEvalDesignReport": { "type": "string" },
        "sectionspanPdfOffsetSelectedReviewDecisionProposalReport": { "type": "string" },
        "sectionspanPdfOffsetSelectedReviewNextActionBriefReport": { "type": "string" },
        "nonSectionspanPdfOffsetFeasibilityAuditReport": { "type": "string" },
        "equationAlignmentFeasibilityAuditReport": { "type": "string" },
        "tableCellProvenanceFeasibilityAuditReport": { "type": "string" },
        "figureRegionLinkFeasibilityAuditReport": { "type": "string" },
        "candidateLayerBlockerDecisionRecordReport": { "type": "string" },
        "candidateLayerReviewGateSchema": { "type": "string" },
        "structuredSummarySchema": { "type": "string" },
        "complexQaEvalDesignSchema": { "type": "string" },
        "sectionspanPdfOffsetSelectedReviewDecisionProposalSchema": { "type": "string" },
        "sectionspanPdfOffsetSelectedReviewNextActionBriefSchema": { "type": "string" },
        "nonSectionspanPdfOffsetFeasibilityAuditSchema": { "type": "string" },
        "equationAlignmentFeasibilityAuditSchema": { "type": "string" },
        "tableCellProvenanceFeasibilityAuditSchema": { "type": "string" },
        "figureRegionLinkFeasibilityAuditSchema": { "type": "string" },
        "candidateLayerBlockerDecisionRecordSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "backlogItemCount",
        "openBacklogItemCount",
        "byPriority",
        "byLayer",
        "totalCandidates",
        "evalQuestionCount",
        "strictEligibleCandidates",
        "citationGradeCandidates",
        "runtimeEvidenceCandidates",
        "currentRuntimeAnswerableQuestions"
      ],
      "properties": {
        "backlogItemCount": { "type": "integer", "minimum": 0 },
        "openBacklogItemCount": { "type": "integer", "minimum": 0 },
        "byPriority": { "type": "object" },
        "byLayer": { "type": "object" },
        "totalCandidates": { "type": "integer", "minimum": 0 },
        "evalQuestionCount": { "type": "integer", "minimum": 0 },
        "strictEligibleCandidates": { "const": 0 },
        "citationGradeCandidates": { "const": 0 },
        "runtimeEvidenceCandidates": { "const": 0 },
        "currentRuntimeAnswerableQuestions": { "const": 0 },
        "sectionspanSelectedDecisionProposalRows": { "type": "integer", "minimum": 0 },
        "sectionspanSelectedDecisionProposalApproveRows": { "type": "integer", "minimum": 0 },
        "sectionspanSelectedDecisionAcceptedRows": { "type": "integer", "minimum": 0 },
        "sectionspanSelectedNextActionBriefRows": { "type": "integer", "minimum": 0 },
        "sectionspanSelectedNextActionNeedsReviewRows": { "type": "integer", "minimum": 0 },
        "sectionspanSelectedNextActionSuggestedApproveRows": { "type": "integer", "minimum": 0 },
        "sectionspanSelectedNextActionDecisionRecordNeedsReviewRows": { "type": "integer", "minimum": 0 },
        "nonSectionspanPdfOffsetAuditRows": { "type": "integer", "minimum": 0 },
        "nonSectionspanPdfOffsetRecoveredRows": { "type": "integer", "minimum": 0 },
        "nonSectionspanPdfOffsetBlockedRows": { "type": "integer", "minimum": 0 },
        "nonSectionspanPdfOffsetDiagnosticPageContextRows": { "type": "integer", "minimum": 0 },
        "nonSectionspanPdfOffsetReadyForRegionReviewRows": { "type": "integer", "minimum": 0 },
        "equationAlignmentAuditRows": { "type": "integer", "minimum": 0 },
        "equationAlignmentCanonicalSourceSpanCreatedRows": { "type": "integer", "minimum": 0 },
        "equationAlignmentDiagnosticTermContextRows": { "type": "integer", "minimum": 0 },
        "tableCellProvenanceAuditRows": { "type": "integer", "minimum": 0 },
        "tableCellProvenanceTotalTableCells": { "type": "integer", "minimum": 0 },
        "tableCellProvenanceCellSourceSpanRows": { "type": "integer", "minimum": 0 },
        "tableCellProvenanceCitationGradeRows": { "type": "integer", "minimum": 0 },
        "figureRegionLinkAuditRows": { "type": "integer", "minimum": 0 },
        "figureRegionLinkCaptionSourceSpanRows": { "type": "integer", "minimum": 0 },
        "figureRegionLinkVerifiedRows": { "type": "integer", "minimum": 0 },
        "candidateLayerBlockerDecisionRecordRows": { "type": "integer", "minimum": 0 },
        "candidateLayerBlockerDecisionNeedsReviewRows": { "type": "integer", "minimum": 0 },
        "candidateLayerBlockerManualApprovalRows": { "type": "integer", "minimum": 0 },
        "candidateLayerBlockerOperatorApprovedRows": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "candidateLayerReviewReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "candidateLayerReviewReady": { "type": "boolean" },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "decision": { "type": "string", "enum": ["blocker_backlog_ready", "blocked"] },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "backlogOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "backlogOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "backlog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "backlog_id",
          "blocker",
          "status",
          "priority",
          "category",
          "affected_layers",
          "affected_candidate_count",
          "affected_eval_question_count",
          "evidenceNeededBeforePromotion",
          "recommendedNextTranche",
          "allowedActions",
          "disallowedActions",
          "stopRule",
          "evidence_tier",
          "strict_eligible",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "backlog_id": { "type": "string" },
          "blocker": { "type": "string" },
          "status": { "const": "open" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "category": { "type": "string" },
          "affected_layers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["sectionspan", "figure_caption", "equation_quote", "table_region"]
            }
          },
          "affected_candidate_count": { "type": "integer", "minimum": 0 },
          "affected_eval_question_count": { "type": "integer", "minimum": 0 },
          "evidenceNeededBeforePromotion": { "type": "array", "items": { "type": "string" } },
          "recommendedNextTranche": { "type": "string" },
          "allowedActions": { "type": "array", "items": { "type": "string" } },
          "disallowedActions": { "type": "array", "items": { "type": "string" } },
          "stopRule": { "type": "string" },
          "evidence_tier": { "const": "candidate_backlog_only" },
          "strict_eligible": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
