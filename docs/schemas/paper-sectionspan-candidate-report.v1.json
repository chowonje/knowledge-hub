{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.sectionspan-candidate-report.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "policy",
    "promotionRules",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.sectionspan-candidate-report.v1" },
    "status": { "type": "string", "enum": ["ok", "empty"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "required": ["decisionReviewPath"],
      "properties": {
        "decisionReviewPath": { "type": "string" },
        "schemaDesignPath": { "type": "string" },
        "decisionReviewSchema": { "type": "string" },
        "schemaDesignStatus": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputReviewCards",
        "sectionSpanCandidates",
        "heldOutCandidates",
        "strictEligibleCandidates",
        "citationGradeCandidates",
        "bySectionType",
        "byPaper",
        "heldOutByReason"
      ],
      "properties": {
        "inputReviewCards": { "type": "integer", "minimum": 0 },
        "sectionSpanCandidates": { "type": "integer", "minimum": 0 },
        "heldOutCandidates": { "type": "integer", "minimum": 0 },
        "strictEligibleCandidates": { "const": 0 },
        "citationGradeCandidates": { "const": 0 },
        "bySectionType": { "type": "object" },
        "byPaper": { "type": "object" },
        "heldOutByReason": { "type": "object" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "allCandidatesNonStrict",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed"
      ],
      "properties": {
        "allCandidatesNonStrict": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false }
      },
      "additionalProperties": true
    },
    "promotionRules": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "candidate_type",
          "source_candidate_id",
          "paper_id",
          "source_parser",
          "candidate_text",
          "section_label",
          "section_title",
          "section_type",
          "section_level",
          "canonical_alignment_status",
          "alignment_method",
          "chars_start",
          "chars_end",
          "page",
          "sourceContentHash",
          "confidence",
          "source_span_locator",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "candidate_id": { "type": "string" },
          "candidate_type": { "const": "section_span_candidate" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "source_parser": { "const": "mineru+pymupdf_alignment" },
          "candidate_text": { "type": "string" },
          "section_label": { "type": "string" },
          "section_title": { "type": "string" },
          "section_type": {
            "type": "string",
            "enum": ["numbered_section", "abstract", "backmatter", "named_section"]
          },
          "section_level": { "type": "integer", "minimum": 0 },
          "canonical_alignment_status": { "const": "aligned" },
          "alignment_method": { "const": "exact" },
          "chars_start": { "type": "integer", "minimum": 0 },
          "chars_end": { "type": "integer", "minimum": 0 },
          "page": { "type": "integer", "minimum": 1 },
          "sourceContentHash": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_span_locator": { "type": "object" },
          "review": { "type": "object" },
          "evidence_tier": { "const": "sectionspan_candidate_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "heldOut": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sourceReviewCardId", "sourceCandidateId", "paperId", "candidateText", "reviewClass", "reason"],
        "properties": {
          "sourceReviewCardId": { "type": "string" },
          "sourceCandidateId": { "type": "string" },
          "paperId": { "type": "string" },
          "candidateText": { "type": "string" },
          "reviewClass": { "type": "string" },
          "reason": { "type": "string" },
          "strictEligible": { "const": false },
          "citationGrade": { "const": false }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
