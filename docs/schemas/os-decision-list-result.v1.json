{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.os.decision.list.result.v1",
  "type": "object",
  "required": ["schema", "status", "count", "items", "createdAt"],
  "properties": {
    "schema": { "const": "knowledge-hub.os.decision.list.result.v1" },
    "status": { "type": "string", "enum": ["ok", "failed"] },
    "count": { "type": "integer", "minimum": 0 },
    "items": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "createdAt": { "type": "string" }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "required": ["sourceType"],
      "properties": {
        "sourceType": { "type": "string", "enum": ["paper", "web", "vault", "scope", "document"] },
        "paperId": { "type": "string" },
        "url": { "type": "string" },
        "noteId": { "type": "string" },
        "stableScopeId": { "type": "string" },
        "documentScopeId": { "type": "string" },
        "title": { "type": "string" }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["id", "projectId", "kind", "summary", "rationale", "sourceRefs", "createdByType", "createdById", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "goalId": { "type": "string" },
        "taskId": { "type": "string" },
        "kind": { "type": "string" },
        "summary": { "type": "string" },
        "rationale": { "type": "string" },
        "sourceRefs": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } },
        "createdByType": { "type": "string", "enum": ["human", "agent", "system"] },
        "createdById": { "type": "string" },
        "supersedesDecisionId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
