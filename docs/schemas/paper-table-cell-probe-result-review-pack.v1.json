{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.table-cell-probe-result-review-pack.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "reviewCards"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.table-cell-probe-result-review-pack.v1" },
    "status": { "type": "string", "enum": ["review_pack_ready", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": ["tableCellExtractorPilotReport", "tableCellExtractorPilotSchema"],
      "properties": {
        "tableCellExtractorPilotReport": { "type": "string" },
        "tableCellExtractorPilotSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "reviewCardRows",
        "pymupdfOverlayCandidateRows",
        "alternativeExtractorRequiredRows",
        "heldOutRows",
        "blockedRows",
        "cellBboxCandidateRows",
        "selectedTableCellBboxCandidates",
        "selectedTableCellTextCandidates",
        "diagnosticUniqueCellTextMatches",
        "diagnosticAmbiguousCellTextMatches",
        "cellBboxTextPairingVerifiedRows",
        "cellSourceSpanCreatedRows",
        "cellSourceHashLinkedRows",
        "tableCellEvidenceCreatedRows",
        "tableCellCitationGradeRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "schemaViolationCount",
        "unsafeUpstreamFlagCount",
        "byPaper",
        "byProbeStatus",
        "byReviewStatus",
        "strictBlockerSummary"
      ],
      "properties": {
        "reviewCardRows": { "type": "integer", "minimum": 0 },
        "pymupdfOverlayCandidateRows": { "type": "integer", "minimum": 0 },
        "alternativeExtractorRequiredRows": { "type": "integer", "minimum": 0 },
        "heldOutRows": { "type": "integer", "minimum": 0 },
        "blockedRows": { "type": "integer", "minimum": 0 },
        "cellBboxCandidateRows": { "type": "integer", "minimum": 0 },
        "selectedTableCellBboxCandidates": { "type": "integer", "minimum": 0 },
        "selectedTableCellTextCandidates": { "type": "integer", "minimum": 0 },
        "diagnosticUniqueCellTextMatches": { "type": "integer", "minimum": 0 },
        "diagnosticAmbiguousCellTextMatches": { "type": "integer", "minimum": 0 },
        "cellBboxTextPairingVerifiedRows": { "const": 0 },
        "cellSourceSpanCreatedRows": { "const": 0 },
        "cellSourceHashLinkedRows": { "const": 0 },
        "tableCellEvidenceCreatedRows": { "const": 0 },
        "tableCellCitationGradeRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object" },
        "byProbeStatus": { "type": "object" },
        "byReviewStatus": { "type": "object" },
        "strictBlockerSummary": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "reviewPackReady",
        "pymupdfOverlayCandidateObserved",
        "alternativeExtractorRequired",
        "extractorChoiceMade",
        "cellBboxTextPairingVerified",
        "cellSourceSpansCreated",
        "cellSourceHashLinked",
        "tableCellEvidenceReady",
        "tableCellCitationGradeReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "unsafeUpstreamFlags",
        "recommendedNextTranche"
      ],
      "properties": {
        "reviewPackReady": { "type": "boolean" },
        "pymupdfOverlayCandidateObserved": { "type": "boolean" },
        "alternativeExtractorRequired": { "type": "boolean" },
        "extractorChoiceMade": { "const": false },
        "cellBboxTextPairingVerified": { "const": false },
        "cellSourceSpansCreated": { "const": false },
        "cellSourceHashLinked": { "const": false },
        "tableCellEvidenceReady": { "const": false },
        "tableCellCitationGradeReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": ["ready_for_table_cell_probe_human_review", "blocked"]
        },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "unsafeUpstreamFlags": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "reviewOnly",
        "extractorChoiceMade",
        "tableCellEvidenceCreated",
        "tableCellCitationGradeEvidenceCreated",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "reviewOnly": { "const": true },
        "extractorChoiceMade": { "const": false },
        "tableCellEvidenceCreated": { "const": false },
        "tableCellCitationGradeEvidenceCreated": { "const": false },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "reviewCards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "review_card_id",
          "source_pilot_row_id",
          "source_table_region_candidate_id",
          "paper_id",
          "candidate_type",
          "source_parser",
          "table_label",
          "candidate_text",
          "page",
          "sourceContentHash",
          "probe_status",
          "review_status",
          "recommended_review_action",
          "selected_table_cell_bbox_count",
          "selected_table_cell_text_count",
          "diagnostic_unique_cell_text_matches",
          "diagnostic_ambiguous_cell_text_matches",
          "cell_bbox_candidates_observed",
          "cell_bbox_text_pairing_verified",
          "cell_source_spans_created",
          "cell_source_hash_linkages_created",
          "table_cell_evidence_created",
          "table_cell_citation_grade",
          "extractor_choice_made",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "review_card_id": { "type": "string" },
          "source_pilot_row_id": { "type": "string" },
          "source_authority_design_id": { "type": "string" },
          "source_review_card_id": { "type": "string" },
          "source_table_region_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_type": { "const": "table_cell_probe_result_review_card" },
          "source_parser": { "const": "pymupdf_table_probe" },
          "table_label": { "type": "string" },
          "candidate_text": { "type": "string" },
          "page": { "type": ["integer", "null"], "minimum": 1 },
          "sourceContentHash": { "type": "string" },
          "probe_status": { "type": "string" },
          "review_status": {
            "type": "string",
            "enum": [
              "pymupdf_overlay_candidate_needs_pairing_review",
              "requires_alternative_table_extractor",
              "held_out_authority_design_not_ready",
              "held_out_max_ready_rows_exceeded",
              "blocked_probe_input",
              "blocked_probe_failed_or_unknown"
            ]
          },
          "recommended_review_action": { "type": "string" },
          "probe_attempted": { "type": "boolean" },
          "probe_failure_reason": { "type": "string" },
          "detected_table_count": { "type": "integer", "minimum": 0 },
          "selected_table_index": { "type": "integer", "minimum": 0 },
          "selected_table_bbox": {
            "anyOf": [
              {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": { "type": "number" }
              },
              { "type": "null" }
            ]
          },
          "selected_table_row_count": { "type": "integer", "minimum": 0 },
          "selected_table_column_count": { "type": "integer", "minimum": 0 },
          "selected_table_cell_bbox_count": { "type": "integer", "minimum": 0 },
          "selected_table_cell_text_count": { "type": "integer", "minimum": 0 },
          "diagnostic_unique_cell_text_matches": { "type": "integer", "minimum": 0 },
          "diagnostic_ambiguous_cell_text_matches": { "type": "integer", "minimum": 0 },
          "diagnostic_no_match_cell_texts": { "type": "integer", "minimum": 0 },
          "sample_cell_bboxes": { "type": "array", "items": { "type": "array" } },
          "sample_cell_text_matches": { "type": "array", "items": { "type": "object" } },
          "cell_bbox_candidates_observed": { "type": "boolean" },
          "cell_bbox_text_pairing_verified": { "const": false },
          "cell_source_spans_created": { "const": 0 },
          "cell_source_hash_linkages_created": { "const": 0 },
          "table_cell_evidence_created": { "const": false },
          "table_cell_citation_grade": { "const": false },
          "extractor_choice_made": { "const": false },
          "evidence_tier": { "const": "table_cell_probe_result_review_card_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
