{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.strict-evidence-eligibility-record.v1",
  "type": "object",
  "required": [
    "schema",
    "eligibilityRecordId",
    "runId",
    "plannedWriteTarget",
    "paperId",
    "artifactType",
    "strictEvidenceId",
    "sourceSpanId",
    "candidateRecordId",
    "decisionRowId",
    "holdRowId",
    "eligibilityPolicyVersion",
    "eligibilityDecision",
    "eligibilityState",
    "strictEvidenceInPlaceMutationAllowed",
    "strictEligibleBooleanMutationAllowed",
    "strictEligibleMutationApplied",
    "citationGrade",
    "runtimeEvidence",
    "runtimeVisible",
    "idempotencyKey",
    "provenanceTrace",
    "writePolicy"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.strict-evidence-eligibility-record.v1" },
    "eligibilityRecordId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "plannedWriteTarget": { "const": "parsed_artifact_strict_evidence_eligibility_store" },
    "paperId": { "type": "string", "minLength": 1 },
    "artifactType": { "type": "string", "enum": ["section", "figure"] },
    "strictEvidenceId": { "type": "string", "minLength": 1 },
    "sourceSpanId": { "type": "string", "minLength": 1 },
    "candidateRecordId": { "type": "string", "minLength": 1 },
    "decisionRowId": { "type": "string", "minLength": 1 },
    "holdRowId": { "type": "string", "minLength": 1 },
    "eligibilityPolicyVersion": { "const": "strict_evidence_eligibility_policy.v1" },
    "eligibilityDecision": { "const": "eligible_for_citation_grade_gate_candidate_only" },
    "eligibilityState": { "const": "strict_evidence_eligible_candidate_only" },
    "strictEvidenceInPlaceMutationAllowed": { "const": false },
    "strictEligibleBooleanMutationAllowed": { "const": false },
    "strictEligibleMutationApplied": { "const": false },
    "citationGrade": { "const": false },
    "runtimeEvidence": { "const": false },
    "runtimeVisible": { "const": false },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "provenanceTrace": {
      "type": "object",
      "required": [
        "strictEvidenceId",
        "sourceSpanId",
        "candidateRecordId",
        "decisionRowId",
        "holdRowId"
      ],
      "properties": {
        "strictEvidenceId": { "type": "string", "minLength": 1 },
        "sourceSpanId": { "type": "string", "minLength": 1 },
        "candidateRecordId": { "type": "string", "minLength": 1 },
        "decisionRowId": { "type": "string", "minLength": 1 },
        "holdRowId": { "type": "string", "minLength": 1 },
        "decision": { "type": "string" }
      },
      "additionalProperties": true
    },
    "writePolicy": {
      "type": "object",
      "required": [
        "executorRequired",
        "eligibilityRecordWrite",
        "strictEvidenceStoreWrite",
        "sourceSpanStoreWrite",
        "strictEligibleMutation",
        "citationGradeEvidenceCreated",
        "runtimeEvidenceCreated",
        "databaseMutation",
        "parserRoutingChanged",
        "answerIntegrationChanged",
        "reindexOrReembed",
        "canonicalParsedArtifactsWritten"
      ],
      "properties": {
        "executorRequired": { "const": true },
        "eligibilityRecordWrite": { "const": false },
        "strictEvidenceStoreWrite": { "const": false },
        "sourceSpanStoreWrite": { "const": false },
        "strictEligibleMutation": { "const": false },
        "citationGradeEvidenceCreated": { "const": false },
        "runtimeEvidenceCreated": { "const": false },
        "databaseMutation": { "const": false },
        "parserRoutingChanged": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "reindexOrReembed": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
