{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-hub.local/schemas/learning-gap-result.v1.json",
  "title": "knowledge-hub learning gap result v1",
  "type": "object",
  "required": ["schema", "runId", "topic", "status", "policy", "summary", "missingTrunks", "weakEdges", "evidenceGaps", "createdAt", "updatedAt"],
  "properties": {
    "schema": {"const": "knowledge-hub.learning.gap.result.v1"},
    "runId": {"type": "string"},
    "topic": {"type": "string"},
    "status": {"type": "string", "enum": ["ok", "blocked", "error"]},
    "policy": {"type": "object"},
    "session": {"type": "object"},
    "summary": {"type": "object"},
    "targetTrunkIds": {"type": "array", "items": {"type": "string"}},
    "missingTrunks": {"type": "array", "items": {"type": "object"}},
    "weakEdges": {"type": "array", "items": {"type": "object"}},
    "evidenceGaps": {"type": "array", "items": {"type": "object"}},
    "parseErrors": {"type": "array", "items": {"type": "string"}},
    "router": {"type": "object"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "policyErrors": {"type": "array", "items": {"type": "string"}},
    "schemaErrors": {"type": "array", "items": {"type": "string"}},
    "createdAt": {"type": "string"},
    "updatedAt": {"type": "string"}
  },
  "additionalProperties": true
}
