{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.candidate-layer-blocker-decision-file-draft.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "decisionFileDraft",
    "draftRows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.candidate-layer-blocker-decision-file-draft.v1" },
    "status": { "type": "string", "enum": ["decision_file_draft_ready", "no_draft_rows", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "candidateLayerBlockerDecisionInputPackReport",
        "candidateLayerBlockerDecisionInputPackSchema"
      ],
      "properties": {
        "candidateLayerBlockerDecisionInputPackReport": { "type": "string" },
        "candidateLayerBlockerDecisionInputPackSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "draftRows",
        "needsReviewRows",
        "nonNeedsReviewRows",
        "acceptedDecisionRows",
        "operatorApprovedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "unsafeUpstreamFlagCount",
        "byBucket",
        "byPriority",
        "byLayer"
      ],
      "properties": {
        "draftRows": { "type": "integer", "minimum": 0 },
        "needsReviewRows": { "type": "integer", "minimum": 0 },
        "nonNeedsReviewRows": { "const": 0 },
        "acceptedDecisionRows": { "const": 0 },
        "operatorApprovedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "byBucket": { "type": "object" },
        "byPriority": { "type": "object" },
        "byLayer": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "decisionFileDraftReady",
        "containsOnlyNeedsReviewDefaults",
        "containsAcceptedDecisions",
        "containsOperatorApprovals",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "unsafeUpstreamFlags",
        "recommendedNextTranche"
      ],
      "properties": {
        "decisionFileDraftReady": { "type": "boolean" },
        "containsOnlyNeedsReviewDefaults": { "const": true },
        "containsAcceptedDecisions": { "const": false },
        "containsOperatorApprovals": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": ["needs_review_draft_ready_for_manual_edit", "no_pending_decision_inputs", "blocked"]
        },
        "unsafeUpstreamFlags": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "decisionFileDraftOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "decisionFileDraftOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "decisionFileDraft": {
      "type": "object",
      "required": ["draftOnly", "instructions", "decisions"],
      "properties": {
        "draftOnly": { "const": true },
        "instructions": { "type": "array", "items": { "type": "string" } },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "source_decision_row_id",
              "decision",
              "reviewer",
              "notes",
              "allowed_decisions",
              "review_bucket",
              "blocker"
            ],
            "properties": {
              "source_decision_row_id": { "type": "string" },
              "decision": { "const": "needs_review" },
              "reviewer": { "type": "string" },
              "notes": { "type": "string" },
              "allowed_decisions": { "type": "array", "items": { "type": "string" } },
              "review_bucket": { "type": "string" },
              "blocker": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "draftRows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "draft_row_id",
          "source_input_row_id",
          "source_decision_row_id",
          "source_review_card_id",
          "source_backlog_id",
          "blocker",
          "priority",
          "review_bucket",
          "affected_layers",
          "allowed_decisions",
          "decision",
          "reviewer",
          "notes",
          "draft_only",
          "decision_scope",
          "evidence_tier",
          "report_only",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "draft_row_id": { "type": "string" },
          "source_input_row_id": { "type": "string" },
          "source_decision_row_id": { "type": "string" },
          "source_review_card_id": { "type": "string" },
          "source_backlog_id": { "type": "string" },
          "blocker": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "review_bucket": {
            "type": "string",
            "enum": [
              "manual_decision_required",
              "operator_approval_required",
              "technical_feasibility_blocked",
              "policy_review_only"
            ]
          },
          "affected_layers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["sectionspan", "figure_caption", "equation_quote", "table_region"]
            }
          },
          "allowed_decisions": { "type": "array", "items": { "type": "string" } },
          "decision": { "const": "needs_review" },
          "reviewer": { "type": "string" },
          "notes": { "type": "string" },
          "draft_only": { "const": true },
          "decision_scope": {
            "const": "candidate_layer_blocker_decision_file_draft_only_no_runtime_or_strict_promotion"
          },
          "evidence_tier": { "const": "candidate_layer_blocker_decision_file_draft_only" },
          "report_only": { "const": true },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
