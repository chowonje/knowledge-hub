{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.tex-equation-pdf-region-anchor-audit.v1",
  "title": "TeX Equation PDF Region Anchor Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.tex-equation-pdf-region-anchor-audit.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lineLocalAnchorReportPath", "lineLocalAnchorReportSchema", "parsedRoot", "paperIds"],
      "properties": {
        "lineLocalAnchorReportPath": { "type": "string" },
        "lineLocalAnchorReportSchema": { "type": "string" },
        "parsedRoot": { "type": "string" },
        "paperIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lineLocalAnchorRows",
        "normalizedWindowRows",
        "pdfRegionCandidateRows",
        "uniquePdfRegionAnchorRows",
        "pdfRegionResolvedAmbiguousRows",
        "pdfRegionWithoutLineLocalWindowRows",
        "ambiguousPdfRegionAnchorRows",
        "failedPdfRegionAnchorRows",
        "sourceSpanCreatedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "schemaViolationCount",
        "byPaper",
        "byPdfRegionAnchorStatus"
      ],
      "properties": {
        "lineLocalAnchorRows": { "type": "integer", "minimum": 0 },
        "normalizedWindowRows": { "type": "integer", "minimum": 0 },
        "pdfRegionCandidateRows": { "type": "integer", "minimum": 0 },
        "uniquePdfRegionAnchorRows": { "type": "integer", "minimum": 0 },
        "pdfRegionResolvedAmbiguousRows": { "type": "integer", "minimum": 0 },
        "pdfRegionWithoutLineLocalWindowRows": { "type": "integer", "minimum": 0 },
        "ambiguousPdfRegionAnchorRows": { "type": "integer", "minimum": 0 },
        "failedPdfRegionAnchorRows": { "type": "integer", "minimum": 0 },
        "sourceSpanCreatedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byPdfRegionAnchorStatus": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pdfRegionAnchorAuditReady",
        "sourceSpanCreationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "pdfRegionAnchorAuditReady": { "type": "boolean" },
        "sourceSpanCreationReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string" },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportOnly",
        "pdfRegionAnchorAuditOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "equationInterpretationAllowed"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "pdfRegionAnchorAuditOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "equationInterpretationAllowed": { "const": false }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pdf_region_anchor_id",
          "source_line_local_anchor_id",
          "source_design_id",
          "source_candidate_id",
          "paper_id",
          "candidate_type",
          "source_parser",
          "source_file",
          "equation_environment",
          "candidate_text",
          "normalized_terms",
          "normalized_window_count",
          "line_local_anchor_status",
          "line_local_anchor_method",
          "canonical_page_markers",
          "source_pdf_path",
          "source_manifest_path",
          "sourceContentHash",
          "input_sourceContentHash",
          "source_hash_agrees_with_input",
          "pdf_region_anchor_status",
          "pdf_region_anchor_method",
          "pdf_region_candidate_count",
          "pdf_region_candidates",
          "selected_pdf_region",
          "pdf_region_anchor_unique",
          "line_local_ambiguity_resolved_by_pdf_region",
          "feasibility_failure_reason",
          "chars_start",
          "chars_end",
          "page",
          "bbox",
          "source_span_created",
          "equation_semantics_interpreted",
          "equation_region_verified",
          "evidence_tier",
          "confidence",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "pdf_region_anchor_id": { "type": "string" },
          "source_line_local_anchor_id": { "type": "string" },
          "source_design_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_type": { "const": "tex_equation_pdf_region_anchor_candidate" },
          "source_parser": { "const": "arxiv_tex+pymupdf_pdf_blocks" },
          "source_file": { "type": "string" },
          "equation_environment": { "type": "string" },
          "candidate_text": { "type": "string" },
          "normalized_terms": { "type": "array", "items": { "type": "string" } },
          "normalized_window_count": { "type": "integer", "minimum": 0 },
          "line_local_anchor_status": { "type": "string" },
          "line_local_anchor_method": { "type": "string" },
          "canonical_page_markers": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
          "source_pdf_path": { "type": "string" },
          "source_manifest_path": { "type": "string" },
          "sourceContentHash": { "type": "string" },
          "input_sourceContentHash": { "type": "string" },
          "source_hash_agrees_with_input": { "type": "boolean" },
          "pdf_region_anchor_status": { "type": "string" },
          "pdf_region_anchor_method": { "type": "string" },
          "pdf_region_candidate_count": { "type": "integer", "minimum": 0 },
          "pdf_region_candidates": {
            "type": "array",
            "items": { "$ref": "#/$defs/pdfRegionCandidate" }
          },
          "selected_pdf_region": {
            "type": "object",
            "additionalProperties": false,
            "required": ["page", "bbox", "block_indexes", "matched_terms", "coverage", "formula_score", "equation_numbers", "text_preview"],
            "properties": {
              "page": { "type": ["integer", "null"] },
              "bbox": { "type": "array", "items": { "type": "number" } },
              "block_indexes": { "type": "array", "items": { "type": "integer" } },
              "matched_terms": { "type": "array", "items": { "type": "string" } },
              "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
              "formula_score": { "type": "number", "minimum": 0 },
              "equation_numbers": { "type": "array", "items": { "type": "string" } },
              "text_preview": { "type": "string" }
            }
          },
          "pdf_region_anchor_unique": { "type": "boolean" },
          "line_local_ambiguity_resolved_by_pdf_region": { "type": "boolean" },
          "feasibility_failure_reason": { "type": "string" },
          "chars_start": { "type": ["integer", "null"] },
          "chars_end": { "type": ["integer", "null"] },
          "page": { "type": ["integer", "null"] },
          "bbox": { "type": "array", "items": { "type": "number" } },
          "source_span_created": { "const": false },
          "equation_semantics_interpreted": { "const": false },
          "equation_region_verified": { "const": false },
          "evidence_tier": { "const": "tex_equation_pdf_region_anchor_candidate_only" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "$defs": {
    "pdfRegionCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_index",
        "page",
        "block_indexes",
        "bbox",
        "window_size",
        "matched_terms",
        "coverage",
        "formula_score",
        "has_equal_sign",
        "equation_numbers",
        "symbol_ratio",
        "line_count",
        "text_length",
        "text_preview",
        "rank"
      ],
      "properties": {
        "candidate_index": { "type": "integer", "minimum": 1 },
        "page": { "type": "integer", "minimum": 1 },
        "block_indexes": { "type": "array", "items": { "type": "integer" } },
        "bbox": { "type": "array", "items": { "type": "number" } },
        "window_size": { "type": "integer", "minimum": 1 },
        "matched_terms": { "type": "array", "items": { "type": "string" } },
        "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "formula_score": { "type": "number", "minimum": 0 },
        "has_equal_sign": { "type": "boolean" },
        "equation_numbers": { "type": "array", "items": { "type": "string" } },
        "symbol_ratio": { "type": "number", "minimum": 0 },
        "line_count": { "type": "integer", "minimum": 1 },
        "text_length": { "type": "integer", "minimum": 0 },
        "text_preview": { "type": "string" },
        "rank": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
