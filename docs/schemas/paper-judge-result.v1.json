{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "status", "topic", "backend", "threshold", "candidateCount", "selectedCount", "degraded", "warnings", "items"],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.judge.result.v1" },
    "status": { "type": "string" },
    "topic": { "type": "string" },
    "backend": { "type": "string" },
    "threshold": { "type": "number" },
    "candidateCount": { "type": "integer" },
    "selectedCount": { "type": "integer" },
    "degraded": { "type": "boolean" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paper_id", "title", "decision", "total_score", "dimension_scores", "top_reasons", "backend", "policy"],
        "properties": {
          "paper_id": { "type": "string" },
          "arxiv_id": { "type": "string" },
          "title": { "type": "string" },
          "decision": { "type": "string" },
          "total_score": { "type": "number" },
          "dimension_scores": { "type": "object" },
          "top_reasons": { "type": "array", "items": { "type": "string" } },
          "backend": { "type": "string" },
          "degraded": { "type": "boolean" },
          "policy": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
