      "type": "object",
      "required": [
        "postPilotPromotionHoldReviewReady",
        "holdDecision",
        "strictEligibleMutationAllowed",
        "citationGradeAllowed",
        "runtimeEvidenceAllowed",
        "parserRoutingAllowed",
        "answerIntegrationAllowed",
        "databaseMutationAllowed",
        "reindexOrReembedAllowed",
        "strictEvidenceStoreWriteAllowed",
        "sourceSpanStoreWriteAllowed",
        "runManifestWriteAllowed",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "postPilotPromotionHoldReviewReady": { "type": "boolean" },
        "holdDecision": { "type": "string" },
        "strictEligibleMutationAllowed": { "const": false },
        "citationGradeAllowed": { "const": false },
        "runtimeEvidenceAllowed": { "const": false },
        "parserRoutingAllowed": { "const": false },
        "answerIntegrationAllowed": { "const": false },
        "databaseMutationAllowed": { "const": false },
        "reindexOrReembedAllowed": { "const": false },
        "strictEvidenceStoreWriteAllowed": { "const": false },
        "sourceSpanStoreWriteAllowed": { "const": false },
        "runManifestWriteAllowed": { "const": false },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": ["reportOnly", "holdReviewOnly"],
      "properties": {
        "reportOnly": { "const": true },
        "holdReviewOnly": { "const": true }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
