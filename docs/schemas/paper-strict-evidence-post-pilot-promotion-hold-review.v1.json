        "inputPolicyCandidateRows": { "type": "integer", "minimum": 0 },
        "validatedPilotRows": { "type": "integer", "minimum": 0 },
        "holdActiveRows": { "type": "integer", "minimum": 0 },
        "sectionHoldRows": { "type": "integer", "minimum": 0 },
        "figureCaptionHoldRows": { "type": "integer", "minimum": 0 },
        "blockedCompletionGateNotCandidateRows": { "type": "integer", "minimum": 0 },
        "blockedPilotNotCompleteRows": { "type": "integer", "minimum": 0 },
        "blockedDownstreamGateAlreadyEnabledRows": { "type": "integer", "minimum": 0 },
        "blockedStoreRowCountChangedRows": { "type": "integer", "minimum": 0 },
        "blockedInputSchemaViolationRows": { "type": "integer", "minimum": 0 },
        "strictEligibleMutationAllowedRows": { "type": "integer", "minimum": 0 },
        "citationGradeAllowedRows": { "type": "integer", "minimum": 0 },
        "runtimeEvidenceAllowedRows": { "type": "integer", "minimum": 0 },
        "parserRoutingAllowedRows": { "type": "integer", "minimum": 0 },
        "answerIntegrationAllowedRows": { "type": "integer", "minimum": 0 },
        "strictEvidenceStoreRows": { "type": "integer", "minimum": 0 },
        "sourceSpanStoreRows": { "type": "integer", "minimum": 0 },
        "strictEvidenceWriteRows": { "const": 0 },
        "strictEvidenceCreatedRows": { "const": 0 },
        "citationGradeEvidenceCreatedRows": { "const": 0 },
        "runtimeEvidenceCreatedRows": { "const": 0 },
        "parserRoutingChangedRows": { "const": 0 },
        "answerIntegrationChangedRows": { "const": 0 },
        "databaseMutationRows": { "const": 0 },
        "canonicalParsedArtifactWriteRows": { "const": 0 },
        "sourceSpanUpdatedRows": { "const": 0 },
        "manifestWriteRows": { "const": 0 },
        "reindexOrReembedRows": { "const": 0 },
