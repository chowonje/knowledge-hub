          "sourceSpanId": { "type": "string" },
          "candidateRecordId": { "type": "string" },
          "paper_id": { "type": "string" },
          "artifact_type": { "type": "string", "enum": ["section", "figure"] },
          "manifestType": { "type": "string" },
          "completion_status": { "type": "string" },
          "hold_status": { "type": "string" },
          "hold_blockers": { "type": "array", "items": { "type": "string" } },
          "postPilotPromotionHoldActive": { "type": "boolean" },
          "strictEligibleMutationAllowed": { "const": false },
          "citationGradeAllowed": { "const": false },
          "runtimeEvidenceAllowed": { "const": false },
          "parserRoutingAllowed": { "const": false },
          "answerIntegrationAllowed": { "const": false },
          "databaseMutationAllowed": { "const": false },
          "reindexOrReembedAllowed": { "const": false },
          "strictEligible": { "const": false },
          "strictEvidenceCreated": { "const": false },
          "citationGrade": { "const": false },
          "runtimeEvidence": { "const": false },
          "parserRoutingChanged": { "const": false },
          "answerIntegrationChanged": { "const": false },
          "databaseMutation": { "const": false },
          "recommended_action": { "type": "string" }
