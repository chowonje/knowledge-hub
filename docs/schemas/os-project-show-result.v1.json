{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.os.project.show.result.v1",
  "type": "object",
  "required": ["schema", "status", "project", "goals", "tasks", "inbox", "createdAt"],
  "properties": {
    "schema": { "const": "knowledge-hub.os.project.show.result.v1" },
    "status": { "type": "string", "enum": ["ok", "failed"] },
    "project": { "$ref": "#/$defs/project" },
    "goals": { "type": "array", "items": { "$ref": "#/$defs/goal" } },
    "tasks": { "type": "array", "items": { "$ref": "#/$defs/task" } },
    "inbox": { "type": "array", "items": { "$ref": "#/$defs/inbox" } },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "projectEvidence": { "$ref": "#/$defs/projectEvidence" },
    "nextActionableTasks": { "type": "array", "items": { "$ref": "#/$defs/task" } },
    "blockedTasks": { "type": "array", "items": { "$ref": "#/$defs/task" } },
    "recentDecisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "createdAt": { "type": "string" }
  },
  "$defs": {
    "project": {
      "type": "object",
      "required": ["id", "title", "slug", "status", "priority", "summary", "owner", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "on_hold", "completed", "archived"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "summary": { "type": "string" },
        "owner": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "goal": {
      "type": "object",
      "required": ["id", "projectId", "title", "status", "successCriteria", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in_progress", "blocked", "completed", "dropped"] },
        "successCriteria": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sourceRef": {
      "type": "object",
      "required": ["sourceType"],
      "properties": {
        "sourceType": { "type": "string", "enum": ["paper", "web", "vault", "scope", "document"] },
        "paperId": { "type": "string" },
        "url": { "type": "string" },
        "noteId": { "type": "string" },
        "stableScopeId": { "type": "string" },
        "documentScopeId": { "type": "string" },
        "title": { "type": "string" }
      },
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "required": ["id", "projectId", "title", "kind", "status", "priority", "assignee", "blockedBy", "sourceRefs", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "goalId": { "type": "string" },
        "title": { "type": "string" },
        "kind": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in_progress", "blocked", "completed", "cancelled"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "assignee": { "type": "string" },
        "dueAt": { "type": "string" },
        "blockedBy": { "type": "array", "items": { "type": "string" } },
        "sourceRefs": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "inbox": {
      "type": "object",
      "required": ["id", "kind", "severity", "state", "summary", "sourceRefs", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "taskId": { "type": "string" },
        "kind": { "type": "string", "enum": ["blocked_task", "due_soon_task", "ops_alert"] },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "state": { "type": "string", "enum": ["open", "resolved"] },
        "summary": { "type": "string" },
        "sourceRefs": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["id", "projectId", "kind", "summary", "rationale", "sourceRefs", "createdByType", "createdById", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "goalId": { "type": "string" },
        "taskId": { "type": "string" },
        "kind": { "type": "string" },
        "summary": { "type": "string" },
        "rationale": { "type": "string" },
        "sourceRefs": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } },
        "createdByType": { "type": "string", "enum": ["human", "agent", "system"] },
        "createdById": { "type": "string" },
        "supersedesDecisionId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "projectEvidenceTaskLink": {
      "type": "object",
      "required": ["taskId", "title", "sourceRef"],
      "properties": {
        "taskId": { "type": "string" },
        "title": { "type": "string" },
        "sourceRef": { "$ref": "#/$defs/sourceRef" }
      },
      "additionalProperties": false
    },
    "projectEvidenceDecisionLink": {
      "type": "object",
      "required": ["decisionId", "summary", "sourceRef"],
      "properties": {
        "decisionId": { "type": "string" },
        "summary": { "type": "string" },
        "sourceRef": { "$ref": "#/$defs/sourceRef" }
      },
      "additionalProperties": false
    },
    "projectEvidenceInboxLink": {
      "type": "object",
      "required": ["inboxId", "summary", "sourceRef"],
      "properties": {
        "inboxId": { "type": "string" },
        "summary": { "type": "string" },
        "sourceRef": { "$ref": "#/$defs/sourceRef" }
      },
      "additionalProperties": false
    },
    "projectEvidenceTaskSummary": {
      "type": "object",
      "required": ["taskId", "title", "sourceRefs"],
      "properties": {
        "taskId": { "type": "string" },
        "title": { "type": "string" },
        "sourceRefs": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } }
      },
      "additionalProperties": false
    },
    "projectEvidenceDecisionSummary": {
      "type": "object",
      "required": ["decisionId", "summary", "sourceRefs"],
      "properties": {
        "decisionId": { "type": "string" },
        "summary": { "type": "string" },
        "sourceRefs": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } }
      },
      "additionalProperties": false
    },
    "projectEvidenceGroupedBySourceType": {
      "type": "object",
      "required": ["paper", "web", "vault", "scope", "document"],
      "properties": {
        "paper": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } },
        "web": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } },
        "vault": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } },
        "scope": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } },
        "document": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } }
      },
      "additionalProperties": false
    },
    "projectEvidence": {
      "type": "object",
      "required": [
        "projectId",
        "sourceRefs",
        "taskLinkedRefs",
        "decisionLinkedRefs",
        "inboxLinkedRefs",
        "groupedBySourceType",
        "recentDecisionEvidence",
        "nextTaskEvidence"
      ],
      "properties": {
        "projectId": { "type": "string" },
        "sourceRefs": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } },
        "taskLinkedRefs": { "type": "array", "items": { "$ref": "#/$defs/projectEvidenceTaskLink" } },
        "decisionLinkedRefs": { "type": "array", "items": { "$ref": "#/$defs/projectEvidenceDecisionLink" } },
        "inboxLinkedRefs": { "type": "array", "items": { "$ref": "#/$defs/projectEvidenceInboxLink" } },
        "groupedBySourceType": { "$ref": "#/$defs/projectEvidenceGroupedBySourceType" },
        "recentDecisionEvidence": { "type": "array", "items": { "$ref": "#/$defs/projectEvidenceDecisionSummary" } },
        "nextTaskEvidence": { "type": "array", "items": { "$ref": "#/$defs/projectEvidenceTaskSummary" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
