{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema",
    "status",
    "query",
    "sourceType",
    "retrievalMode",
    "topK",
    "alpha",
    "readOnly",
    "writeFree",
    "labsOnly",
    "runtimeApplied",
    "applied",
    "resultCount",
    "changedRankCount",
    "originalResults",
    "rerankedResults",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.rag.answerability-rerank.result.v1" },
    "status": { "type": "string" },
    "query": { "type": "string" },
    "sourceType": { "type": "string" },
    "retrievalMode": { "type": "string" },
    "topK": { "type": "integer" },
    "alpha": { "type": "number" },
    "readOnly": { "type": "boolean" },
    "writeFree": { "type": "boolean" },
    "labsOnly": { "type": "boolean" },
    "runtimeApplied": { "type": "boolean" },
    "applied": { "type": "boolean" },
    "resultCount": { "type": "integer" },
    "changedRankCount": { "type": "integer" },
    "retrievalStrategy": { "type": "object" },
    "answerabilityRerank": { "type": "object" },
    "originalResults": { "type": "array" },
    "rerankedResults": { "type": "array" },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
