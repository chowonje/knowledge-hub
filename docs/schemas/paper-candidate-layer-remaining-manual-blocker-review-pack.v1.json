{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.candidate-layer-remaining-manual-blocker-review-pack.v1",
  "title": "Candidate Layer Remaining Manual Blocker Review Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
