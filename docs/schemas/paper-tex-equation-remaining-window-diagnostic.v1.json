{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.tex-equation-remaining-window-diagnostic.v1",
  "title": "TeX Equation Remaining Window Diagnostic",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.tex-equation-remaining-window-diagnostic.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pdfRegionAnchorReportPath", "pdfRegionAnchorReportSchema", "paperIds"],
      "properties": {
        "pdfRegionAnchorReportPath": { "type": "string" },
        "pdfRegionAnchorReportSchema": { "type": "string" },
        "paperIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputRows",
        "diagnosticRows",
        "blockedNoLineLocalWindowRows",
        "sourceSpanCreatedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "parserRoutingChangedRows",
        "answerIntegrationChangedRows",
        "schemaViolationCount",
        "byPaper",
        "byEnvironment",
        "byDiagnosis",
        "byRecommendedAction"
      ],
      "properties": {
        "inputRows": { "type": "integer", "minimum": 0 },
        "diagnosticRows": { "type": "integer", "minimum": 0 },
        "blockedNoLineLocalWindowRows": { "type": "integer", "minimum": 0 },
        "sourceSpanCreatedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "parserRoutingChangedRows": { "const": 0 },
        "answerIntegrationChangedRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byEnvironment": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byDiagnosis": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byRecommendedAction": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnosticReady",
        "sourceSpanCreationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "diagnosticReady": { "type": "boolean" },
        "sourceSpanCreationReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string" },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allRowsNonStrict",
        "reportOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "equationInterpretationAllowed"
      ],
      "properties": {
        "allRowsNonStrict": { "const": true },
        "reportOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "equationInterpretationAllowed": { "const": false }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "diagnostic_id",
          "candidate_type",
          "source_pdf_region_anchor_id",
          "source_line_local_anchor_id",
          "source_design_id",
          "source_candidate_id",
          "paper_id",
          "source_parser",
          "source_file",
          "equation_environment",
          "candidate_text",
          "candidate_text_length",
          "normalized_terms",
          "normalized_term_count",
          "custom_latex_macros",
          "custom_latex_macro_count",
          "line_local_anchor_status",
          "pdf_region_anchor_status",
          "normalized_window_count",
          "pdf_region_candidate_count",
          "diagnoses",
          "recommended_action",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "source_span_created",
          "parser_routing_changed",
          "answer_integration_changed",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "diagnostic_id": { "type": "string" },
          "candidate_type": { "const": "tex_equation_remaining_window_diagnostic" },
          "source_pdf_region_anchor_id": { "type": "string" },
          "source_line_local_anchor_id": { "type": "string" },
          "source_design_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "source_parser": { "const": "arxiv_tex+pymupdf_pdf_blocks" },
          "source_file": { "type": "string" },
          "equation_environment": { "type": "string" },
          "candidate_text": { "type": "string" },
          "candidate_text_length": { "type": "integer", "minimum": 0 },
          "normalized_terms": { "type": "array", "items": { "type": "string" } },
          "normalized_term_count": { "type": "integer", "minimum": 0 },
          "custom_latex_macros": { "type": "array", "items": { "type": "string" } },
          "custom_latex_macro_count": { "type": "integer", "minimum": 0 },
          "line_local_anchor_status": { "type": "string" },
          "pdf_region_anchor_status": { "type": "string" },
          "normalized_window_count": { "type": "integer", "minimum": 0 },
          "pdf_region_candidate_count": { "type": "integer", "minimum": 0 },
          "diagnoses": { "type": "array", "items": { "type": "string" } },
          "recommended_action": { "type": "string" },
          "evidence_tier": { "const": "remaining_window_diagnostic_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "source_span_created": { "const": false },
          "parser_routing_changed": { "const": false },
          "answer_integration_changed": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
