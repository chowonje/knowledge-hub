{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.sectionspan-pdf-offset-recovery-review-pack.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "reviewCards"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.sectionspan-pdf-offset-recovery-review-pack.v1" },
    "status": { "type": "string", "enum": ["review_pack_ready", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "sectionspanPdfOffsetRecoveryDryRunReport",
        "sectionspanPdfOffsetRecoveryDryRunSchema"
      ],
      "properties": {
        "sectionspanPdfOffsetRecoveryDryRunReport": { "type": "string" },
        "sectionspanPdfOffsetRecoveryDryRunSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputRecoveryRows",
        "reviewCardRows",
        "readyForHumanReviewRows",
        "heldOutRows",
        "pageAgreementRows",
        "sourceHashAgreementRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "unsafeUpstreamFlagCount",
        "byPaper",
        "bySectionType",
        "byReviewStatus",
        "byMatchMethod"
      ],
      "properties": {
        "inputRecoveryRows": { "type": "integer", "minimum": 0 },
        "reviewCardRows": { "type": "integer", "minimum": 0 },
        "readyForHumanReviewRows": { "type": "integer", "minimum": 0 },
        "heldOutRows": { "type": "integer", "minimum": 0 },
        "pageAgreementRows": { "type": "integer", "minimum": 0 },
        "sourceHashAgreementRows": { "type": "integer", "minimum": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object" },
        "bySectionType": { "type": "object" },
        "byReviewStatus": { "type": "object" },
        "byMatchMethod": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "reviewPackReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "unsafeUpstreamFlags",
        "recommendedNextTranche"
      ],
      "properties": {
        "reviewPackReady": { "type": "boolean" },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string", "enum": ["review_pack_ready_non_strict", "blocked"] },
        "unsafeUpstreamFlags": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "reviewCards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "review_card_id",
          "source_recovery_plan_id",
          "source_sectionspan_candidate_id",
          "paper_id",
          "candidate_text",
          "section_type",
          "section_level",
          "canonical_span",
          "original_pdf_span",
          "page_agreement",
          "source_hash_agreement",
          "review_status",
          "review_recommendation",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "review_card_id": { "type": "string" },
          "source_recovery_plan_id": { "type": "string" },
          "source_sectionspan_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_text": { "type": "string" },
          "section_type": { "type": "string" },
          "section_level": { "type": "integer", "minimum": 0 },
          "canonical_span": { "type": "object" },
          "original_pdf_span": { "type": "object" },
          "page_agreement": { "type": "boolean" },
          "source_hash_agreement": { "type": "boolean" },
          "review_status": {
            "type": "string",
            "enum": [
              "ready_for_human_review",
              "held_out_recovery_blocked",
              "held_out_page_conflict",
              "held_out_source_hash_conflict"
            ]
          },
          "review_recommendation": { "type": "string" },
          "evidence_tier": { "const": "sectionspan_pdf_offset_recovery_review_card_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
