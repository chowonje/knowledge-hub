{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.tex-equation-label-number-pdf-region-disambiguation-design.v1",
  "title": "TeX Equation Label/Number PDF-Region Disambiguation Design",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.tex-equation-label-number-pdf-region-disambiguation-design.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "renderedMacroTermProfileDesignReportPath",
        "renderedMacroTermProfileDesignReportSchema",
        "arxivSourceTexAvailabilityReportPath",
        "arxivSourceTexAvailabilityReportSchema",
        "parsedRoot",
        "paperIds"
      ],
      "properties": {
        "renderedMacroTermProfileDesignReportPath": { "type": "string" },
        "renderedMacroTermProfileDesignReportSchema": { "type": "string" },
        "arxivSourceTexAvailabilityReportPath": { "type": "string" },
        "arxivSourceTexAvailabilityReportSchema": { "type": "string" },
        "parsedRoot": { "type": "string" },
        "paperIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputRows",
        "targetRows",
        "sourceLabelNumberHintRows",
        "candidateReadyRows",
        "uniqueDisambiguatedRows",
        "ambiguousDisambiguatedRows",
        "noMatchingPdfRegionRows",
        "sourceSpanCreatedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "parserRoutingChangedRows",
        "answerIntegrationChangedRows",
        "schemaViolationCount",
        "byPaper",
        "byEnvironment",
        "byDisambiguationStatus",
        "byRecommendedAction"
      ],
      "properties": {
        "inputRows": { "type": "integer", "minimum": 0 },
        "targetRows": { "type": "integer", "minimum": 0 },
        "sourceLabelNumberHintRows": { "type": "integer", "minimum": 0 },
        "candidateReadyRows": { "type": "integer", "minimum": 0 },
        "uniqueDisambiguatedRows": { "type": "integer", "minimum": 0 },
        "ambiguousDisambiguatedRows": { "type": "integer", "minimum": 0 },
        "noMatchingPdfRegionRows": { "type": "integer", "minimum": 0 },
        "sourceSpanCreatedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "parserRoutingChangedRows": { "const": 0 },
        "answerIntegrationChangedRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byEnvironment": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byDisambiguationStatus": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byRecommendedAction": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "designReady",
        "sourceSpanCreationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "designReady": { "type": "boolean" },
        "sourceSpanCreationReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string" },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allRowsNonStrict",
        "reportOnly",
        "designOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "equationInterpretationAllowed"
      ],
      "properties": {
        "allRowsNonStrict": { "const": true },
        "reportOnly": { "const": true },
        "designOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "equationInterpretationAllowed": { "const": false }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "design_id",
          "candidate_type",
          "source_rendered_macro_design_id",
          "source_diagnostic_id",
          "source_pdf_region_anchor_id",
          "source_line_local_anchor_id",
          "source_design_id",
          "source_candidate_id",
          "paper_id",
          "source_parser",
          "source_file",
          "equation_environment",
          "candidate_text",
          "latex_labels",
          "recommended_profile",
          "profile_normalized_terms",
          "profile_normalized_term_count",
          "source_context_status",
          "sourceContentHash",
          "source_pdf_path",
          "source_manifest_path",
          "source_label_number_hint",
          "pdf_region_candidates",
          "pdf_region_candidate_count",
          "label_number_matching_candidate_count",
          "selected_pdf_region",
          "disambiguation_status",
          "candidate_ready",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "source_span_created",
          "parser_routing_changed",
          "answer_integration_changed",
          "recommended_action",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "design_id": { "type": "string" },
          "candidate_type": { "const": "tex_equation_label_number_pdf_region_disambiguation_design" },
          "source_rendered_macro_design_id": { "type": "string" },
          "source_diagnostic_id": { "type": "string" },
          "source_pdf_region_anchor_id": { "type": "string" },
          "source_line_local_anchor_id": { "type": "string" },
          "source_design_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "source_parser": { "const": "arxiv_tex+pymupdf_pdf_blocks" },
          "source_file": { "type": "string" },
          "equation_environment": { "type": "string" },
          "candidate_text": { "type": "string" },
          "latex_labels": { "type": "array", "items": { "type": "string" } },
          "recommended_profile": { "type": "string" },
          "profile_normalized_terms": { "type": "array", "items": { "type": "string" } },
          "profile_normalized_term_count": { "type": "integer", "minimum": 0 },
          "source_context_status": { "type": "string" },
          "sourceContentHash": { "type": "string" },
          "source_pdf_path": { "type": "string" },
          "source_manifest_path": { "type": "string" },
          "source_label_number_hint": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sourceStructureRowId",
              "texEnvironment",
              "latexLabels",
              "inferredEquationNumbers",
              "method",
              "status"
            ],
            "properties": {
              "sourceStructureRowId": { "type": "string" },
              "texEnvironment": { "type": "string" },
              "latexLabels": { "type": "array", "items": { "type": "string" } },
              "inferredEquationNumbers": { "type": "array", "items": { "type": "string" } },
              "method": { "type": "string" },
              "status": { "type": "string" }
            }
          },
          "pdf_region_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "rank",
                "page",
                "bbox",
                "blockIndexes",
                "matchedTerms",
                "coverage",
                "formulaScore",
                "equationNumbers",
                "labelNumberMatch",
                "textPreview"
              ],
              "properties": {
                "rank": { "type": "integer", "minimum": 0 },
                "page": { "type": "integer", "minimum": 0 },
                "bbox": { "type": "array", "items": { "type": "number" } },
                "blockIndexes": { "type": "array", "items": { "type": "integer" } },
                "matchedTerms": { "type": "array", "items": { "type": "string" } },
                "coverage": { "type": "number" },
                "formulaScore": { "type": "number" },
                "equationNumbers": { "type": "array", "items": { "type": "string" } },
                "labelNumberMatch": { "type": "boolean" },
                "textPreview": { "type": "string" }
              }
            }
          },
          "pdf_region_candidate_count": { "type": "integer", "minimum": 0 },
          "label_number_matching_candidate_count": { "type": "integer", "minimum": 0 },
          "selected_pdf_region": {
            "type": "object",
            "additionalProperties": false,
            "required": ["page", "bbox", "blockIndexes", "matchedTerms", "coverage", "formulaScore", "equationNumbers", "textPreview"],
            "properties": {
              "page": { "type": ["integer", "null"] },
              "bbox": { "type": "array", "items": { "type": "number" } },
              "blockIndexes": { "type": "array", "items": { "type": "integer" } },
              "matchedTerms": { "type": "array", "items": { "type": "string" } },
              "coverage": { "type": "number" },
              "formulaScore": { "type": "number" },
              "equationNumbers": { "type": "array", "items": { "type": "string" } },
              "textPreview": { "type": "string" }
            }
          },
          "disambiguation_status": { "type": "string" },
          "candidate_ready": { "type": "boolean" },
          "evidence_tier": { "const": "label_number_pdf_region_disambiguation_design_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "source_span_created": { "const": false },
          "parser_routing_changed": { "const": false },
          "answer_integration_changed": { "const": false },
          "recommended_action": { "type": "string" },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
