{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper-memory.build.result.v1",
  "type": "object",
  "required": ["schema", "status", "mode", "count", "items", "warnings"],
  "properties": {
    "schema": { "const": "knowledge-hub.paper-memory.build.result.v1" },
    "status": { "type": "string", "enum": ["ok", "failed"] },
    "mode": { "type": "string", "enum": ["single", "rebuild_all"] },
    "count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/paperMemoryCard" }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "paperMemoryCard": {
      "type": "object",
      "required": [
        "memoryId",
        "paperId",
        "sourceNoteId",
        "title",
        "paperCore",
        "problemContext",
        "methodCore",
        "evidenceCore",
        "limitations",
        "conceptLinks",
        "claimRefs",
        "publishedAt",
        "evidenceWindow",
        "searchText",
        "qualityFlag",
        "version",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "memoryId": { "type": "string" },
        "paperId": { "type": "string" },
        "sourceNoteId": { "type": "string" },
        "title": { "type": "string" },
        "paperCore": { "type": "string" },
        "problemContext": { "type": "string" },
        "methodCore": { "type": "string" },
        "evidenceCore": { "type": "string" },
        "limitations": { "type": "string" },
        "conceptLinks": { "type": "array", "items": { "type": "string" } },
        "claimRefs": { "type": "array", "items": { "type": "string" } },
        "publishedAt": { "type": "string" },
        "evidenceWindow": { "type": "string" },
        "searchText": { "type": "string" },
        "qualityFlag": { "type": "string" },
        "version": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
