{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.sectionspan-pdf-offset-recovery-dry-run.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "paperContexts",
    "recoveryRows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.sectionspan-pdf-offset-recovery-dry-run.v1" },
    "status": { "type": "string", "enum": ["dry_run_complete", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "sectionspanPdfOffsetRecoveryDesignReport",
        "sectionspanPdfOffsetRecoveryDesignSchema",
        "pymupdfParsedRoot"
      ],
      "properties": {
        "sectionspanPdfOffsetRecoveryDesignReport": { "type": "string" },
        "sectionspanPdfOffsetRecoveryDesignSchema": { "type": "string" },
        "pymupdfParsedRoot": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputRecoveryPlanRows",
        "dryRunRows",
        "originalPdfOffsetRecoveredRows",
        "blockedRows",
        "exactRecoveredRows",
        "normalizedRecoveredRows",
        "ambiguousRows",
        "noMatchRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "schemaViolationCount",
        "byPaper",
        "bySectionType",
        "byRecoveryStatus"
      ],
      "properties": {
        "inputRecoveryPlanRows": { "type": "integer", "minimum": 0 },
        "dryRunRows": { "type": "integer", "minimum": 0 },
        "originalPdfOffsetRecoveredRows": { "type": "integer", "minimum": 0 },
        "blockedRows": { "type": "integer", "minimum": 0 },
        "exactRecoveredRows": { "type": "integer", "minimum": 0 },
        "normalizedRecoveredRows": { "type": "integer", "minimum": 0 },
        "ambiguousRows": { "type": "integer", "minimum": 0 },
        "noMatchRows": { "type": "integer", "minimum": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object" },
        "bySectionType": { "type": "object" },
        "byRecoveryStatus": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "dryRunComplete",
        "applyExecuted",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
