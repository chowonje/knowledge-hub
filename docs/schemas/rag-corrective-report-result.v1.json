{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema",
    "status",
    "query",
    "sourceType",
    "retrievalMode",
    "topK",
    "alpha",
    "readOnly",
    "resultCount",
    "retrievalPlan",
    "retrievalStrategy",
    "retrievalQuality",
    "answerabilityRerank",
    "correctiveRetrieval",
    "artifactHealth",
    "suggestedActions",
    "actionsApplied",
    "resultsPreview",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.rag.corrective-report.result.v1" },
    "status": { "type": "string" },
    "query": { "type": "string" },
    "sourceType": { "type": "string" },
    "retrievalMode": { "type": "string" },
    "topK": { "type": "integer" },
    "alpha": { "type": "number" },
    "readOnly": { "type": "boolean" },
    "resultCount": { "type": "integer" },
    "retrievalPlan": { "type": "object" },
    "retrievalStrategy": { "type": "object" },
    "retrievalQuality": { "type": "object" },
    "answerabilityRerank": { "type": "object" },
    "correctiveRetrieval": { "type": "object" },
    "artifactHealth": { "type": "object" },
    "candidateSources": { "type": "array" },
    "rerankSignals": { "type": "object" },
    "memoryRoute": { "type": "object" },
    "memoryPrefilter": { "type": "object" },
    "paperMemoryPrefilter": { "type": "object" },
    "suggestedActions": { "type": "array" },
    "actionsApplied": { "type": "array" },
    "resultsPreview": { "type": "array" },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
