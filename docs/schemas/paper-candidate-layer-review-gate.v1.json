{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.candidate-layer-review-gate.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.candidate-layer-review-gate.v1" },
    "status": { "type": "string", "enum": ["ready_for_candidate_layer_review", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "structuredSummaryReport",
        "complexQaEvalDesignReport",
        "structuredSummarySchema",
        "complexQaEvalDesignSchema"
      ],
      "properties": {
        "structuredSummaryReport": { "type": "string" },
        "complexQaEvalDesignReport": { "type": "string" },
        "structuredSummarySchema": { "type": "string" },
        "complexQaEvalDesignSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "totalCandidates",
        "questionCount",
        "strictEligibleCandidates",
        "citationGradeCandidates",
        "runtimeEvidenceCandidates",
        "currentRuntimeAnswerableQuestions",
        "executedQuestions",
        "strictEvidenceCreated"
      ],
      "properties": {
        "totalCandidates": { "type": "integer", "minimum": 0 },
        "questionCount": { "type": "integer", "minimum": 0 },
        "strictEligibleCandidates": { "type": "integer", "minimum": 0 },
        "citationGradeCandidates": { "type": "integer", "minimum": 0 },
        "runtimeEvidenceCandidates": { "type": "integer", "minimum": 0 },
        "currentRuntimeAnswerableQuestions": { "type": "integer", "minimum": 0 },
        "executedQuestions": { "type": "integer", "minimum": 0 },
        "strictEvidenceCreated": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "candidateLayerReviewReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "decision",
        "strictPromotionDecision",
        "parserRoutingDecision",
        "answerIntegrationDecision",
        "violations",
        "blockers",
        "recommendedNextTranche"
      ],
      "properties": {
        "candidateLayerReviewReady": { "type": "boolean" },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "decision": { "type": "string", "enum": ["ready_for_candidate_layer_review", "blocked"] },
        "strictPromotionDecision": { "const": "blocked" },
        "parserRoutingDecision": { "const": "blocked" },
        "answerIntegrationDecision": { "const": "blocked" },
        "violations": { "type": "array", "items": { "type": "string" } },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reviewGateOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reviewGateOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
