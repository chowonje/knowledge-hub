{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.tex-equation-normalization-bridge-audit.v1",
  "title": "TeX Equation Normalization Bridge Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.tex-equation-normalization-bridge-audit.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diagnosticReportPath", "diagnosticReportSchema", "parsedRoot", "paperIds"],
      "properties": {
        "diagnosticReportPath": { "type": "string" },
        "diagnosticReportSchema": { "type": "string" },
        "parsedRoot": { "type": "string" },
        "paperIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "equationDiagnosticRows",
        "textBearingEquationRows",
        "emptyEquationTextRows",
        "bridgeWindowRows",
        "uniqueBridgeWindowRows",
        "ambiguousBridgeWindowRows",
        "failedBridgeWindowRows",
        "sourceSpanCreatedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "schemaViolationCount",
        "byPaper",
        "byBridgeStatus"
      ],
      "properties": {
        "equationDiagnosticRows": { "type": "integer", "minimum": 0 },
        "textBearingEquationRows": { "type": "integer", "minimum": 0 },
        "emptyEquationTextRows": { "type": "integer", "minimum": 0 },
        "bridgeWindowRows": { "type": "integer", "minimum": 0 },
        "uniqueBridgeWindowRows": { "type": "integer", "minimum": 0 },
        "ambiguousBridgeWindowRows": { "type": "integer", "minimum": 0 },
        "failedBridgeWindowRows": { "type": "integer", "minimum": 0 },
        "sourceSpanCreatedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byBridgeStatus": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bridgeAuditReady",
        "sourceSpanCreationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "bridgeAuditReady": { "type": "boolean" },
        "sourceSpanCreationReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string" },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportOnly",
        "bridgeAuditOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "equationInterpretationAllowed"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "bridgeAuditOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "equationInterpretationAllowed": { "const": false }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bridge_candidate_id",
          "source_diagnostic_id",
          "source_candidate_id",
          "paper_id",
          "candidate_type",
          "source_parser",
          "source_file",
          "equation_environment",
          "candidate_text",
          "bridge_anchor_terms",
          "bridge_anchor_term_count",
          "canonical_document_path",
          "canonical_document_available",
          "bridge_status",
          "bridge_method",
          "bridge_window_count",
          "canonical_context_preview",
          "sourceContentHash",
          "chars_start",
          "chars_end",
          "page",
          "source_span_created",
          "equation_semantics_interpreted",
          "equation_region_verified",
          "evidence_tier",
          "confidence",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "bridge_candidate_id": { "type": "string" },
          "source_diagnostic_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_type": { "const": "tex_equation_normalization_bridge_candidate" },
          "source_parser": { "const": "arxiv_tex+pymupdf_alignment" },
          "source_file": { "type": "string" },
          "equation_environment": { "type": "string" },
          "candidate_text": { "type": "string" },
          "bridge_anchor_terms": { "type": "array", "items": { "type": "string" } },
          "bridge_anchor_term_count": { "type": "integer", "minimum": 0 },
          "canonical_document_path": { "type": "string" },
          "canonical_document_available": { "type": "boolean" },
          "bridge_status": { "type": "string" },
          "bridge_method": { "type": "string" },
          "bridge_window_count": { "type": "integer", "minimum": 0 },
          "canonical_context_preview": { "type": "string" },
          "sourceContentHash": { "type": "string" },
          "chars_start": { "type": ["integer", "null"] },
          "chars_end": { "type": ["integer", "null"] },
          "page": { "type": ["integer", "null"] },
          "source_span_created": { "const": false },
          "equation_semantics_interpreted": { "const": false },
          "equation_region_verified": { "const": false },
          "evidence_tier": { "const": "tex_equation_normalization_bridge_candidate_only" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
