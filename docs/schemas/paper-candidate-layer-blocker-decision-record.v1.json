{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.candidate-layer-blocker-decision-record.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "decisionRecords"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.candidate-layer-blocker-decision-record.v1" },
    "status": { "type": "string", "enum": ["decision_record_required", "decision_recorded", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "candidateLayerBlockerDecisionTemplateReport",
        "candidateLayerBlockerDecisionTemplateSchema",
        "blockerDecisionsReport",
        "blockerDecisionInputRows"
      ],
      "properties": {
        "candidateLayerBlockerDecisionTemplateReport": { "type": "string" },
        "candidateLayerBlockerDecisionTemplateSchema": { "type": "string" },
        "blockerDecisionsReport": { "type": "string" },
        "blockerDecisionInputRows": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "recordRows",
        "needsReviewRows",
        "manualApprovalRows",
        "manualRejectionRows",
        "operatorApprovedRows",
        "operatorDeclinedRows",
        "technicalAcceptedOpenRows",
        "technicalDeferredRows",
        "policyAcceptedGuardrailRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "unsafeUpstreamFlagCount",
        "byBucket",
        "byPriority",
        "byLayer",
        "byDecision"
      ],
      "properties": {
        "recordRows": { "type": "integer", "minimum": 0 },
        "needsReviewRows": { "type": "integer", "minimum": 0 },
        "manualApprovalRows": { "type": "integer", "minimum": 0 },
        "manualRejectionRows": { "type": "integer", "minimum": 0 },
        "operatorApprovedRows": { "type": "integer", "minimum": 0 },
        "operatorDeclinedRows": { "type": "integer", "minimum": 0 },
        "technicalAcceptedOpenRows": { "type": "integer", "minimum": 0 },
        "technicalDeferredRows": { "type": "integer", "minimum": 0 },
        "policyAcceptedGuardrailRows": { "type": "integer", "minimum": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "byBucket": { "type": "object" },
        "byPriority": { "type": "object" },
        "byLayer": { "type": "object" },
        "byDecision": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "decisionRecordReady",
        "allDecisionRowsComplete",
        "humanReviewComplete",
        "operatorApprovalComplete",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "unsafeUpstreamFlags",
        "recommendedNextTranche"
      ],
      "properties": {
        "decisionRecordReady": { "type": "boolean" },
        "allDecisionRowsComplete": { "type": "boolean" },
        "humanReviewComplete": { "type": "boolean" },
        "operatorApprovalComplete": { "type": "boolean" },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": [
            "manual_or_operator_decisions_still_required",
            "blocker_decisions_recorded_non_strict",
            "blocked"
          ]
        },
        "unsafeUpstreamFlags": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "decisionRecordOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "decisionRecordOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "decisionRecords": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_row_id",
          "source_decision_row_id",
          "source_review_card_id",
          "source_backlog_id",
          "blocker",
          "priority",
          "review_bucket",
          "affected_layers",
          "affected_candidate_count",
          "affected_eval_question_count",
          "recommended_next_tranche",
          "recommended_review_action",
          "raw_decision",
          "recorded_decision",
          "decision_scope",
          "reviewer",
          "notes",
          "evidence_tier",
          "report_only",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "record_row_id": { "type": "string" },
          "source_decision_row_id": { "type": "string" },
          "source_review_card_id": { "type": "string" },
          "source_backlog_id": { "type": "string" },
          "blocker": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "review_bucket": {
            "type": "string",
            "enum": [
              "manual_decision_required",
              "operator_approval_required",
              "technical_feasibility_blocked",
              "policy_review_only"
            ]
          },
          "affected_layers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["sectionspan", "figure_caption", "equation_quote", "table_region"]
            }
          },
          "affected_candidate_count": { "type": "integer", "minimum": 0 },
          "affected_eval_question_count": { "type": "integer", "minimum": 0 },
          "recommended_next_tranche": { "type": "string" },
          "recommended_review_action": { "type": "string" },
          "raw_decision": { "type": "string" },
          "recorded_decision": {
            "type": "string",
            "enum": [
              "needs_review",
              "manual_approval_recorded_for_later_design_only",
              "manual_rejection_recorded_keep_blocked",
              "operator_diagnostic_action_approved_report_only",
              "operator_diagnostic_action_declined_keep_blocked",
              "technical_blocker_accepted_open",
              "technical_followup_deferred",
              "technical_blocker_closed_as_not_needed",
              "policy_blocker_accepted_guardrail",
              "policy_review_deferred",
              "keep_blocked"
            ]
          },
          "decision_scope": {
            "const": "candidate_layer_blocker_decision_record_only_no_runtime_or_strict_promotion"
          },
          "reviewer": { "type": "string" },
          "notes": { "type": "string" },
          "evidence_tier": { "const": "candidate_layer_blocker_decision_record_only" },
          "report_only": { "const": true },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
