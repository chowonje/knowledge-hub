{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.tex-equation-line-local-anchor-audit.v1",
  "title": "TeX Equation Line-Local Anchor Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.tex-equation-line-local-anchor-audit.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normalizerDesignReportPath", "normalizerDesignReportSchema", "parsedRoot", "paperIds"],
      "properties": {
        "normalizerDesignReportPath": { "type": "string" },
        "normalizerDesignReportSchema": { "type": "string" },
        "parsedRoot": { "type": "string" },
        "paperIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "normalizerDesignRows",
        "textBearingEquationRows",
        "emptyEquationTextRows",
        "normalizedWindowRows",
        "uniqueLineLocalAnchorRows",
        "uniqueEquationNumberAnchorRows",
        "ambiguousAnchorRows",
        "failedAnchorRows",
        "sourceSpanCreatedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "schemaViolationCount",
        "byPaper",
        "byLineLocalAnchorStatus"
      ],
      "properties": {
        "normalizerDesignRows": { "type": "integer", "minimum": 0 },
        "textBearingEquationRows": { "type": "integer", "minimum": 0 },
        "emptyEquationTextRows": { "type": "integer", "minimum": 0 },
        "normalizedWindowRows": { "type": "integer", "minimum": 0 },
        "uniqueLineLocalAnchorRows": { "type": "integer", "minimum": 0 },
        "uniqueEquationNumberAnchorRows": { "type": "integer", "minimum": 0 },
        "ambiguousAnchorRows": { "type": "integer", "minimum": 0 },
        "failedAnchorRows": { "type": "integer", "minimum": 0 },
        "sourceSpanCreatedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byLineLocalAnchorStatus": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lineLocalAnchorAuditReady",
        "sourceSpanCreationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "lineLocalAnchorAuditReady": { "type": "boolean" },
        "sourceSpanCreationReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string" },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportOnly",
        "lineLocalAnchorAuditOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "equationInterpretationAllowed"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "lineLocalAnchorAuditOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "equationInterpretationAllowed": { "const": false }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "anchor_id",
          "source_design_id",
          "source_diagnostic_id",
          "source_candidate_id",
          "paper_id",
          "candidate_type",
          "source_parser",
          "source_file",
          "equation_environment",
          "candidate_text",
          "recommended_profile",
          "normalized_terms",
          "normalized_term_count",
          "canonical_document_path",
          "canonical_document_available",
          "normalized_window_count",
          "distinct_line_count",
          "distinct_page_marker_count",
          "equation_number_candidates",
          "window_details",
          "line_local_anchor_status",
          "line_local_anchor_method",
          "recommended_action",
          "sourceContentHash",
          "chars_start",
          "chars_end",
          "page",
          "source_span_created",
          "equation_semantics_interpreted",
          "equation_region_verified",
          "evidence_tier",
          "confidence",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "anchor_id": { "type": "string" },
          "source_design_id": { "type": "string" },
          "source_diagnostic_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_type": { "const": "tex_equation_line_local_anchor_candidate" },
          "source_parser": { "const": "arxiv_tex+pymupdf_alignment" },
          "source_file": { "type": "string" },
          "equation_environment": { "type": "string" },
          "candidate_text": { "type": "string" },
          "recommended_profile": { "type": "string" },
          "normalized_terms": { "type": "array", "items": { "type": "string" } },
          "normalized_term_count": { "type": "integer", "minimum": 0 },
          "canonical_document_path": { "type": "string" },
          "canonical_document_available": { "type": "boolean" },
          "normalized_window_count": { "type": "integer", "minimum": 0 },
          "distinct_line_count": { "type": "integer", "minimum": 0 },
          "distinct_page_marker_count": { "type": "integer", "minimum": 0 },
          "equation_number_candidates": { "type": "array", "items": { "type": "string" } },
          "window_details": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "window_index",
                "line_number",
                "page_marker",
                "line_equation_numbers",
                "context_equation_numbers",
                "line_preview",
                "context_preview"
              ],
              "properties": {
                "window_index": { "type": "integer", "minimum": 1 },
                "line_number": { "type": ["integer", "null"] },
                "page_marker": { "type": ["integer", "null"] },
                "line_equation_numbers": { "type": "array", "items": { "type": "string" } },
                "context_equation_numbers": { "type": "array", "items": { "type": "string" } },
                "line_preview": { "type": "string" },
                "context_preview": { "type": "string" }
              }
            }
          },
          "line_local_anchor_status": { "type": "string" },
          "line_local_anchor_method": { "type": "string" },
          "recommended_action": { "type": "string" },
          "sourceContentHash": { "type": "string" },
          "chars_start": { "type": ["integer", "null"] },
          "chars_end": { "type": ["integer", "null"] },
          "page": { "type": ["integer", "null"] },
          "source_span_created": { "const": false },
          "equation_semantics_interpreted": { "const": false },
          "equation_region_verified": { "const": false },
          "evidence_tier": { "const": "tex_equation_line_local_anchor_candidate_only" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
