{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.equation-quote-decision-file-draft.v1",
  "title": "EquationQuote Decision File Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "decisionFileDraft",
    "draftRows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.equation-quote-decision-file-draft.v1" },
    "status": {
      "type": "string",
      "enum": ["decision_file_draft_ready", "no_equation_quote_review_rows", "blocked"]
    },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "equationQuoteManualReviewSheetReport",
        "equationQuoteManualReviewSheetSchema"
      ],
      "properties": {
        "equationQuoteManualReviewSheetReport": { "type": "string" },
        "equationQuoteManualReviewSheetSchema": { "type": "string" }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "draftRows",
        "needsReviewRows",
        "nonNeedsReviewRows",
        "rejectDecisionRows",
        "reextractRequestRows",
        "keepBlockedRows",
        "sourceSpanCreatedRows",
        "originalPdfOffsetRecoveredRows",
        "equationSemanticsInterpretedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "unsafeUpstreamFlagCount",
        "byPaper",
        "byActionType",
        "byActionStatus"
      ],
      "properties": {
        "draftRows": { "type": "integer", "minimum": 0 },
        "needsReviewRows": { "type": "integer", "minimum": 0 },
        "nonNeedsReviewRows": { "const": 0 },
        "rejectDecisionRows": { "const": 0 },
        "reextractRequestRows": { "const": 0 },
        "keepBlockedRows": { "const": 0 },
        "sourceSpanCreatedRows": { "const": 0 },
        "originalPdfOffsetRecoveredRows": { "const": 0 },
        "equationSemanticsInterpretedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "byPaper": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "byActionType": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "byActionStatus": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decisionFileDraftReady",
        "containsOnlyNeedsReviewDefaults",
        "containsRejectRows",
        "containsReextractRequestRows",
        "humanReviewComplete",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "unsafeUpstreamFlags",
        "recommendedNextTranche"
      ],
      "properties": {
        "decisionFileDraftReady": { "type": "boolean" },
        "containsOnlyNeedsReviewDefaults": { "const": true },
        "containsRejectRows": { "const": false },
        "containsReextractRequestRows": { "const": false },
        "humanReviewComplete": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": ["needs_review_draft_ready_for_manual_edit", "no_equation_quote_review_rows", "blocked"]
        },
        "unsafeUpstreamFlags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommendedNextTranche": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportOnly",
        "decisionFileDraftOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "decisionFileDraftOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "decisionFileDraft": {
      "type": "object",
      "additionalProperties": true,
      "required": ["draftOnly", "instructions", "decisions"],
      "properties": {
        "draftOnly": { "const": true },
        "instructions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "source_review_sheet_row_id",
              "source_action_card_id",
              "source_equation_quote_candidate_id",
              "paper_id",
              "candidate_text",
              "action_type",
              "decision",
              "reviewer",
              "notes",
              "allowed_decisions"
            ],
            "properties": {
              "source_review_sheet_row_id": { "type": "string" },
              "source_action_card_id": { "type": "string" },
              "source_equation_quote_candidate_id": { "type": "string" },
              "paper_id": { "type": "string" },
              "candidate_text": { "type": "string" },
              "action_type": { "type": "string" },
              "decision": { "const": "needs_review" },
              "reviewer": { "const": "" },
              "notes": { "const": "" },
              "allowed_decisions": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "draftRows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "draft_row_id",
          "source_review_sheet_row_id",
          "source_action_card_id",
          "source_equation_quote_candidate_id",
          "paper_id",
          "candidate_text",
          "equation_label",
          "action_type",
          "action_status",
          "priority",
          "allowed_decisions",
          "decision",
          "reviewer",
          "notes",
          "draft_only",
          "decision_scope",
          "evidence_tier",
          "report_only",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "draft_row_id": { "type": "string" },
          "source_review_sheet_row_id": { "type": "string" },
          "source_action_card_id": { "type": "string" },
          "source_equation_quote_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_text": { "type": "string" },
          "equation_label": { "type": "string" },
          "action_type": { "type": "string" },
          "action_status": { "type": "string" },
          "priority": { "type": "string" },
          "allowed_decisions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "decision": { "const": "needs_review" },
          "reviewer": { "const": "" },
          "notes": { "const": "" },
          "draft_only": { "const": true },
          "decision_scope": { "const": "equation_quote_decision_file_draft_only_no_runtime_or_strict_promotion" },
          "evidence_tier": { "const": "equation_quote_decision_file_draft_only" },
          "report_only": { "const": true },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_blockers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "non_strict_reason": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
