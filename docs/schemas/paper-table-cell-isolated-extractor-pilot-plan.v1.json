        "packagesInstalled": { "const": 0 },
        "globalPackagesInstalled": { "const": 0 },
        "tableCellEvidenceCreatedRows": { "const": 0 },
        "tableCellCitationGradeRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
