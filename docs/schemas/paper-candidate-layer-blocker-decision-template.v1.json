{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.candidate-layer-blocker-decision-template.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "decisionRows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.candidate-layer-blocker-decision-template.v1" },
    "status": { "type": "string", "enum": ["decision_template_ready", "no_decision_rows", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "candidateLayerBlockerReviewPackReport",
        "candidateLayerBlockerReviewPackSchema"
      ],
      "properties": {
        "candidateLayerBlockerReviewPackReport": { "type": "string" },
        "candidateLayerBlockerReviewPackSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "templateRows",
        "pendingDecisionRows",
        "acceptedDecisionRows",
        "rejectedDecisionRows",
        "operatorApprovedRows",
        "operatorDeclinedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "unsafeUpstreamFlagCount",
        "byBucket",
        "byPriority",
        "byLayer"
      ],
      "properties": {
        "templateRows": { "type": "integer", "minimum": 0 },
        "pendingDecisionRows": { "type": "integer", "minimum": 0 },
        "acceptedDecisionRows": { "const": 0 },
        "rejectedDecisionRows": { "const": 0 },
        "operatorApprovedRows": { "const": 0 },
        "operatorDeclinedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "byBucket": { "type": "object" },
        "byPriority": { "type": "object" },
        "byLayer": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "decisionTemplateReady",
        "humanReviewComplete",
        "operatorApprovalComplete",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "unsafeUpstreamFlags",
        "recommendedNextTranche"
      ],
      "properties": {
        "decisionTemplateReady": { "type": "boolean" },
        "humanReviewComplete": { "const": false },
        "operatorApprovalComplete": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": [
            "manual_or_operator_decision_template_ready",
            "no_review_cards_for_decision_template",
            "blocked"
          ]
        },
        "unsafeUpstreamFlags": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "decisionTemplateOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "decisionTemplateOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "decisionRows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "decision_row_id",
          "source_review_card_id",
          "source_backlog_id",
          "blocker",
          "priority",
          "review_bucket",
          "affected_layers",
          "affected_candidate_count",
          "affected_eval_question_count",
          "recommended_next_tranche",
          "recommended_review_action",
          "default_decision",
          "allowed_decisions",
          "manual_decision_input",
          "required_review_checks",
          "decision_scope",
          "evidence_tier",
          "report_only",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "decision_row_id": { "type": "string" },
          "source_review_card_id": { "type": "string" },
          "source_backlog_id": { "type": "string" },
          "blocker": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "review_bucket": {
            "type": "string",
            "enum": [
              "manual_decision_required",
              "operator_approval_required",
              "technical_feasibility_blocked",
              "policy_review_only"
            ]
          },
          "affected_layers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["sectionspan", "figure_caption", "equation_quote", "table_region"]
            }
          },
          "affected_candidate_count": { "type": "integer", "minimum": 0 },
          "affected_eval_question_count": { "type": "integer", "minimum": 0 },
          "recommended_next_tranche": { "type": "string" },
          "recommended_review_action": { "type": "string" },
          "default_decision": { "const": "needs_review" },
          "allowed_decisions": { "type": "array", "items": { "type": "string" } },
          "manual_decision_input": { "type": "object" },
          "required_review_checks": { "type": "array", "items": { "type": "string" } },
          "decision_scope": {
            "const": "candidate_layer_blocker_decision_template_only_no_runtime_or_strict_promotion"
          },
          "evidence_tier": { "const": "candidate_layer_blocker_decision_template_only" },
          "report_only": { "const": true },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
