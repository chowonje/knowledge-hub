{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "status", "runId", "counts", "items", "ts"],
  "properties": {
    "schema": {"const": "knowledge-hub.ko-note.enrich.status.result.v1"},
    "status": {"type": "string"},
    "runId": {"type": "string", "minLength": 1},
    "counts": {
      "type": "object",
      "properties": {
        "sourceTargets": {"type": "integer", "minimum": 0},
        "sourceEnriched": {"type": "integer", "minimum": 0},
        "conceptTargets": {"type": "integer", "minimum": 0},
        "conceptEnriched": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": {"type": "integer"}
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "itemType", "status"],
        "properties": {
          "id": {"type": ["integer", "null"]},
          "itemType": {"type": "string"},
          "status": {"type": "string"},
          "noteItemId": {"type": ["integer", "null"]},
          "targetPath": {"type": ["string", "null"]},
          "route": {"type": ["string", "null"]},
          "provider": {"type": ["string", "null"]},
          "model": {"type": ["string", "null"]}
        },
        "additionalProperties": true
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}},
    "schemaErrors": {"type": "array", "items": {"type": "string"}},
    "ts": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
