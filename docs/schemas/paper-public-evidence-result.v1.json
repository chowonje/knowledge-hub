{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.public.evidence.v1",
  "type": "object",
  "required": ["schema", "status", "paperId", "paperTitle", "evidenceSummary", "evidenceMap", "claimCoverage", "warnings"],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.public.evidence.v1" },
    "status": { "type": "string" },
    "paperId": { "type": "string" },
    "paperTitle": { "type": "string" },
    "parserUsed": { "type": "string" },
    "fallbackUsed": { "type": "boolean" },
    "evidenceSummary": { "type": "object" },
    "evidenceMap": { "type": "array", "items": { "type": "object" } },
    "conceptsDetailed": { "type": "array" },
    "quality": { "type": "object" },
    "claimCoverage": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
