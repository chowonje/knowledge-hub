          "candidate_text",
          "section_type",
          "section_level",
          "review_priority",
          "canonical_span",
          "original_pdf_span",
          "page_agreement",
          "source_hash_agreement",
          "recorded_decision",
          "decision_scope",
          "reviewer",
          "notes",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason"
