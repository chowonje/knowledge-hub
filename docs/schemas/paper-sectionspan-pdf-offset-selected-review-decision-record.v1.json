          "record_row_id": { "type": "string" },
          "source_decision_row_id": { "type": "string" },
          "source_selected_review_card_id": { "type": "string" },
          "source_priority_card_id": { "type": "string" },
          "source_original_decision_row_id": { "type": "string" },
          "source_gate_row_id": { "type": "string" },
          "source_review_card_id": { "type": "string" },
          "source_sectionspan_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_text": { "type": "string" },
          "section_type": { "type": "string" },
          "section_level": { "type": "integer", "minimum": 0 },
          "review_priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "canonical_span": { "type": "object" },
          "original_pdf_span": { "type": "object" },
          "page_agreement": { "type": "boolean" },
          "source_hash_agreement": { "type": "boolean" },
          "recorded_decision": {
            "type": "string",
            "enum": [
              "needs_review",
              "approved_for_later_promotion_design",
              "rejected_keep_candidate_only"
            ]
