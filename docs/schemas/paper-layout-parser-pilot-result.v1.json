{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.layout-parser-pilot.result.v1",
  "type": "object",
  "required": ["schema", "status", "generatedAt", "request", "counts", "papers", "warnings"],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.layout-parser-pilot.result.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked", "partial", "failed"] },
    "generatedAt": { "type": "string" },
    "request": {
      "type": "object",
      "required": ["paperIds", "parsers", "run", "timeoutSeconds", "outputDir"],
      "properties": {
        "paperIds": { "type": "array", "items": { "type": "string" } },
        "parsers": { "type": "array", "items": { "type": "string" } },
        "run": { "type": "boolean" },
        "timeoutSeconds": { "type": "integer", "minimum": 0 },
        "outputDir": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": ["planned", "ok", "blocked", "failed", "timeout"],
      "properties": {
        "planned": { "type": "integer", "minimum": 0 },
        "ok": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "timeout": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "papers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paperId", "paperTitle", "sourcePdf", "parsers"],
        "properties": {
          "paperId": { "type": "string" },
          "paperTitle": { "type": "string" },
          "sourcePdf": {
            "type": "object",
            "required": ["exists", "path"],
            "properties": {
              "exists": { "type": "boolean" },
              "path": { "type": "string" }
            },
            "additionalProperties": true
          },
          "parsers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "parser",
                "status",
                "reason",
                "available",
                "availability",
                "durationMs",
                "durationSeconds",
                "timeoutSeconds",
                "artifactDir",
                "metrics"
              ],
              "properties": {
                "parser": { "type": "string" },
                "status": { "type": "string", "enum": ["planned", "ok", "blocked", "failed", "timeout"] },
                "reason": { "type": "string" },
                "available": { "type": "boolean" },
                "availability": { "type": "object" },
                "durationMs": { "type": "integer", "minimum": 0 },
                "durationSeconds": { "type": "number", "minimum": 0 },
                "timeoutSeconds": { "type": "integer", "minimum": 0 },
                "artifactDir": { "type": "string" },
                "metrics": {
                  "type": "object",
                  "required": [
                    "markdownChars",
                    "elementCount",
                    "realHeadingCount",
                    "bboxElementCount",
                    "readingOrderElementCount",
                    "tableCellElementCount",
                    "pageCount",
                    "columnCountDetected",
                    "tablesDetected",
                    "figuresDetected",
                    "equationsDetected",
                    "extractionDegraded",
                    "degradationReasons"
                  ],
                  "properties": {
                    "markdownChars": { "type": "integer", "minimum": 0 },
                    "elementCount": { "type": "integer", "minimum": 0 },
                    "realHeadingCount": { "type": "integer", "minimum": 0 },
                    "bboxElementCount": { "type": "integer", "minimum": 0 },
                    "readingOrderElementCount": { "type": "integer", "minimum": 0 },
                    "tableCellElementCount": { "type": "integer", "minimum": 0 },
                    "pageCount": { "type": "integer", "minimum": 0 },
                    "columnCountDetected": { "type": "integer", "minimum": 0 },
                    "tablesDetected": { "type": "integer", "minimum": 0 },
                    "figuresDetected": { "type": "integer", "minimum": 0 },
                    "equationsDetected": { "type": "integer", "minimum": 0 },
                    "extractionDegraded": { "type": "boolean" },
                    "degradationReasons": { "type": "array", "items": { "type": "string" } }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "schemaErrors": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
