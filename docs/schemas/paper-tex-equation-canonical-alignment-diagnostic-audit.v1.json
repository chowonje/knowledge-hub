{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.tex-equation-canonical-alignment-diagnostic-audit.v1",
  "title": "TeX Equation Canonical Alignment Diagnostic Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.tex-equation-canonical-alignment-diagnostic-audit.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alignmentReportPath", "alignmentReportSchema", "parsedRoot", "paperIds"],
      "properties": {
        "alignmentReportPath": { "type": "string" },
        "alignmentReportSchema": { "type": "string" },
        "parsedRoot": { "type": "string" },
        "paperIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "equationEnvironmentRows",
        "textBearingEquationEnvironmentRows",
        "emptyEquationTextRows",
        "rawTexMatchRows",
        "compactTexMatchRows",
        "plainTextMatchRows",
        "diagnosticTermContextRows",
        "likelyCanonicalEquationTextMissingRows",
        "normalizationGapRows",
        "sourceSpanCreatedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "schemaViolationCount",
        "byPaper",
        "byDiagnosis"
      ],
      "properties": {
        "equationEnvironmentRows": { "type": "integer", "minimum": 0 },
        "textBearingEquationEnvironmentRows": { "type": "integer", "minimum": 0 },
        "emptyEquationTextRows": { "type": "integer", "minimum": 0 },
        "rawTexMatchRows": { "type": "integer", "minimum": 0 },
        "compactTexMatchRows": { "type": "integer", "minimum": 0 },
        "plainTextMatchRows": { "type": "integer", "minimum": 0 },
        "diagnosticTermContextRows": { "type": "integer", "minimum": 0 },
        "likelyCanonicalEquationTextMissingRows": { "type": "integer", "minimum": 0 },
        "normalizationGapRows": { "type": "integer", "minimum": 0 },
        "sourceSpanCreatedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byDiagnosis": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diagnosticReady",
        "sourceSpanCreationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "diagnosticReady": { "type": "boolean" },
        "sourceSpanCreationReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string" },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportOnly",
        "diagnosticOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "equationInterpretationAllowed"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "diagnosticOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "equationInterpretationAllowed": { "const": false }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "diagnostic_id",
          "source_candidate_id",
          "paper_id",
          "candidate_type",
          "source_parser",
          "source_file",
          "equation_environment",
          "candidate_text",
          "plain_text_candidate",
          "canonical_document_path",
          "canonical_document_available",
          "existing_alignment_status",
          "existing_alignment_method",
          "existing_alignment_reason",
          "tex_has_macros",
          "raw_tex_match_count",
          "compact_tex_match_count",
          "plain_text_match_count",
          "diagnostic_terms",
          "diagnostic_term_matches",
          "diagnostic_term_coverage",
          "diagnosis",
          "confidence",
          "sourceContentHash",
          "source_span_created",
          "equation_semantics_interpreted",
          "equation_region_verified",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "diagnostic_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_type": { "const": "tex_equation_canonical_alignment_diagnostic" },
          "source_parser": { "const": "arxiv_tex+pymupdf_alignment" },
          "source_file": { "type": "string" },
          "equation_environment": { "type": "string" },
          "candidate_text": { "type": "string" },
          "plain_text_candidate": { "type": "string" },
          "canonical_document_path": { "type": "string" },
          "canonical_document_available": { "type": "boolean" },
          "existing_alignment_status": { "type": "string" },
          "existing_alignment_method": { "type": "string" },
          "existing_alignment_reason": { "type": "string" },
          "tex_has_macros": { "type": "boolean" },
          "raw_tex_match_count": { "type": "integer", "minimum": 0 },
          "compact_tex_match_count": { "type": "integer", "minimum": 0 },
          "plain_text_match_count": { "type": "integer", "minimum": 0 },
          "diagnostic_terms": { "type": "array", "items": { "type": "string" } },
          "diagnostic_term_matches": { "type": "array", "items": { "type": "string" } },
          "diagnostic_term_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
          "diagnosis": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "sourceContentHash": { "type": "string" },
          "source_span_created": { "const": false },
          "equation_semantics_interpreted": { "const": false },
          "equation_region_verified": { "const": false },
          "evidence_tier": { "const": "tex_equation_alignment_diagnostic_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
