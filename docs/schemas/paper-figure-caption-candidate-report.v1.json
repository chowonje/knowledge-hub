{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.figure-caption-candidate-report.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "policy",
    "promotionRules",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.figure-caption-candidate-report.v1" },
    "status": { "type": "string", "enum": ["ok", "empty"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "required": ["sourceAlignmentReportPath", "sourceAlignmentSchema"],
      "properties": {
        "sourceAlignmentReportPath": { "type": "string" },
        "sourceAlignmentSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputCandidateCount",
        "figureCaptionCandidates",
        "alignedCaptionSpanCandidates",
        "layoutRegionCandidateCount",
        "figureRegionVerifiedCandidates",
        "strictEligibleCandidates",
        "citationGradeCandidates",
        "byPaper",
        "byAlignmentStatus",
        "byAlignmentMethod",
        "byReadiness",
        "strictBlockerSummary"
      ],
      "properties": {
        "inputCandidateCount": { "type": "integer", "minimum": 0 },
        "figureCaptionCandidates": { "type": "integer", "minimum": 0 },
        "alignedCaptionSpanCandidates": { "type": "integer", "minimum": 0 },
        "layoutRegionCandidateCount": { "type": "integer", "minimum": 0 },
        "figureRegionVerifiedCandidates": { "const": 0 },
        "strictEligibleCandidates": { "const": 0 },
        "citationGradeCandidates": { "const": 0 },
        "byPaper": { "type": "object" },
        "byAlignmentStatus": { "type": "object" },
        "byAlignmentMethod": { "type": "object" },
        "byReadiness": { "type": "object" },
        "strictBlockerSummary": { "type": "object" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "allCandidatesNonStrict",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "figureRegionVerificationRequired"
      ],
      "properties": {
        "allCandidatesNonStrict": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "figureRegionVerificationRequired": { "const": true }
      },
      "additionalProperties": true
    },
    "promotionRules": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "candidate_type",
          "source_candidate_id",
          "paper_id",
          "source_parser",
          "candidate_text",
          "figure_label",
          "caption_text",
          "canonical_alignment_status",
          "alignment_method",
          "chars_start",
          "chars_end",
          "page",
          "sourceContentHash",
          "confidence",
          "source_span_locator",
          "layout_element_ids",
          "bbox",
          "layout_region_candidate_present",
          "figure_region_link_verified",
          "figure_region_link_status",
          "readiness",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "candidate_id": { "type": "string" },
          "candidate_type": { "const": "figure_caption_candidate" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "source_parser": { "const": "mineru+pymupdf_alignment" },
          "candidate_text": { "type": "string" },
          "figure_label": { "type": "string" },
          "caption_text": { "type": "string" },
          "canonical_alignment_status": { "type": "string", "enum": ["aligned", "failed", "blocked", "ambiguous", ""] },
          "alignment_method": { "type": "string" },
          "alignment_reason": { "type": "string" },
          "chars_start": { "type": ["integer", "null"], "minimum": 0 },
          "chars_end": { "type": ["integer", "null"], "minimum": 0 },
          "page": { "type": ["integer", "null"], "minimum": 1 },
          "sourceContentHash": { "type": "string" },
          "sourceContentHashSource": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_span_locator": { "type": "object" },
          "layout_element_ids": { "type": "array", "items": { "type": "string" } },
          "bbox": {
            "anyOf": [
              {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": { "type": "number" }
              },
              { "type": "null" }
            ]
          },
          "layout_link_reason": { "type": "string" },
          "layout_region_candidate_present": { "type": "boolean" },
          "figure_region_link_verified": { "const": false },
          "figure_region_link_status": {
            "type": "string",
            "enum": ["layout_region_candidate_only_unverified", "missing_layout_region_candidate"]
          },
          "readiness": {
            "type": "string",
            "enum": [
              "caption_span_aligned_region_candidate_non_strict",
              "caption_span_aligned_fuzzy_non_strict",
              "caption_span_aligned_region_missing_non_strict",
              "blocked_alignment_incomplete",
              "blocked_missing_source_span",
              "blocked_missing_page",
              "blocked_missing_source_hash"
            ]
          },
          "source_classification": { "type": "string" },
          "evidence_tier": { "const": "figure_caption_candidate_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
