{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.tex-equation-source-span-promotion-readiness-audit.v1",
  "title": "TeX Equation Source-Span Promotion Readiness Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": {
      "const": "knowledge-hub.paper.tex-equation-source-span-promotion-readiness-audit.v1"
    },
    "status": {
      "type": "string",
      "enum": ["ok", "blocked"]
    },
    "generatedAt": {
      "type": "string"
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "renderedMacroTermProfileDesignReportPath",
        "renderedMacroTermProfileDesignReportSchema",
        "labelNumberPdfRegionDisambiguationDesignReportPath",
        "labelNumberPdfRegionDisambiguationDesignReportSchema",
        "segmentedMultilineMatchingDesignReportPath",
        "segmentedMultilineMatchingDesignReportSchema",
        "pdfRegionAnchorAuditReportPath",
        "pdfRegionAnchorAuditReportSchema",
        "paperIds"
      ],
      "properties": {
        "renderedMacroTermProfileDesignReportPath": { "type": "string" },
        "renderedMacroTermProfileDesignReportSchema": { "type": "string" },
        "labelNumberPdfRegionDisambiguationDesignReportPath": { "type": "string" },
        "labelNumberPdfRegionDisambiguationDesignReportSchema": { "type": "string" },
        "segmentedMultilineMatchingDesignReportPath": { "type": "string" },
        "segmentedMultilineMatchingDesignReportSchema": { "type": "string" },
        "pdfRegionAnchorAuditReportPath": { "type": "string" },
        "pdfRegionAnchorAuditReportSchema": { "type": "string" },
        "paperIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputRows",
        "targetRows",
        "promotionReviewReadyCandidateOnlyRows",
        "blockedMissingSourceHashRows",
        "blockedAmbiguousPdfRegionRows",
        "blockedMissingLabelNumberRows",
        "blockedPdfRegionOnlyRows",
        "blockedManualOrLaterExtractorRows",
        "sourceSpanCreatedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "parserRoutingChangedRows",
        "answerIntegrationChangedRows",
        "schemaViolationCount",
        "byPaper",
        "byReadiness",
        "byEnvironment"
      ],
      "properties": {
        "inputRows": { "type": "integer", "minimum": 0 },
        "targetRows": { "type": "integer", "minimum": 0 },
        "promotionReviewReadyCandidateOnlyRows": { "type": "integer", "minimum": 0 },
        "blockedMissingSourceHashRows": { "type": "integer", "minimum": 0 },
        "blockedAmbiguousPdfRegionRows": { "type": "integer", "minimum": 0 },
        "blockedMissingLabelNumberRows": { "type": "integer", "minimum": 0 },
        "blockedPdfRegionOnlyRows": { "type": "integer", "minimum": 0 },
        "blockedManualOrLaterExtractorRows": { "type": "integer", "minimum": 0 },
        "sourceSpanCreatedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "parserRoutingChangedRows": { "const": 0 },
        "answerIntegrationChangedRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byReadiness": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byEnvironment": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readinessAuditRows",
        "sourceSpanCreationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "readinessAuditRows": { "type": "boolean" },
        "sourceSpanCreationReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string" },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allRowsNonStrict",
        "reportOnly",
        "designOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "equationInterpretationAllowed"
      ],
      "properties": {
        "allRowsNonStrict": { "const": true },
        "reportOnly": { "const": true },
        "designOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "equationInterpretationAllowed": { "const": false }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "readiness_audit_id",
          "candidate_type",
          "source_rendered_macro_design_id",
          "source_label_number_disambiguation_design_id",
          "source_segmented_multiline_design_id",
          "source_pdf_region_anchor_id",
          "source_line_local_anchor_id",
          "source_diagnostic_id",
          "source_design_id",
          "source_candidate_id",
          "paper_id",
          "source_parser",
          "source_file",
          "equation_environment",
          "candidate_text",
          "source_tex_row_id",
          "sourceContentHash",
          "source_pdf_path",
          "source_manifest_path",
          "pdf_region",
          "label_number_disambiguation_evidence",
          "readiness_category",
          "recommended_next_action",
          "source_span_created",
          "citation_grade",
          "runtime_evidence",
          "parser_routing_changed",
          "answer_integration_changed",
          "strict_eligible",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "readiness_audit_id": { "type": "string" },
          "candidate_type": { "const": "tex_equation_source_span_promotion_readiness_audit" },
          "source_rendered_macro_design_id": { "type": "string" },
          "source_label_number_disambiguation_design_id": { "type": "string" },
          "source_segmented_multiline_design_id": { "type": "string" },
          "source_pdf_region_anchor_id": { "type": "string" },
          "source_line_local_anchor_id": { "type": "string" },
          "source_diagnostic_id": { "type": "string" },
          "source_design_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "source_parser": { "type": "string" },
          "source_file": { "type": "string" },
          "equation_environment": { "type": "string" },
          "candidate_text": { "type": "string" },
          "source_tex_row_id": { "type": "string" },
          "sourceContentHash": { "type": "string" },
          "source_pdf_path": { "type": "string" },
          "source_manifest_path": { "type": "string" },
          "pdf_region": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "page",
              "bbox",
              "blockIndexes",
              "matchedTerms",
              "coverage",
              "formulaScore",
              "textPreview"
            ],
            "properties": {
              "page": { "type": ["integer", "null"] },
              "bbox": { "type": "array", "items": { "type": "number" } },
              "blockIndexes": { "type": "array", "items": { "type": "integer" } },
              "matchedTerms": { "type": "array", "items": { "type": "string" } },
              "coverage": { "type": "number" },
              "formulaScore": { "type": "number" },
              "textPreview": { "type": "string" }
            }
          },
          "label_number_disambiguation_evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sourceStructureRowId",
              "texEnvironment",
              "latexLabels",
              "inferredEquationNumbers",
              "method",
              "status"
            ],
            "properties": {
              "sourceStructureRowId": { "type": "string" },
              "texEnvironment": { "type": "string" },
              "latexLabels": { "type": "array", "items": { "type": "string" } },
              "inferredEquationNumbers": { "type": "array", "items": { "type": "string" } },
              "method": { "type": "string" },
              "status": { "type": "string" }
            }
          },
          "readiness_category": {
            "type": "string",
            "enum": [
              "promotion_review_ready_candidate_only",
              "blocked_missing_source_hash",
              "blocked_ambiguous_pdf_region",
              "blocked_missing_label_number_disambiguation",
              "blocked_pdf_region_only_not_source_span",
              "blocked_requires_manual_or_later_extractor_review"
            ]
          },
          "recommended_next_action": { "type": "string" },
          "source_span_created": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "parser_routing_changed": { "const": false },
          "answer_integration_changed": { "const": false },
          "strict_eligible": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
