{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.equation-alignment-feasibility-audit.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.equation-alignment-feasibility-audit.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "equationQuoteReport",
        "mineruSourceAlignmentReport",
        "equationQuoteSchema",
        "mineruSourceAlignmentSchema"
      ],
      "properties": {
        "equationQuoteReport": { "type": "string" },
        "mineruSourceAlignmentReport": { "type": "string" },
        "equationQuoteSchema": { "type": "string" },
        "mineruSourceAlignmentSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputEquationQuoteCandidates",
        "auditedEquationQuoteCandidates",
        "rawTextMatchCandidates",
        "compactUniqueMatchCandidates",
        "diagnosticTermContextCandidates",
        "canonicalSourceSpanCreatedCandidates",
        "equationSemanticsInterpretedCandidates",
        "strictEligibleCandidates",
        "citationGradeCandidates",
        "runtimeEvidenceCandidates",
        "schemaViolationCount",
        "byPaper",
        "byFeasibilityStatus",
        "strictBlockerSummary"
      ],
      "properties": {
        "inputEquationQuoteCandidates": { "type": "integer", "minimum": 0 },
        "auditedEquationQuoteCandidates": { "type": "integer", "minimum": 0 },
        "rawTextMatchCandidates": { "type": "integer", "minimum": 0 },
        "compactUniqueMatchCandidates": { "type": "integer", "minimum": 0 },
        "diagnosticTermContextCandidates": { "type": "integer", "minimum": 0 },
        "canonicalSourceSpanCreatedCandidates": { "const": 0 },
        "equationSemanticsInterpretedCandidates": { "const": 0 },
        "strictEligibleCandidates": { "const": 0 },
        "citationGradeCandidates": { "const": 0 },
        "runtimeEvidenceCandidates": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object" },
        "byFeasibilityStatus": { "type": "object" },
        "strictBlockerSummary": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "equationAlignmentFeasibilityReviewed",
        "sourceSpanCreationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "equationAlignmentFeasibilityReviewed": { "type": "boolean" },
        "sourceSpanCreationReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "decision": { "type": "string", "enum": ["equation_alignment_feasibility_reviewed", "blocked"] },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "auditOnly",
        "quoteOnly",
        "equationSemanticsInterpreted",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "auditOnly": { "const": true },
        "quoteOnly": { "const": true },
        "equationSemanticsInterpreted": { "const": false },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "audit_id",
          "candidate_id",
          "paper_id",
          "candidate_type",
          "candidate_text",
          "canonical_document_path",
          "canonical_document_available",
          "existing_alignment_status",
          "raw_text_match",
          "compact_text_match_count",
          "diagnostic_terms",
          "diagnostic_term_matches",
          "diagnostic_term_coverage",
          "feasibility_status",
          "source_span_created",
          "equation_semantics_interpreted",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "audit_id": { "type": "string" },
          "candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_type": { "type": "string" },
          "candidate_text": { "type": "string" },
          "source_parser": { "type": "string" },
          "canonical_document_path": { "type": "string" },
          "canonical_document_available": { "type": "boolean" },
          "existing_alignment_status": { "type": "string" },
          "existing_alignment_method": { "type": "string" },
          "raw_text_match": { "type": "boolean" },
          "compact_text_match_count": { "type": "integer", "minimum": 0 },
          "diagnostic_terms": { "type": "array", "items": { "type": "string" } },
          "diagnostic_term_matches": { "type": "array", "items": { "type": "string" } },
          "diagnostic_term_coverage": { "type": "number", "minimum": 0 },
          "feasibility_status": { "type": "string" },
          "layout_element_count": { "type": "integer", "minimum": 0 },
          "bbox_available": { "type": "boolean" },
          "sourceContentHash": { "type": "string" },
          "source_span_created": { "const": false },
          "equation_semantics_interpreted": { "const": false },
          "evidence_tier": { "const": "equation_alignment_feasibility_candidate_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
