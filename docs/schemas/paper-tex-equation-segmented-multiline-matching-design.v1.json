{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.tex-equation-segmented-multiline-matching-design.v1",
  "title": "TeX Equation Segmented Multiline Matching Design",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.tex-equation-segmented-multiline-matching-design.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["remainingWindowDiagnosticReportPath", "remainingWindowDiagnosticReportSchema", "parsedRoot", "paperIds"],
      "properties": {
        "remainingWindowDiagnosticReportPath": { "type": "string" },
        "remainingWindowDiagnosticReportSchema": { "type": "string" },
        "parsedRoot": { "type": "string" },
        "paperIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputRows",
        "targetRows",
        "segmentRows",
        "rowsWithCandidateReadySegments",
        "candidateReadySegmentRows",
        "uniqueCanonicalSegmentRows",
        "ambiguousCanonicalSegmentRows",
        "uniquePdfRegionSegmentRows",
        "ambiguousPdfRegionSegmentRows",
        "sourceSpanCreatedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "parserRoutingChangedRows",
        "answerIntegrationChangedRows",
        "schemaViolationCount",
        "byPaper",
        "byEnvironment",
        "byCanonicalMatchStatus",
        "byPdfRegionMatchStatus",
        "byRecommendedAction"
      ],
      "properties": {
        "inputRows": { "type": "integer", "minimum": 0 },
        "targetRows": { "type": "integer", "minimum": 0 },
        "segmentRows": { "type": "integer", "minimum": 0 },
        "rowsWithCandidateReadySegments": { "type": "integer", "minimum": 0 },
        "candidateReadySegmentRows": { "type": "integer", "minimum": 0 },
        "uniqueCanonicalSegmentRows": { "type": "integer", "minimum": 0 },
        "ambiguousCanonicalSegmentRows": { "type": "integer", "minimum": 0 },
        "uniquePdfRegionSegmentRows": { "type": "integer", "minimum": 0 },
        "ambiguousPdfRegionSegmentRows": { "type": "integer", "minimum": 0 },
        "sourceSpanCreatedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "parserRoutingChangedRows": { "const": 0 },
        "answerIntegrationChangedRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byEnvironment": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byCanonicalMatchStatus": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byPdfRegionMatchStatus": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "byRecommendedAction": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "designReady",
        "sourceSpanCreationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "designReady": { "type": "boolean" },
        "sourceSpanCreationReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string" },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allRowsNonStrict",
        "reportOnly",
        "designOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "equationInterpretationAllowed"
      ],
      "properties": {
        "allRowsNonStrict": { "const": true },
        "reportOnly": { "const": true },
        "designOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "equationInterpretationAllowed": { "const": false }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "design_id",
          "candidate_type",
          "source_diagnostic_id",
          "source_pdf_region_anchor_id",
          "source_line_local_anchor_id",
          "source_design_id",
          "source_candidate_id",
          "paper_id",
          "source_parser",
          "source_file",
          "equation_environment",
          "candidate_text",
          "segment_count",
          "candidate_ready_segment_count",
          "source_context_status",
          "sourceContentHash",
          "source_pdf_path",
          "source_manifest_path",
          "segments",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "source_span_created",
          "parser_routing_changed",
          "answer_integration_changed",
          "recommended_action",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "design_id": { "type": "string" },
          "candidate_type": { "const": "tex_equation_segmented_multiline_matching_design" },
          "source_diagnostic_id": { "type": "string" },
          "source_pdf_region_anchor_id": { "type": "string" },
          "source_line_local_anchor_id": { "type": "string" },
          "source_design_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "source_parser": { "const": "arxiv_tex+pymupdf_pdf_blocks" },
          "source_file": { "type": "string" },
          "equation_environment": { "type": "string" },
          "candidate_text": { "type": "string" },
          "segment_count": { "type": "integer", "minimum": 0 },
          "candidate_ready_segment_count": { "type": "integer", "minimum": 0 },
          "source_context_status": { "type": "string" },
          "sourceContentHash": { "type": "string" },
          "source_pdf_path": { "type": "string" },
          "source_manifest_path": { "type": "string" },
          "segments": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "segment_id",
                "segment_index",
                "segment_text",
                "segment_text_length",
                "term_profile",
                "normalized_terms",
                "normalized_term_count",
                "canonical_match_status",
                "canonical_window_count",
                "pdf_region_match_status",
                "pdf_region_candidate_count",
                "selected_pdf_region",
                "segment_candidate_ready",
                "source_span_created",
                "strict_eligible",
                "citation_grade",
                "runtime_evidence",
                "strict_blockers",
                "non_strict_reason"
              ],
              "properties": {
                "segment_id": { "type": "string" },
                "segment_index": { "type": "integer", "minimum": 1 },
                "segment_text": { "type": "string" },
                "segment_text_length": { "type": "integer", "minimum": 0 },
                "term_profile": { "type": "string" },
                "normalized_terms": { "type": "array", "items": { "type": "string" } },
                "normalized_term_count": { "type": "integer", "minimum": 0 },
                "canonical_match_status": { "type": "string" },
                "canonical_window_count": { "type": "integer", "minimum": 0 },
                "pdf_region_match_status": { "type": "string" },
                "pdf_region_candidate_count": { "type": "integer", "minimum": 0 },
                "selected_pdf_region": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["page", "bbox", "blockIndexes", "matchedTerms", "coverage", "formulaScore", "textPreview"],
                  "properties": {
                    "page": { "type": ["integer", "null"] },
                    "bbox": { "type": "array", "items": { "type": "number" } },
                    "blockIndexes": { "type": "array", "items": { "type": "integer" } },
                    "matchedTerms": { "type": "array", "items": { "type": "string" } },
                    "coverage": { "type": "number" },
                    "formulaScore": { "type": "number" },
                    "textPreview": { "type": "string" }
                  }
                },
                "segment_candidate_ready": { "type": "boolean" },
                "source_span_created": { "const": false },
                "strict_eligible": { "const": false },
                "citation_grade": { "const": false },
                "runtime_evidence": { "const": false },
                "strict_blockers": { "type": "array", "items": { "type": "string" } },
                "non_strict_reason": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "evidence_tier": { "const": "segmented_multiline_matching_design_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "source_span_created": { "const": false },
          "parser_routing_changed": { "const": false },
          "answer_integration_changed": { "const": false },
          "recommended_action": { "type": "string" },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
