{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-hub.local/schemas/compare-packet.v1.json",
  "title": "knowledge-hub.compare-packet.v1",
  "description": "Evidence-first comparison packet. It separates citation-grade supporting spans from retrieval signals before synthesis.",
  "type": "object",
  "required": ["schema", "packet_id", "query", "dimensions", "coverage"],
  "properties": {
    "schema": { "const": "knowledge-hub.compare-packet.v1" },
    "packet_id": { "type": "string", "minLength": 1 },
    "query": { "type": "string" },
    "dimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dimensionId", "label", "comparisonStatus", "supportingSpans"],
        "properties": {
          "dimensionId": { "type": "string" },
          "label": { "type": "string" },
          "leftClaim": { "type": "string" },
          "rightClaim": { "type": "string" },
          "comparisonStatus": {
            "type": "string",
            "enum": ["supported", "conflict", "unknown", "insufficient"]
          },
          "supportingSpans": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["spanRef", "sourceId"],
              "properties": {
                "spanRef": { "type": "string" },
                "sourceId": { "type": "string" },
                "sourceType": { "type": "string" },
                "contentHash": { "type": "string" },
                "quote": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "retrievalSignals": {
      "type": "array",
      "items": { "type": "object" }
    },
    "coverage": {
      "type": "object",
      "required": ["dimensionCount", "supportingSpanCount", "excludedNonEvidenceSpanCount", "answerable"],
      "properties": {
        "dimensionCount": { "type": "integer", "minimum": 0 },
        "supportedDimensionCount": { "type": "integer", "minimum": 0 },
        "conflictDimensionCount": { "type": "integer", "minimum": 0 },
        "unknownDimensionCount": { "type": "integer", "minimum": 0 },
        "supportingSpanCount": { "type": "integer", "minimum": 0 },
        "excludedNonEvidenceSpanCount": { "type": "integer", "minimum": 0 },
        "answerable": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "schemaErrors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
