{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.sectionspan-contract-review.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "contractPrinciples",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.sectionspan-contract-review.v1" },
    "status": { "type": "string", "enum": ["contract_review_ready", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "sectionspanCandidateReport",
        "candidateLayerPromotionPolicyDraftReport",
        "sectionspanCandidateReportSchema",
        "candidateLayerPromotionPolicyDraftSchema"
      ],
      "properties": {
        "sectionspanCandidateReport": { "type": "string" },
        "candidateLayerPromotionPolicyDraftReport": { "type": "string" },
        "sectionspanCandidateReportSchema": { "type": "string" },
        "candidateLayerPromotionPolicyDraftSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputSectionSpanCandidates",
        "contractCandidateCount",
        "contractReadyCandidates",
        "blockedContractCandidates",
        "heldOutCandidates",
        "strictEligibleCandidates",
        "citationGradeCandidates",
        "runtimeEvidenceCandidates",
        "schemaViolationCount",
        "unsafeUpstreamFlagCount",
        "bySectionType",
        "byPaper",
        "byContractStatus",
        "heldOutByReason"
      ],
      "properties": {
        "inputSectionSpanCandidates": { "type": "integer", "minimum": 0 },
        "contractCandidateCount": { "type": "integer", "minimum": 0 },
        "contractReadyCandidates": { "type": "integer", "minimum": 0 },
        "blockedContractCandidates": { "type": "integer", "minimum": 0 },
        "heldOutCandidates": { "type": "integer", "minimum": 0 },
        "strictEligibleCandidates": { "const": 0 },
        "citationGradeCandidates": { "const": 0 },
        "runtimeEvidenceCandidates": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "bySectionType": { "type": "object" },
        "byPaper": { "type": "object" },
        "byContractStatus": { "type": "object" },
        "heldOutByReason": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "sectionspanContractReviewReady",
        "candidateFormalizationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "unsafeUpstreamFlags",
        "recommendedNextTranche"
      ],
      "properties": {
        "sectionspanContractReviewReady": { "type": "boolean" },
        "candidateFormalizationReady": { "type": "boolean" },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": ["sectionspan_contract_review_ready_non_strict", "blocked"]
        },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "unsafeUpstreamFlags": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "allCandidatesNonStrict",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "allCandidatesNonStrict": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "contractPrinciples": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "contractCandidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "contract_candidate_id",
          "source_candidate_id",
          "candidate_type",
          "paper_id",
          "source_parser",
          "candidate_text",
          "section_label",
          "section_title",
          "section_type",
          "section_level",
          "canonical_alignment_status",
          "alignment_method",
          "chars_start",
          "chars_end",
          "page",
          "sourceContentHash",
          "confidence",
          "contract_status",
          "contract_ready",
          "contract_blockers",
          "contract_requirements",
          "allowed_next_actions",
          "disallowed_actions",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "contract_candidate_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "candidate_type": { "const": "sectionspan_contract_candidate" },
          "paper_id": { "type": "string" },
          "source_parser": { "type": "string" },
          "candidate_text": { "type": "string" },
          "section_label": { "type": "string" },
          "section_title": { "type": "string" },
          "section_type": {
            "type": "string",
            "enum": ["numbered_section", "abstract", "backmatter", "named_section"]
          },
          "section_level": { "type": "integer", "minimum": 0 },
          "canonical_alignment_status": { "type": "string" },
          "alignment_method": { "type": "string" },
          "chars_start": { "type": "integer", "minimum": 0 },
          "chars_end": { "type": "integer", "minimum": 0 },
          "page": { "type": "integer", "minimum": 0 },
          "sourceContentHash": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "contract_status": { "type": "string", "enum": ["contract_ready_non_strict", "blocked"] },
          "contract_ready": { "type": "boolean" },
          "contract_blockers": { "type": "array", "items": { "type": "string" } },
          "contract_requirements": { "type": "array", "items": { "type": "string" } },
          "allowed_next_actions": { "type": "array", "items": { "type": "string" } },
          "disallowed_actions": { "type": "array", "items": { "type": "string" } },
          "evidence_tier": { "const": "sectionspan_contract_candidate_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "heldOut": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sourceCandidateId",
          "paperId",
          "candidateText",
          "reviewClass",
          "reason",
          "contractStatus",
          "strictEligible",
          "citationGrade",
          "runtimeEvidence"
        ],
        "properties": {
          "sourceCandidateId": { "type": "string" },
          "paperId": { "type": "string" },
          "candidateText": { "type": "string" },
          "reviewClass": { "type": "string" },
          "reason": { "type": "string" },
          "contractStatus": { "const": "held_out" },
          "strictEligible": { "const": false },
          "citationGrade": { "const": false },
          "runtimeEvidence": { "const": false }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
