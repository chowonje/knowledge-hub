{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.figure-caption-pdf-offset-feasibility.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "paperContexts",
    "feasibilityRows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.figure-caption-pdf-offset-feasibility.v1" },
    "status": { "type": "string", "enum": ["feasibility_complete", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "figureCaptionCandidateReport",
        "figureCaptionCandidateSchema",
        "pymupdfParsedRoot"
      ],
      "properties": {
        "figureCaptionCandidateReport": { "type": "string" },
        "figureCaptionCandidateSchema": { "type": "string" },
        "pymupdfParsedRoot": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputFigureCaptionCandidates",
        "feasibilityRows",
        "originalPdfOffsetRecoveredRows",
        "blockedRows",
        "exactRecoveredRows",
        "normalizedRecoveredRows",
        "fullCandidateTextRecoveredRows",
        "captionBodyTextRecoveredRows",
        "ambiguousRows",
        "noMatchRows",
        "pageAgreementRows",
        "sourceHashAgreementRows",
        "figureRegionVerifiedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "schemaViolationCount",
        "byPaper",
        "byFeasibilityStatus",
        "byMatchTarget",
        "strictBlockerSummary"
      ],
      "properties": {
        "inputFigureCaptionCandidates": { "type": "integer", "minimum": 0 },
        "feasibilityRows": { "type": "integer", "minimum": 0 },
        "originalPdfOffsetRecoveredRows": { "type": "integer", "minimum": 0 },
        "blockedRows": { "type": "integer", "minimum": 0 },
        "exactRecoveredRows": { "type": "integer", "minimum": 0 },
        "normalizedRecoveredRows": { "type": "integer", "minimum": 0 },
        "fullCandidateTextRecoveredRows": { "type": "integer", "minimum": 0 },
        "captionBodyTextRecoveredRows": { "type": "integer", "minimum": 0 },
        "ambiguousRows": { "type": "integer", "minimum": 0 },
        "noMatchRows": { "type": "integer", "minimum": 0 },
        "pageAgreementRows": { "type": "integer", "minimum": 0 },
        "sourceHashAgreementRows": { "type": "integer", "minimum": 0 },
        "figureRegionVerifiedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object" },
        "byFeasibilityStatus": { "type": "object" },
        "byMatchTarget": { "type": "object" },
        "strictBlockerSummary": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "feasibilityComplete",
        "applyExecuted",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "feasibilityComplete": { "type": "boolean" },
        "applyExecuted": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string", "enum": ["feasibility_complete_non_strict", "blocked"] },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "dryRunOnly",
        "applyExecuted",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "figureRegionVerificationRequired"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "dryRunOnly": { "const": true },
        "applyExecuted": { "const": false },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "figureRegionVerificationRequired": { "const": true }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "paperContexts": { "type": "object" },
    "feasibilityRows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "feasibility_row_id",
          "source_figure_caption_candidate_id",
          "paper_id",
          "candidate_text",
          "caption_text",
          "figure_label",
          "canonical_alignment_status",
          "canonical_alignment_method",
          "canonical_span",
          "layout_element_ids",
          "bbox",
          "layout_region_candidate_present",
          "figure_region_link_verified",
          "source_pdf_path",
          "source_manifest_path",
          "sourceContentHash",
          "evidence_tier",
          "report_only",
          "runtime_promotion_allowed",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "feasibility_status",
          "original_pdf_offset_recovered",
          "original_pdf_span",
          "match_target",
          "matched_text",
          "match_count",
          "attempted_matches",
          "page_agrees_with_canonical",
          "source_hash_agrees_with_canonical",
          "feasibility_failure_reason",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "feasibility_row_id": { "type": "string" },
          "source_figure_caption_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_text": { "type": "string" },
          "caption_text": { "type": "string" },
          "figure_label": { "type": "string" },
          "canonical_alignment_status": { "type": "string" },
          "canonical_alignment_method": { "type": "string" },
          "canonical_span": { "type": "object" },
          "layout_element_ids": { "type": "array", "items": { "type": "string" } },
          "bbox": {
            "anyOf": [
              {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": { "type": "number" }
              },
              { "type": "null" }
            ]
          },
          "layout_region_candidate_present": { "type": "boolean" },
          "figure_region_link_verified": { "const": false },
          "source_pdf_path": { "type": "string" },
          "source_manifest_path": { "type": "string" },
          "sourceContentHash": { "type": "string" },
          "evidence_tier": { "const": "figure_caption_pdf_offset_feasibility_only" },
          "report_only": { "const": true },
          "runtime_promotion_allowed": { "const": false },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "feasibility_status": { "type": "string" },
          "original_pdf_offset_recovered": { "type": "boolean" },
          "original_pdf_span": { "type": "object" },
          "match_target": { "type": "string" },
          "matched_text": { "type": "string" },
          "match_count": { "type": "integer", "minimum": 0 },
          "attempted_matches": { "type": "array", "items": { "type": "object" } },
          "page_agrees_with_canonical": { "type": "boolean" },
          "source_hash_agrees_with_canonical": { "type": "boolean" },
          "feasibility_failure_reason": { "type": "string" },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
