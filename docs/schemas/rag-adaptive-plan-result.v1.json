{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema",
    "status",
    "query",
    "sourceType",
    "retrievalMode",
    "topK",
    "alpha",
    "readOnly",
    "labsOnly",
    "retrievalStrategy",
    "plan",
    "suggestedActions",
    "actionsApplied",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.rag.adaptive-plan.result.v1" },
    "status": { "type": "string" },
    "query": { "type": "string" },
    "sourceType": { "type": "string" },
    "retrievalMode": { "type": "string" },
    "topK": { "type": "integer" },
    "alpha": { "type": "number" },
    "readOnly": { "type": "boolean" },
    "labsOnly": { "type": "boolean" },
    "retrievalStrategy": { "type": "object" },
    "retrievalQuality": { "type": "object" },
    "correctiveRetrieval": { "type": "object" },
    "plan": { "type": "object" },
    "suggestedActions": { "type": "array" },
    "actionsApplied": { "type": "array" },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
