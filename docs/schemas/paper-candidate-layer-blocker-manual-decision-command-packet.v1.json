{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.candidate-layer-blocker-manual-decision-command-packet.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "derivedPaths",
    "counts",
    "gate",
    "policy",
    "warnings",
    "commands"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.candidate-layer-blocker-manual-decision-command-packet.v1" },
    "status": { "type": "string", "enum": ["command_packet_ready", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "candidateLayerBlockerDecisionInputPackReport",
        "candidateLayerBlockerDecisionInputPackSchema",
        "candidateLayerBlockerDecisionTemplateReport",
        "candidateLayerBlockerDecisionTemplateSchema",
        "candidateLayerBlockerDecisionFileDraftReport",
        "candidateLayerBlockerDecisionFileDraftSchema",
        "candidateLayerBlockerBacklogReport",
        "candidateLayerBlockerBacklogSchema",
        "worktree",
        "outputDir"
      ],
      "properties": {
        "candidateLayerBlockerDecisionInputPackReport": { "type": "string" },
        "candidateLayerBlockerDecisionInputPackSchema": { "type": "string" },
        "candidateLayerBlockerDecisionTemplateReport": { "type": "string" },
        "candidateLayerBlockerDecisionTemplateSchema": { "type": "string" },
        "candidateLayerBlockerDecisionFileDraftReport": { "type": "string" },
        "candidateLayerBlockerDecisionFileDraftSchema": { "type": "string" },
        "candidateLayerBlockerBacklogReport": { "type": "string" },
        "candidateLayerBlockerBacklogSchema": { "type": "string" },
        "worktree": { "type": "string" },
        "outputDir": { "type": "string" }
      },
      "additionalProperties": true
    },
    "derivedPaths": {
      "type": "object",
      "properties": {
        "reviewFile": { "type": "string" },
        "validationOutputDir": { "type": "string" },
        "recordOutputDir": { "type": "string" },
        "recordReport": { "type": "string" },
        "previewOutputDir": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "commandCount",
        "inputRows",
        "manualDecisionInputRows",
        "technicalDecisionInputRows",
        "policyDecisionInputRows",
        "repoFilesChanged",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "schemaViolationCount"
      ],
      "properties": {
        "commandCount": { "type": "integer", "minimum": 0 },
        "inputRows": { "type": "integer", "minimum": 0 },
        "manualDecisionInputRows": { "type": "integer", "minimum": 0 },
        "technicalDecisionInputRows": { "type": "integer", "minimum": 0 },
        "policyDecisionInputRows": { "type": "integer", "minimum": 0 },
        "repoFilesChanged": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "commandPacketReady",
        "manualEditRequired",
        "commandsExecuted",
        "decisionsRecorded",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "commandPacketReady": { "type": "boolean" },
        "manualEditRequired": { "type": "boolean" },
        "commandsExecuted": { "const": false },
        "decisionsRecorded": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string" },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "commandPacketOnly",
        "commandsExecuted",
        "decisionFileModified",
        "decisionRecordCreated",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "commandPacketOnly": { "const": true },
        "commandsExecuted": { "const": false },
        "decisionFileModified": { "const": false },
        "decisionRecordCreated": { "const": false },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step",
          "name",
          "purpose",
          "command",
          "reads",
          "writes",
          "requires",
          "doesNotDo"
        ],
        "properties": {
          "step": { "type": "integer", "minimum": 1 },
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "command": { "type": "string" },
          "reads": { "type": "array", "items": { "type": "string" } },
          "writes": { "type": "array", "items": { "type": "string" } },
          "requires": { "type": "array", "items": { "type": "string" } },
          "doesNotDo": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
