{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-hub.local/schemas/crawl-pending-list-result.v1.json",
  "title": "knowledge-hub crawl pending list result v1",
  "type": "object",
  "required": [
    "schema",
    "topic",
    "status",
    "count",
    "items",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schema": {
      "const": "knowledge-hub.crawl.pending.list.result.v1"
    },
    "topic": {
      "type": "string"
    },
    "topicSlug": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["ok", "error", "blocked"]
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "run_id",
          "topic_slug",
          "note_id",
          "source_url",
          "source_canonical_id",
          "relation_norm",
          "target_canonical_id",
          "confidence",
          "status"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "run_id": {
            "type": "string",
            "minLength": 1
          },
          "topic_slug": {
            "type": "string",
            "minLength": 1
          },
          "note_id": {
            "type": "string",
            "minLength": 1
          },
          "source_url": {
            "type": "string"
          },
          "source_canonical_id": {
            "type": "string",
            "minLength": 1
          },
          "relation_norm": {
            "type": "string"
          },
          "target_canonical_id": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence_ptrs_json": {
            "type": "array",
            "items": { "type": "object" }
          },
          "reason_json": {
            "type": "object"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "approved", "rejected"]
          },
          "created_at": {
            "type": "string"
          },
          "reviewed_at": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": true
      }
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "schemaErrors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
