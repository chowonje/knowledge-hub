{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.parsed-artifact-strict-evidence-promotion-tranche-plan.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "tranches",
    "blockedLater",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": {
      "const": "knowledge-hub.paper.parsed-artifact-strict-evidence-promotion-tranche-plan.v1"
    },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "required": ["policyGateReportPath", "policyGateSchema", "requestedPaperIds"],
      "properties": {
        "policyGateReportPath": { "type": "string" },
        "policyGateSchema": { "type": "string" },
        "policyGateReportStatus": { "type": "string" },
        "requestedPaperIds": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputRows",
        "policyCandidateRows",
        "plannedPromotionRows",
        "sectionPilotRows",
        "figureCaptionPilotRows",
        "holdoutRows",
        "blockedInputReportSchemaViolationRows",
        "blockedPolicyGateNotCandidateRows",
        "blockedMissingRecordIdentityRows",
        "blockedUnsupportedArtifactTypeRows",
        "blockedRuntimeOrCitationFlagViolationRows",
        "strictEvidenceWriteRows",
        "strictEvidenceCreatedRows",
        "citationGradeEvidenceCreatedRows",
        "runtimeEvidenceCreatedRows",
        "parserRoutingChangedRows",
        "answerIntegrationChangedRows",
        "databaseMutationRows",
        "canonicalParsedArtifactWriteRows",
        "sourceSpanUpdatedRows",
        "schemaViolationCount",
        "byPaperId",
        "byArtifactType",
        "byPlannedTranche",
        "byPlanStatus",
        "byRecommendedAction"
      ],
      "properties": {
        "inputRows": { "type": "integer", "minimum": 0 },
        "policyCandidateRows": { "type": "integer", "minimum": 0 },
        "plannedPromotionRows": { "type": "integer", "minimum": 0 },
        "sectionPilotRows": { "type": "integer", "minimum": 0 },
        "figureCaptionPilotRows": { "type": "integer", "minimum": 0 },
        "holdoutRows": { "type": "integer", "minimum": 0 },
        "blockedInputReportSchemaViolationRows": { "type": "integer", "minimum": 0 },
        "blockedPolicyGateNotCandidateRows": { "type": "integer", "minimum": 0 },
        "blockedMissingRecordIdentityRows": { "type": "integer", "minimum": 0 },
        "blockedUnsupportedArtifactTypeRows": { "type": "integer", "minimum": 0 },
        "blockedRuntimeOrCitationFlagViolationRows": { "type": "integer", "minimum": 0 },
        "strictEvidenceWriteRows": { "const": 0 },
        "strictEvidenceCreatedRows": { "const": 0 },
        "citationGradeEvidenceCreatedRows": { "const": 0 },
        "runtimeEvidenceCreatedRows": { "const": 0 },
        "parserRoutingChangedRows": { "const": 0 },
        "answerIntegrationChangedRows": { "const": 0 },
        "databaseMutationRows": { "const": 0 },
        "canonicalParsedArtifactWriteRows": { "const": 0 },
        "sourceSpanUpdatedRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaperId": { "type": "object" },
        "byArtifactType": { "type": "object" },
        "byPlannedTranche": { "type": "object" },
        "byPlanStatus": { "type": "object" },
        "byRecommendedAction": { "type": "object" }
      },
      "additionalProperties": true
    },
    "tranches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["trancheId", "status", "scope", "rowCount"],
        "properties": {
          "trancheId": { "type": "string" },
          "status": { "type": "string" },
          "artifactTypes": { "type": "array", "items": { "type": "string" } },
          "scope": { "type": "string" },
          "rowCount": { "type": "integer", "minimum": 0 },
          "recommendedExecutionOrder": { "type": ["integer", "null"] }
        },
        "additionalProperties": true
      }
    },
    "blockedLater": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gateId", "status", "reason"],
        "properties": {
          "gateId": { "type": "string" },
          "status": { "type": "string" },
          "reason": { "type": "string" },
          "requiresExplicitTranche": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "gate": {
      "type": "object",
      "required": [
        "promotionTranchePlanReady",
        "strictEligibleMutationAllowed",
        "strictEvidenceStoreWriteAllowed",
        "strictEvidenceCreated",
        "citationReady",
        "runtimeEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimeMutationAllowed",
        "schemaViolations",
        "decision",
        "recommendedNextTranche",
        "recommendedTrancheExecutionOrder"
      ],
      "properties": {
        "promotionTranchePlanReady": { "type": "boolean" },
        "strictEligibleMutationAllowed": { "const": false },
        "strictEvidenceStoreWriteAllowed": { "const": false },
        "strictEvidenceCreated": { "const": false },
        "citationReady": { "const": false },
        "runtimeEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimeMutationAllowed": { "const": false },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "decision": {
          "type": "string",
          "enum": [
            "parsed_artifact_strict_evidence_promotion_tranche_plan_ready",
            "blocked"
          ]
        },
        "recommendedNextTranche": { "type": "string" },
        "recommendedTrancheExecutionOrder": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "promotionTranchePlanOnly",
        "strictEvidenceStoreWrite",
        "sourceSpanStoreWrite",
        "strictEvidenceCreated",
        "strictEligibleMutation",
        "citationGradeEvidenceCreated",
        "runtimeEvidenceCreated",
        "parserRoutingChanged",
        "answerIntegrationChanged",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "canonicalParsedArtifactsWritten"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "promotionTranchePlanOnly": { "const": true },
        "strictEvidenceStoreWrite": { "const": false },
        "sourceSpanStoreWrite": { "const": false },
        "strictEvidenceCreated": { "const": false },
        "strictEligibleMutation": { "const": false },
        "citationGradeEvidenceCreated": { "const": false },
        "runtimeEvidenceCreated": { "const": false },
        "parserRoutingChanged": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "plan_row_id",
          "policy_gate_row_id",
          "strictEvidenceId",
          "sourceSpanId",
          "candidateRecordId",
          "runId",
          "paper_id",
          "artifact_type",
          "sourceContentHash",
          "idempotencyKey",
          "strict_evidence_store_path",
          "strict_evidence_store_line",
          "policy_gate_status",
          "strictEvidencePolicyCandidateOnly",
          "planned_tranche",
          "planned_tranche_scope",
          "plan_status",
          "plan_blockers",
          "promotionTranchePlanCandidateOnly",
          "strictEligible",
          "strictEvidenceWriteRows",
          "strictEvidenceCreated",
          "citationGrade",
          "runtimeEvidence",
          "parserRoutingChanged",
          "answerIntegrationChanged",
          "databaseMutation",
          "canonicalParsedArtifactsWritten",
          "sourceSpanUpdatedRows",
          "recommended_action"
        ],
        "properties": {
          "plan_row_id": { "type": "string" },
          "policy_gate_row_id": { "type": "string" },
          "strictEvidenceId": { "type": "string" },
          "sourceSpanId": { "type": "string" },
          "candidateRecordId": { "type": "string" },
          "runId": { "type": "string" },
          "paper_id": { "type": "string" },
          "artifact_type": { "type": "string" },
          "sourceContentHash": { "type": "string" },
          "idempotencyKey": { "type": "string" },
          "strict_evidence_store_path": { "type": "string" },
          "strict_evidence_store_line": { "type": "integer", "minimum": 0 },
          "policy_gate_status": { "type": "string" },
          "strictEvidencePolicyCandidateOnly": { "type": "boolean" },
          "planned_tranche": { "type": "string" },
          "planned_tranche_scope": { "type": "string" },
          "plan_status": {
            "type": "string",
            "enum": [
              "promotion_tranche_plan_candidate_only",
              "blocked_policy_gate_not_candidate",
              "blocked_missing_record_identity",
              "blocked_unsupported_artifact_type",
              "blocked_runtime_or_citation_flag_violation",
              "blocked_input_schema_violation"
            ]
          },
          "plan_blockers": { "type": "array", "items": { "type": "string" } },
          "promotionTranchePlanCandidateOnly": { "type": "boolean" },
          "strictEligible": { "const": false },
          "strictEvidenceWriteRows": { "const": 0 },
          "strictEvidenceCreated": { "const": false },
          "citationGrade": { "const": false },
          "runtimeEvidence": { "const": false },
          "parserRoutingChanged": { "const": false },
          "answerIntegrationChanged": { "const": false },
          "databaseMutation": { "const": false },
          "canonicalParsedArtifactsWritten": { "const": false },
          "sourceSpanUpdatedRows": { "const": 0 },
          "recommended_action": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
