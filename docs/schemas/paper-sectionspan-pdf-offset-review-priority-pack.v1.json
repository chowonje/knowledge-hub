{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.sectionspan-pdf-offset-review-priority-pack.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "priorityCards"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.sectionspan-pdf-offset-review-priority-pack.v1" },
    "status": { "type": "string", "enum": ["priority_pack_ready", "no_pending_review_rows", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "sectionspanPdfOffsetReviewDecisionRecordReport",
        "sectionspanPdfOffsetReviewDecisionRecordSchema",
        "maxInitialCards"
      ],
      "properties": {
        "sectionspanPdfOffsetReviewDecisionRecordReport": { "type": "string" },
        "sectionspanPdfOffsetReviewDecisionRecordSchema": { "type": "string" },
        "maxInitialCards": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputDecisionRecordRows",
        "priorityCardRows",
        "selectedInitialReviewRows",
        "needsReviewRows",
        "approvedRows",
        "rejectedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "unsafeUpstreamFlagCount",
        "byPaper",
        "bySectionType",
        "byReviewPriority",
        "bySelection"
      ],
      "properties": {
        "inputDecisionRecordRows": { "type": "integer", "minimum": 0 },
        "priorityCardRows": { "type": "integer", "minimum": 0 },
        "selectedInitialReviewRows": { "type": "integer", "minimum": 0 },
        "needsReviewRows": { "type": "integer", "minimum": 0 },
        "approvedRows": { "const": 0 },
        "rejectedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object" },
        "bySectionType": { "type": "object" },
        "byReviewPriority": { "type": "object" },
        "bySelection": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "priorityPackReady",
        "humanReviewComplete",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "unsafeUpstreamFlags",
        "recommendedNextTranche"
      ],
      "properties": {
        "priorityPackReady": { "type": "boolean" },
        "humanReviewComplete": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": [
            "initial_manual_review_priority_pack_ready",
            "no_pending_sectionspan_review_rows",
            "blocked"
          ]
        },
        "unsafeUpstreamFlags": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "priorityPackOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "priorityPackOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "priorityCards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "priority_card_id",
          "source_decision_record_row_id",
          "source_decision_row_id",
          "source_gate_row_id",
          "source_review_card_id",
          "source_sectionspan_candidate_id",
          "paper_id",
          "candidate_text",
          "section_type",
          "section_level",
          "recorded_decision",
          "review_priority",
          "selected_for_initial_review",
          "priority_reasons",
          "canonical_span",
          "original_pdf_span",
          "page_agreement",
          "source_hash_agreement",
          "review_checklist",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "priority_card_id": { "type": "string" },
          "source_decision_record_row_id": { "type": "string" },
          "source_decision_row_id": { "type": "string" },
          "source_gate_row_id": { "type": "string" },
          "source_review_card_id": { "type": "string" },
          "source_sectionspan_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_text": { "type": "string" },
          "section_type": { "type": "string" },
          "section_level": { "type": "integer", "minimum": 0 },
          "recorded_decision": { "const": "needs_review" },
          "review_priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "selected_for_initial_review": { "type": "boolean" },
          "priority_reasons": { "type": "array", "items": { "type": "string" } },
          "canonical_span": { "type": "object" },
          "original_pdf_span": { "type": "object" },
          "page_agreement": { "type": "boolean" },
          "source_hash_agreement": { "type": "boolean" },
          "review_checklist": { "type": "array", "items": { "type": "string" } },
          "evidence_tier": { "const": "sectionspan_pdf_offset_review_priority_card_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
