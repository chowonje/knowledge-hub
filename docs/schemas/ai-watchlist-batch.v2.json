{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-hub.local/schemas/ai-watchlist-batch.v2.json",
  "title": "knowledge-hub ai watchlist batch v2",
  "type": "object",
  "required": ["schema", "version", "kind", "category", "updated_at", "count", "items"],
  "properties": {
    "schema": {
      "const": "knowledge-hub.ai-watchlist-batch.v2"
    },
    "version": {
      "const": 2
    },
    "kind": {
      "const": "ai_watchlist_batch"
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/discoveredSourceItem"
      }
    },
    "status": {
      "type": "string"
    },
    "watchlist": {
      "type": "string"
    },
    "outputPrefix": {
      "type": "string"
    },
    "txtPath": {
      "type": "string"
    },
    "yamlPath": {
      "type": "string"
    },
    "bySource": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "failedSources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_name", "error"],
        "properties": {
          "source_name": {"type": "string"},
          "error": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "schemaErrors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "sourceIdentity": {
      "type": "object",
      "required": ["source_vendor", "source_channel", "source_channel_type", "source_item_id"],
      "properties": {
        "source_vendor": {"type": "string"},
        "source_channel": {"type": "string"},
        "source_channel_type": {"type": "string"},
        "source_item_id": {"type": "string"}
      },
      "additionalProperties": false
    },
    "discoveryProvenance": {
      "type": "object",
      "required": ["method", "origin_url", "entry_ref", "discovered_at", "rank"],
      "properties": {
        "method": {"type": "string"},
        "origin_url": {"type": "string"},
        "entry_ref": {"type": "string"},
        "discovered_at": {"type": "string"},
        "rank": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "discoveredSourceItem": {
      "type": "object",
      "required": [
        "identity",
        "source_name",
        "source_type",
        "url",
        "canonical_url",
        "title_hint",
        "published_at",
        "author",
        "tags",
        "provenance",
        "metadata"
      ],
      "properties": {
        "identity": {"$ref": "#/$defs/sourceIdentity"},
        "source_name": {"type": "string"},
        "source_type": {"type": "string"},
        "url": {"type": "string"},
        "canonical_url": {"type": "string"},
        "title_hint": {"type": "string"},
        "published_at": {"type": "string"},
        "author": {"type": "string"},
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "provenance": {"$ref": "#/$defs/discoveryProvenance"},
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
