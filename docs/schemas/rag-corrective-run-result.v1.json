{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema",
    "status",
    "query",
    "sourceType",
    "retrievalMode",
    "topK",
    "alpha",
    "execute",
    "readOnly",
    "writeFree",
    "initialReport",
    "retryReport",
    "suggestedActions",
    "actionsApplied",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.rag.corrective-run.result.v1" },
    "status": { "type": "string" },
    "query": { "type": "string" },
    "sourceType": { "type": "string" },
    "retrievalMode": { "type": "string" },
    "topK": { "type": "integer" },
    "alpha": { "type": "number" },
    "execute": { "type": "boolean" },
    "readOnly": { "type": "boolean" },
    "writeFree": { "type": "boolean" },
    "initialReport": { "type": "object" },
    "retryReport": { "type": "object" },
    "suggestedActions": { "type": "array" },
    "actionsApplied": { "type": "array" },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
