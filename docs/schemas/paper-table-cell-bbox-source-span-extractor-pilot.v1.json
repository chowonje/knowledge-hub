        "tableRegionPdfOffsetFeasibilityReport",
        "tableCellAuthorityDesignSchema",
        "tableRegionPdfOffsetFeasibilitySchema",
        "maxReadyRows"
      ],
      "properties": {
        "tableCellAuthorityDesignReport": { "type": "string" },
        "tableRegionPdfOffsetFeasibilityReport": { "type": "string" },
        "tableCellAuthorityDesignSchema": { "type": "string" },
        "tableRegionPdfOffsetFeasibilitySchema": { "type": "string" },
        "maxReadyRows": { "type": "integer", "minimum": 0 }
