        "recommendedNextTranche"
      ],
      "properties": {
        "pilotComplete": { "type": "boolean" },
        "cellBboxCandidatesObserved": { "type": "boolean" },
        "cellBboxTextPairingVerified": { "const": false },
        "cellSourceSpansCreated": { "const": false },
        "cellSourceHashLinked": { "const": false },
        "tableCellEvidenceReady": { "const": false },
        "tableCellCitationGradeReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": ["table_cell_extractor_pilot_complete_non_strict", "blocked"]
        },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "unsafeUpstreamFlags": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "pilotOnly",
        "tableCellEvidenceCreated",
        "tableCellCitationGradeEvidenceCreated",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
