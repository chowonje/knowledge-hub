{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.ops.report.run.result.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "policyVersion",
    "ts",
    "koNoteRunId",
    "koNoteReport",
    "ragReport",
    "alertCounts",
    "alerts",
    "recommendedActions",
    "artifactPaths",
    "notePath",
    "actionQueue",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.ops.report.run.result.v1" },
    "status": { "type": "string", "enum": ["ok", "warning", "failed"] },
    "policyVersion": { "type": "string" },
    "ts": { "type": "string" },
    "koNoteRunId": { "type": "string" },
    "koNoteReport": { "type": "object" },
    "ragReport": { "type": "object" },
    "alertCounts": {
      "type": "object",
      "required": ["info", "warning", "critical", "total"],
      "properties": {
        "info": { "type": "integer", "minimum": 0 },
        "warning": { "type": "integer", "minimum": 0 },
        "critical": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "alerts": {
      "type": "array",
      "items": { "type": "object" }
    },
    "recommendedActions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "artifactPaths": {
      "type": "object",
      "required": ["root", "snapshotDir", "opsReportJson", "koNoteReportJson", "ragReportJson"],
      "properties": {
        "root": { "type": "string" },
        "snapshotDir": { "type": "string" },
        "opsReportJson": { "type": "string" },
        "koNoteReportJson": { "type": "string" },
        "ragReportJson": { "type": "string" }
      },
      "additionalProperties": false
    },
    "notePath": { "type": "string" },
    "actionQueue": {
      "type": "object",
      "required": ["created", "updated", "reopened", "counts", "pendingActions", "warnings"],
      "properties": {
        "created": { "type": "integer", "minimum": 0 },
        "updated": { "type": "integer", "minimum": 0 },
        "reopened": { "type": "integer", "minimum": 0 },
        "counts": {
          "type": "object",
          "required": ["pending", "acked", "resolved", "total"],
          "properties": {
            "pending": { "type": "integer", "minimum": 0 },
            "acked": { "type": "integer", "minimum": 0 },
            "resolved": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "pendingActions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["actionId", "scope", "actionType", "status", "summary", "command", "args", "targetKind", "targetKey", "seenCount", "lastSeenAt", "lastExecutionStatus", "lastResultSummary"],
            "properties": {
              "actionId": { "type": "string" },
              "scope": { "type": "string" },
              "actionType": { "type": "string" },
              "status": { "type": "string" },
              "summary": { "type": "string" },
              "command": { "type": "string" },
              "args": { "type": "array", "items": { "type": "string" } },
              "targetKind": { "type": "string" },
              "targetKey": { "type": "string" },
              "seenCount": { "type": "integer", "minimum": 0 },
              "lastSeenAt": { "type": "string" },
              "lastExecutionStatus": { "type": "string" },
              "lastResultSummary": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
