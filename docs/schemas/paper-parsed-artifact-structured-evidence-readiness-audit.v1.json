{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.parsed-artifact-structured-evidence-readiness-audit.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "gate",
    "policy",
    "warnings",
    "rows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.parsed-artifact-structured-evidence-readiness-audit.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "properties": {
        "sectionspanCandidateReport": { "type": "string" },
        "tableRegionCandidateReport": { "type": "string" },
        "figureCaptionCandidateReport": { "type": "string" },
        "equationQuoteCandidateReport": { "type": "string" },
        "texRenderedMacroTermProfileDesignReport": { "type": "string" },
        "texSegmentedMultilineMatchingDesignReport": { "type": "string" },
        "texLabelNumberPdfRegionDisambiguationDesignReport": { "type": "string" },
        "texEquationPdfRegionAnchorAuditReport": { "type": "string" },
        "parsedRoot": { "type": "string" },
        "requestedPaperIds": { "type": "array", "items": { "type": "string" } },
        "sectionspanSchema": { "type": "string" },
        "tableRegionSchema": { "type": "string" },
        "figureCaptionSchema": { "type": "string" },
        "equationQuoteSchema": { "type": "string" },
        "texRenderedMacroTermProfileDesignSchema": { "type": "string" },
        "texSegmentedMultilineMatchingDesignSchema": { "type": "string" },
        "texLabelNumberPdfRegionDisambiguationDesignSchema": { "type": "string" },
        "texPdfRegionAnchorSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputRows",
        "targetRows",
        "promotionReviewReadyCandidateOnlyRows",
        "blockedMissingSourceHashRows",
        "blockedAmbiguousPdfRegionRows",
        "blockedMissingLabelNumberRows",
        "blockedPdfRegionOnlyRows",
        "blockedManualOrLaterExtractorRows",
        "sourceSpanCreatedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "parserRoutingChangedRows",
        "answerIntegrationChangedRows",
        "schemaViolationCount",
        "byArtifactType",
        "byReadinessStatus",
        "byRecommendedAction"
      ],
      "properties": {
        "inputRows": { "type": "integer", "minimum": 0 },
        "targetRows": { "type": "integer", "minimum": 0 },
        "promotionReviewReadyCandidateOnlyRows": { "type": "integer", "minimum": 0 },
        "blockedMissingSourceHashRows": { "type": "integer", "minimum": 0 },
        "blockedAmbiguousPdfRegionRows": { "type": "integer", "minimum": 0 },
        "blockedMissingLabelNumberRows": { "type": "integer", "minimum": 0 },
        "blockedPdfRegionOnlyRows": { "type": "integer", "minimum": 0 },
        "blockedManualOrLaterExtractorRows": { "type": "integer", "minimum": 0 },
        "sourceSpanCreatedRows": { "type": "integer", "minimum": 0 },
        "strictEligibleRows": { "type": "integer", "minimum": 0 },
        "citationGradeRows": { "type": "integer", "minimum": 0 },
        "runtimeEvidenceRows": { "type": "integer", "minimum": 0 },
        "parserRoutingChangedRows": { "type": "integer", "minimum": 0 },
        "answerIntegrationChangedRows": { "type": "integer", "minimum": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byArtifactType": { "type": "object" },
        "byReadinessStatus": { "type": "object" },
        "byRecommendedAction": { "type": "object" },
        "parsedPaperCoverage": { "type": "object" },
        "inputPaperCount": { "type": "integer", "minimum": 0 },
        "papersMissingParsedArtifacts": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "readyForPromotionReadinessReview",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "schemaViolations",
        "decision",
        "recommendedNextTranche"
      ],
      "properties": {
        "readyForPromotionReadinessReview": { "type": "boolean" },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "decision": { "type": "string", "enum": ["parsed_artifact_structured_evidence_readiness_audit_ready", "blocked"] },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "designOnly",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "canonicalParsedArtifactsWritten",
        "sourceSpanCreated",
        "strictEvidenceCreated",
        "runtimeEvidenceCreated",
        "parserRoutingChanged",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "designOnly": { "const": true },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "sourceSpanCreated": { "const": false },
        "strictEvidenceCreated": { "const": false },
        "runtimeEvidenceCreated": { "const": false },
        "parserRoutingChanged": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_type",
          "paper_id",
          "source_candidate_id",
          "sourceContentHash",
          "source_tex_row_id",
          "source_file",
          "page",
          "bbox",
          "blockIndexes",
          "labelNumberHint",
          "strict_blockers",
          "non_strict_reason",
          "readiness_status",
          "recommended_action"
        ],
        "properties": {
          "artifact_type": { "type": "string", "enum": ["section", "table", "figure", "equation"] },
          "paper_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "sourceContentHash": { "type": "string" },
          "source_tex_row_id": { "type": "string" },
          "source_file": { "type": "string" },
        "page": { "type": ["integer", "null"], "minimum": 0 },
          "bbox": { "type": "array", "items": { "type": "number" } },
          "blockIndexes": { "type": "array", "items": { "type": "integer" } },
          "labelNumberHint": {},
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } },
          "readiness_status": {
            "type": "string",
            "enum": [
              "promotion_review_ready_candidate_only",
              "blocked_missing_source_hash",
              "blocked_ambiguous_pdf_region",
              "blocked_missing_label_number_disambiguation",
              "blocked_pdf_region_only_not_source_span",
              "blocked_requires_manual_or_later_extractor_review"
            ]
          },
          "recommended_action": { "type": "string" },
          "source_span_created": { "type": "boolean" },
          "strict_eligible": { "type": "boolean" },
          "citation_grade": { "type": "boolean" },
          "runtime_evidence": { "type": "boolean" },
          "parser_routing_changed": { "type": "boolean" },
          "answer_integration_changed": { "type": "boolean" },
          "parsedManifestPresent": { "type": "boolean" },
          "parsedDocumentPresent": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
