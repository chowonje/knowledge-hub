    "generatedAt": { "type": "string" },
    "repoRoot": { "type": "string" },
    "runsRoot": { "type": "string" },
    "runsRootPhysical": { "type": "string" },
    "runsRootIsSymlink": { "type": "boolean" },
    "queriesDir": { "type": "string" },
    "sourceQuality": { "type": "object" },
    "answerLoop": { "type": "object" },
    "failureBank": { "type": "object" },
    "evalCases": { "type": "object" },
    "queryInventory": { "type": "object" },
    "reportIndex": { "type": "object" },
    "coverage": { "type": "object" },
    "gaps": { "type": "array", "items": { "type": "object" } },
    "recommendations": { "type": "array", "items": { "type": "string" } },
    "operatorBrief": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "schemaErrors": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
