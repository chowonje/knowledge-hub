    "status",
    "generatedAt",
    "repoRoot",
    "runsRoot",
    "queriesDir",
    "sourceQuality",
    "answerLoop",
    "failureBank",
    "evalCases",
    "queryInventory",
    "reportIndex",
    "coverage",
    "gaps",
    "recommendations",
    "operatorBrief",
    "warnings"
  ],
  "properties": {
