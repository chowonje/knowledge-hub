{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.candidate-layer-blocker-decision-input-pack.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "decisionInputs"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.candidate-layer-blocker-decision-input-pack.v1" },
    "status": { "type": "string", "enum": ["decision_input_pack_ready", "no_pending_decision_inputs", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "candidateLayerBlockerDecisionTemplateReport",
        "candidateLayerBlockerDecisionTemplateSchema",
        "candidateLayerBlockerDecisionRecordReport",
        "candidateLayerBlockerDecisionRecordSchema"
      ],
      "properties": {
        "candidateLayerBlockerDecisionTemplateReport": { "type": "string" },
        "candidateLayerBlockerDecisionTemplateSchema": { "type": "string" },
        "candidateLayerBlockerDecisionRecordReport": { "type": "string" },
        "candidateLayerBlockerDecisionRecordSchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputRows",
        "pendingSourceDecisionRows",
        "defaultNeedsReviewRows",
        "manualDecisionInputRows",
        "operatorApprovalInputRows",
        "technicalDecisionInputRows",
        "policyDecisionInputRows",
        "acceptedDecisionRows",
        "operatorApprovedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "unsafeUpstreamFlagCount",
        "byBucket",
        "byPriority",
        "byLayer"
      ],
      "properties": {
        "inputRows": { "type": "integer", "minimum": 0 },
        "pendingSourceDecisionRows": { "type": "integer", "minimum": 0 },
        "defaultNeedsReviewRows": { "type": "integer", "minimum": 0 },
        "manualDecisionInputRows": { "type": "integer", "minimum": 0 },
        "operatorApprovalInputRows": { "type": "integer", "minimum": 0 },
        "technicalDecisionInputRows": { "type": "integer", "minimum": 0 },
        "policyDecisionInputRows": { "type": "integer", "minimum": 0 },
        "acceptedDecisionRows": { "const": 0 },
        "operatorApprovedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "byBucket": { "type": "object" },
        "byPriority": { "type": "object" },
        "byLayer": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "decisionInputPackReady",
        "containsAcceptedDecisions",
        "containsOperatorApprovals",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "unsafeUpstreamFlags",
        "recommendedNextTranche"
      ],
      "properties": {
        "decisionInputPackReady": { "type": "boolean" },
        "containsAcceptedDecisions": { "const": false },
        "containsOperatorApprovals": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": ["pending_decision_inputs_ready", "no_pending_decision_rows", "blocked"]
        },
        "unsafeUpstreamFlags": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "decisionInputPackOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "decisionInputPackOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "decisionInputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "input_row_id",
          "source_decision_row_id",
          "source_review_card_id",
          "source_backlog_id",
          "blocker",
          "priority",
          "review_bucket",
          "affected_layers",
          "affected_candidate_count",
          "affected_eval_question_count",
          "recommended_next_tranche",
          "recommended_review_action",
          "allowed_decisions",
          "decision",
          "reviewer",
          "notes",
          "decision_scope",
          "evidence_tier",
          "report_only",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "input_row_id": { "type": "string" },
          "source_decision_row_id": { "type": "string" },
          "source_review_card_id": { "type": "string" },
          "source_backlog_id": { "type": "string" },
          "blocker": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "review_bucket": {
            "type": "string",
            "enum": [
              "manual_decision_required",
              "operator_approval_required",
              "technical_feasibility_blocked",
              "policy_review_only"
            ]
          },
          "affected_layers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["sectionspan", "figure_caption", "equation_quote", "table_region"]
            }
          },
          "affected_candidate_count": { "type": "integer", "minimum": 0 },
          "affected_eval_question_count": { "type": "integer", "minimum": 0 },
          "recommended_next_tranche": { "type": "string" },
          "recommended_review_action": { "type": "string" },
          "allowed_decisions": { "type": "array", "items": { "type": "string" } },
          "decision": { "const": "needs_review" },
          "reviewer": { "type": "string" },
          "notes": { "type": "string" },
          "decision_scope": {
            "const": "candidate_layer_blocker_decision_input_pack_only_no_runtime_or_strict_promotion"
          },
          "evidence_tier": { "const": "candidate_layer_blocker_decision_input_pack_only" },
          "report_only": { "const": true },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
