{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.ops.action.list.result.v1",
  "type": "object",
  "required": ["schema", "status", "count", "counts", "filters", "items"],
  "properties": {
    "schema": { "const": "knowledge-hub.ops.action.list.result.v1" },
    "status": { "type": "string", "enum": ["ok", "failed"] },
    "count": { "type": "integer", "minimum": 0 },
    "counts": {
      "type": "object",
      "required": ["pending", "acked", "resolved", "total"],
      "properties": {
        "pending": { "type": "integer", "minimum": 0 },
        "acked": { "type": "integer", "minimum": 0 },
        "resolved": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "filters": {
      "type": "object",
      "required": ["status", "scope"],
      "properties": {
        "status": { "type": "string" },
        "scope": { "type": "string" }
      },
      "additionalProperties": false
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["actionId", "scope", "actionType", "status", "targetKind", "targetKey", "summary", "reasonCodes", "command", "args", "alerts", "seenCount", "firstSeenAt", "lastSeenAt", "ackedAt", "ackedBy", "resolvedAt", "resolvedBy", "note", "lastExecutionAt", "lastExecutionStatus", "lastResultSummary", "lastReceiptId", "lastMcpJobId"],
        "properties": {
          "actionId": { "type": "string" },
          "scope": { "type": "string" },
          "actionType": { "type": "string" },
          "status": { "type": "string" },
          "targetKind": { "type": "string" },
          "targetKey": { "type": "string" },
          "summary": { "type": "string" },
          "reasonCodes": { "type": "array", "items": { "type": "string" } },
          "command": { "type": "string" },
          "args": { "type": "array", "items": { "type": "string" } },
          "alerts": { "type": "array", "items": { "type": "object" } },
          "action": { "type": "object" },
          "seenCount": { "type": "integer", "minimum": 0 },
          "firstSeenAt": { "type": "string" },
          "lastSeenAt": { "type": "string" },
          "ackedAt": { "type": "string" },
          "ackedBy": { "type": "string" },
          "resolvedAt": { "type": "string" },
          "resolvedBy": { "type": "string" },
          "note": { "type": "string" },
          "lastExecutionAt": { "type": "string" },
          "lastExecutionStatus": { "type": "string" },
          "lastResultSummary": { "type": "string" },
          "lastReceiptId": { "type": "string" },
          "lastMcpJobId": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
