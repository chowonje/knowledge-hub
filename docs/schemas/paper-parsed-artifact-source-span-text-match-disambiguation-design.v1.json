    "warnings": { "type": "array", "items": { "type": "string" } },
    "disambiguationDesignRows": { "type": "array", "items": { "type": "object" } },
    "stillAmbiguousRows": { "type": "array", "items": { "type": "object" } },
    "rows": {
      "type": "array",
