          "disambiguation_row_id": { "type": "string" },
          "review_row_id": { "type": "string" },
          "design_row_id": { "type": "string" },
          "sourceSpanId": { "type": "string" },
          "paper_id": { "type": "string" },
          "artifact_type": { "type": "string" },
          "text_surface": { "type": "string" },
          "disambiguation_status": { "type": "string" },
          "disambiguation_method": { "type": "string" },
          "disambiguation_blockers": { "type": "array", "items": { "type": "string" } },
          "candidate_match_offsets": { "type": "array", "items": { "type": "object" } },
          "filtered_match_offsets": { "type": "array", "items": { "type": "object" } },
          "proposed_chars": { "type": "object" },
          "recommended_action": { "type": "string" },
          "strictEligible": { "const": false },
          "strictEvidenceCreated": { "const": false },
          "sourceSpanUpdatedRows": { "const": 0 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
