      "properties": {
        "inputRows": { "type": "integer", "minimum": 0 },
        "targetRows": { "type": "integer", "minimum": 0 },
        "disambiguationDesignCandidateOnlyRows": { "type": "integer", "minimum": 0 },
        "blockedStillNonUniqueAfterLocatorContextRows": { "type": "integer", "minimum": 0 },
        "blockedMissingLocatorContextRows": { "type": "integer", "minimum": 0 },
        "blockedMissingCandidateMatchOffsetsRows": { "type": "integer", "minimum": 0 },
        "blockedSourceTextUnavailableRows": { "type": "integer", "minimum": 0 },
        "blockedRequiresManualOrLaterExtractorReviewRows": { "type": "integer", "minimum": 0 },
        "blockedInputSchemaViolationRows": { "type": "integer", "minimum": 0 },
        "sourceSpanUpdatedRows": { "const": 0 },
        "strictEvidenceCreatedRows": { "const": 0 },
        "runtimeEvidenceCreatedRows": { "const": 0 },
        "parserRoutingChangedRows": { "const": 0 },
        "answerIntegrationChangedRows": { "const": 0 },
        "databaseMutationRows": { "const": 0 },
        "canonicalParsedArtifactWriteRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byArtifactType": { "type": "object" },
        "byDisambiguationStatus": { "type": "object" },
        "byRecommendedAction": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "disambiguationDesignComplete",
        "strictEvidenceCreated",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimeMutationAllowed",
        "schemaViolations",
        "decision",
        "recommendedNextTranche"
