        "designReviewReportPath": { "type": "string" },
        "designReviewSchema": { "type": "string" },
        "papersDir": { "type": "string" },
        "parsedRoot": { "type": "string" },
        "requestedPaperIds": { "type": "array", "items": { "type": "string" } }
