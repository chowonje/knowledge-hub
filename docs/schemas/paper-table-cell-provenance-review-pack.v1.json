{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.table-cell-provenance-review-pack.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "reviewCards"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.table-cell-provenance-review-pack.v1" },
    "status": { "type": "string", "enum": ["review_pack_ready", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "tableCellProvenanceFeasibilityReport",
        "tableRegionPdfOffsetFeasibilityReport",
        "tableCellProvenanceFeasibilitySchema",
        "tableRegionPdfOffsetFeasibilitySchema"
      ],
      "properties": {
        "tableCellProvenanceFeasibilityReport": { "type": "string" },
        "tableRegionPdfOffsetFeasibilityReport": { "type": "string" },
        "tableCellProvenanceFeasibilitySchema": { "type": "string" },
        "tableRegionPdfOffsetFeasibilitySchema": { "type": "string" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "reviewCardRows",
        "readyForCellProvenanceReviewRows",
        "heldOutRows",
        "captionSourceSpanRows",
        "captionOriginalPdfOffsetRecoveredRows",
        "tableStructureRows",
        "rowColumnTextRows",
        "totalTableRows",
        "totalTableCells",
        "nonEmptyTableCells",
        "cellBboxRows",
        "cellSourceSpanRows",
        "cellSourceHashRows",
        "tableCellEvidenceVerifiedRows",
        "tableCellCitationGradeRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "schemaViolationCount",
        "byPaper",
        "byReviewStatus",
        "bySourceFeasibilityStatus",
        "strictBlockerSummary"
      ],
      "properties": {
        "reviewCardRows": { "type": "integer", "minimum": 0 },
        "readyForCellProvenanceReviewRows": { "type": "integer", "minimum": 0 },
        "heldOutRows": { "type": "integer", "minimum": 0 },
        "captionSourceSpanRows": { "type": "integer", "minimum": 0 },
        "captionOriginalPdfOffsetRecoveredRows": { "type": "integer", "minimum": 0 },
        "tableStructureRows": { "type": "integer", "minimum": 0 },
        "rowColumnTextRows": { "type": "integer", "minimum": 0 },
        "totalTableRows": { "type": "integer", "minimum": 0 },
        "totalTableCells": { "type": "integer", "minimum": 0 },
        "nonEmptyTableCells": { "type": "integer", "minimum": 0 },
        "cellBboxRows": { "type": "integer", "minimum": 0 },
        "cellSourceSpanRows": { "type": "integer", "minimum": 0 },
        "cellSourceHashRows": { "type": "integer", "minimum": 0 },
        "tableCellEvidenceVerifiedRows": { "const": 0 },
        "tableCellCitationGradeRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object" },
        "byReviewStatus": { "type": "object" },
        "bySourceFeasibilityStatus": { "type": "object" },
        "strictBlockerSummary": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "reviewPackReady",
        "tableCellProvenanceReviewReady",
        "tableCellCitationGradeReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "reviewPackReady": { "type": "boolean" },
        "tableCellProvenanceReviewReady": { "type": "boolean" },
        "tableCellCitationGradeReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": ["ready_for_table_cell_provenance_human_review", "blocked"]
        },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "reviewOnly",
        "tableCellEvidenceCreated",
        "tableCellCitationGradeEvidenceCreated",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "reviewOnly": { "const": true },
        "tableCellEvidenceCreated": { "const": false },
        "tableCellCitationGradeEvidenceCreated": { "const": false },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "reviewCards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "review_card_id",
          "source_table_cell_feasibility_audit_id",
          "source_table_region_candidate_id",
          "paper_id",
          "candidate_type",
          "source_parser",
          "table_label",
          "candidate_text",
          "caption_text",
          "caption_source_span_available",
          "caption_original_pdf_offset_recovered",
          "original_pdf_span",
          "page_agrees_with_canonical",
          "source_hash_agrees_with_canonical",
          "table_structure_available",
          "row_column_text_available",
          "table_row_count",
          "table_cell_count",
          "non_empty_table_cell_count",
          "cell_bbox_count",
          "cell_source_span_count",
          "cell_source_hash_count",
          "cell_bbox_available",
          "cell_source_span_available",
          "cell_source_hash_backed",
          "table_cell_citation_grade",
          "table_cell_evidence_verified",
          "cell_level_review_required",
          "source_feasibility_status",
          "review_status",
          "recommended_review_action",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "review_card_id": { "type": "string" },
          "source_table_cell_feasibility_audit_id": { "type": "string" },
          "source_table_region_candidate_id": { "type": "string" },
          "source_table_region_pdf_offset_row_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_type": { "const": "table_cell_provenance_review_card" },
          "source_parser": { "const": "mineru+pymupdf_alignment" },
          "table_label": { "type": "string" },
          "candidate_text": { "type": "string" },
          "caption_text": { "type": "string" },
          "caption_source_span_available": { "type": "boolean" },
          "caption_original_pdf_offset_recovered": { "type": "boolean" },
          "original_pdf_span": {
            "type": "object",
            "properties": {
              "originalPdfCharsStart": { "type": ["integer", "null"], "minimum": 0 },
              "originalPdfCharsEnd": { "type": ["integer", "null"], "minimum": 0 },
              "page": { "type": ["integer", "null"], "minimum": 1 },
              "sourceContentHash": { "type": "string" },
              "matchMethod": { "type": "string" },
              "matchConfidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": true
          },
          "page_agrees_with_canonical": { "type": "boolean" },
          "source_hash_agrees_with_canonical": { "type": "boolean" },
          "layout_element_count": { "type": "integer", "minimum": 0 },
          "table_region_bbox_available": { "type": "boolean" },
          "normalizer_candidate_id": { "type": "string" },
          "normalizer_report_path": { "type": "string" },
          "normalizer_match": { "type": "boolean" },
          "table_structure_available": { "type": "boolean" },
          "row_column_text_available": { "type": "boolean" },
          "table_row_count": { "type": "integer", "minimum": 0 },
          "table_max_column_count": { "type": "integer", "minimum": 0 },
          "table_cell_count": { "type": "integer", "minimum": 0 },
          "non_empty_table_cell_count": { "type": "integer", "minimum": 0 },
          "header_like_cell_count": { "type": "integer", "minimum": 0 },
          "rowspan_cell_count": { "type": "integer", "minimum": 0 },
          "colspan_cell_count": { "type": "integer", "minimum": 0 },
          "cell_bbox_count": { "type": "integer", "minimum": 0 },
          "cell_source_span_count": { "type": "integer", "minimum": 0 },
          "cell_source_hash_count": { "type": "integer", "minimum": 0 },
          "sample_cells": { "type": "array", "items": { "type": "object" } },
          "cell_bbox_available": { "type": "boolean" },
          "cell_source_span_available": { "type": "boolean" },
          "cell_source_hash_backed": { "type": "boolean" },
          "table_cell_citation_grade": { "const": false },
          "table_cell_evidence_verified": { "const": false },
          "cell_level_review_required": { "const": true },
          "source_feasibility_status": { "type": "string" },
          "review_status": {
            "type": "string",
            "enum": [
              "ready_for_cell_provenance_review",
              "held_out_caption_source_offset_missing",
              "held_out_table_structure_missing",
              "held_out_normalizer_table_missing",
              "held_out_row_column_text_missing"
            ]
          },
          "recommended_review_action": { "type": "string" },
          "evidence_tier": { "const": "table_cell_provenance_review_card_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
