{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "status", "runId", "run", "recentRuns", "recentSummary", "alerts", "recommendedActions", "warnings", "ts"],
  "properties": {
    "schema": { "const": "knowledge-hub.ko-note.report.result.v1" },
    "status": { "type": "string" },
    "runId": { "type": "string" },
    "run": { "type": "object" },
    "recentRuns": { "type": "array" },
    "recentSummary": { "type": "object" },
    "alerts": { "type": "array" },
    "recommendedActions": { "type": "array" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "ts": { "type": "string" }
  },
  "additionalProperties": true
}
