{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.candidate-layer-blocker-decision-file-validation.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings",
    "validationRows"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.candidate-layer-blocker-decision-file-validation.v1" },
    "status": {
      "type": "string",
      "enum": ["decision_file_required", "decision_file_incomplete", "decision_file_validated", "blocked"]
    },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "candidateLayerBlockerDecisionInputPackReport",
        "candidateLayerBlockerDecisionInputPackSchema",
        "candidateLayerBlockerDecisionsFile",
        "candidateLayerBlockerDecisionFileRows"
      ],
      "properties": {
        "candidateLayerBlockerDecisionInputPackReport": { "type": "string" },
        "candidateLayerBlockerDecisionInputPackSchema": { "type": "string" },
        "candidateLayerBlockerDecisionsFile": { "type": "string" },
        "candidateLayerBlockerDecisionFileRows": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "validationRows",
        "validRows",
        "invalidRows",
        "missingRows",
        "needsReviewRows",
        "nonNeedsReviewRows",
        "fileErrorCount",
        "acceptedDecisionRows",
        "operatorApprovedRows",
        "strictEligibleRows",
        "citationGradeRows",
        "runtimeEvidenceRows",
        "unsafeUpstreamFlagCount",
        "byStatus",
        "byBucket",
        "byDecision",
        "byLayer"
      ],
      "properties": {
        "validationRows": { "type": "integer", "minimum": 0 },
        "validRows": { "type": "integer", "minimum": 0 },
        "invalidRows": { "type": "integer", "minimum": 0 },
        "missingRows": { "type": "integer", "minimum": 0 },
        "needsReviewRows": { "type": "integer", "minimum": 0 },
        "nonNeedsReviewRows": { "type": "integer", "minimum": 0 },
        "fileErrorCount": { "type": "integer", "minimum": 0 },
        "acceptedDecisionRows": { "const": 0 },
        "operatorApprovedRows": { "const": 0 },
        "strictEligibleRows": { "const": 0 },
        "citationGradeRows": { "const": 0 },
        "runtimeEvidenceRows": { "const": 0 },
        "unsafeUpstreamFlagCount": { "type": "integer", "minimum": 0 },
        "byStatus": { "type": "object" },
        "byBucket": { "type": "object" },
        "byDecision": { "type": "object" },
        "byLayer": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "decisionFileValidationReady",
        "decisionFileComplete",
        "containsRecordedDecisions",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "unsafeUpstreamFlags",
        "fileValidationErrors",
        "recommendedNextTranche"
      ],
      "properties": {
        "decisionFileValidationReady": { "type": "boolean" },
        "decisionFileComplete": { "type": "boolean" },
        "containsRecordedDecisions": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": {
          "type": "string",
          "enum": [
            "manual_decision_file_missing",
            "manual_decision_file_incomplete",
            "manual_decision_file_validated_non_runtime",
            "blocked"
          ]
        },
        "unsafeUpstreamFlags": { "type": "array", "items": { "type": "string" } },
        "fileValidationErrors": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "reportOnly",
        "decisionFileValidationOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "reportOnly": { "const": true },
        "decisionFileValidationOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "validationRows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "validation_row_id",
          "source_input_row_id",
          "source_decision_row_id",
          "source_review_card_id",
          "source_backlog_id",
          "blocker",
          "priority",
          "review_bucket",
          "affected_layers",
          "allowed_decisions",
          "submitted_decision",
          "reviewer",
          "notes",
          "validation_status",
          "validation_errors",
          "decision_scope",
          "evidence_tier",
          "report_only",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "validation_row_id": { "type": "string" },
          "source_input_row_id": { "type": "string" },
          "source_decision_row_id": { "type": "string" },
          "source_review_card_id": { "type": "string" },
          "source_backlog_id": { "type": "string" },
          "blocker": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "review_bucket": {
            "type": "string",
            "enum": [
              "manual_decision_required",
              "operator_approval_required",
              "technical_feasibility_blocked",
              "policy_review_only"
            ]
          },
          "affected_layers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["sectionspan", "figure_caption", "equation_quote", "table_region"]
            }
          },
          "allowed_decisions": { "type": "array", "items": { "type": "string" } },
          "submitted_decision": { "type": "string" },
          "reviewer": { "type": "string" },
          "notes": { "type": "string" },
          "validation_status": { "type": "string", "enum": ["missing", "valid", "invalid"] },
          "validation_errors": { "type": "array", "items": { "type": "string" } },
          "decision_scope": {
            "const": "candidate_layer_blocker_decision_file_validation_only_no_runtime_or_strict_promotion"
          },
          "evidence_tier": { "const": "candidate_layer_blocker_decision_file_validation_only" },
          "report_only": { "const": true },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
