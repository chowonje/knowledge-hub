{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper-memory.card.result.v1",
  "type": "object",
  "required": ["schema", "status", "item", "warnings"],
  "properties": {
    "schema": { "const": "knowledge-hub.paper-memory.card.result.v1" },
    "status": { "type": "string", "enum": ["ok", "failed"] },
    "item": {
      "oneOf": [
        { "$ref": "#/$defs/paperMemoryCardWithRefs" },
        {
          "type": "object",
          "maxProperties": 0
        }
      ]
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "paperMemoryCard": {
      "type": "object",
      "required": [
        "memoryId",
        "paperId",
        "sourceNoteId",
        "title",
        "paperCore",
        "problemContext",
        "methodCore",
        "evidenceCore",
        "limitations",
        "conceptLinks",
        "claimRefs",
        "publishedAt",
        "evidenceWindow",
        "searchText",
        "qualityFlag",
        "version",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "memoryId": { "type": "string" },
        "paperId": { "type": "string" },
        "sourceNoteId": { "type": "string" },
        "title": { "type": "string" },
        "paperCore": { "type": "string" },
        "problemContext": { "type": "string" },
        "methodCore": { "type": "string" },
        "evidenceCore": { "type": "string" },
        "limitations": { "type": "string" },
        "conceptLinks": { "type": "array", "items": { "type": "string" } },
        "claimRefs": { "type": "array", "items": { "type": "string" } },
        "publishedAt": { "type": "string" },
        "evidenceWindow": { "type": "string" },
        "searchText": { "type": "string" },
        "qualityFlag": { "type": "string" },
        "version": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "paperRef": {
      "type": "object",
      "required": ["paperId", "title", "field"],
      "properties": {
        "paperId": { "type": "string" },
        "title": { "type": "string" },
        "year": { "type": ["integer", "null"] },
        "field": { "type": "string" },
        "publishedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sourceNoteRef": {
      "type": "object",
      "required": ["id", "title", "sourceType"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "sourceType": { "type": "string" }
      },
      "additionalProperties": false
    },
    "claimRef": {
      "type": "object",
      "required": ["claimId", "claimText"],
      "properties": {
        "claimId": { "type": "string" },
        "claimText": { "type": "string" },
        "confidence": { "type": ["number", "integer", "null"] }
      },
      "additionalProperties": false
    },
    "paperMemoryCardWithRefs": {
      "type": "object",
      "required": [
        "memoryId",
        "paperId",
        "sourceNoteId",
        "title",
        "paperCore",
        "problemContext",
        "methodCore",
        "evidenceCore",
        "limitations",
        "conceptLinks",
        "claimRefs",
        "publishedAt",
        "evidenceWindow",
        "searchText",
        "qualityFlag",
        "version",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "memoryId": { "type": "string" },
        "paperId": { "type": "string" },
        "sourceNoteId": { "type": "string" },
        "title": { "type": "string" },
        "paperCore": { "type": "string" },
        "problemContext": { "type": "string" },
        "methodCore": { "type": "string" },
        "evidenceCore": { "type": "string" },
        "limitations": { "type": "string" },
        "conceptLinks": { "type": "array", "items": { "type": "string" } },
        "claimRefs": { "type": "array", "items": { "type": "string" } },
        "publishedAt": { "type": "string" },
        "evidenceWindow": { "type": "string" },
        "searchText": { "type": "string" },
        "qualityFlag": { "type": "string" },
        "version": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "paper": { "$ref": "#/$defs/paperRef" },
        "sourceNote": { "$ref": "#/$defs/sourceNoteRef" },
        "claims": {
          "type": "array",
          "items": { "$ref": "#/$defs/claimRef" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
