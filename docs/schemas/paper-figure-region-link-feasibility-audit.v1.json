{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge-hub.paper.figure-region-link-feasibility-audit.v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generatedAt",
    "inputs",
    "counts",
    "gate",
    "policy",
    "warnings"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.figure-region-link-feasibility-audit.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": [
        "figureCaptionReport",
        "mineruSourceAlignmentReport",
        "figureCaptionSchema",
        "mineruSourceAlignmentSchema",
        "mineruNormalizerReportPaths",
        "mineruNormalizerSchemas"
      ],
      "properties": {
        "figureCaptionReport": { "type": "string" },
        "mineruSourceAlignmentReport": { "type": "string" },
        "figureCaptionSchema": { "type": "string" },
        "mineruSourceAlignmentSchema": { "type": "string" },
        "mineruNormalizerReportPaths": { "type": "object" },
        "mineruNormalizerSchemas": { "type": "object" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": [
        "inputFigureCaptionCandidates",
        "auditedFigureCaptionCandidates",
        "normalizerFigureCaptionMatches",
        "captionSourceSpanCandidates",
        "layoutRegionCandidates",
        "regionPageRecoveredCandidates",
        "captionRegionPageMatchCandidates",
        "figureRegionTypeVerifiedCandidates",
        "figureRegionLinkVerifiedCandidates",
        "strictEligibleCandidates",
        "citationGradeCandidates",
        "runtimeEvidenceCandidates",
        "schemaViolationCount",
        "byPaper",
        "byFeasibilityStatus",
        "strictBlockerSummary"
      ],
      "properties": {
        "inputFigureCaptionCandidates": { "type": "integer", "minimum": 0 },
        "auditedFigureCaptionCandidates": { "type": "integer", "minimum": 0 },
        "normalizerFigureCaptionMatches": { "type": "integer", "minimum": 0 },
        "captionSourceSpanCandidates": { "type": "integer", "minimum": 0 },
        "layoutRegionCandidates": { "type": "integer", "minimum": 0 },
        "regionPageRecoveredCandidates": { "type": "integer", "minimum": 0 },
        "captionRegionPageMatchCandidates": { "type": "integer", "minimum": 0 },
        "figureRegionTypeVerifiedCandidates": { "const": 0 },
        "figureRegionLinkVerifiedCandidates": { "const": 0 },
        "strictEligibleCandidates": { "const": 0 },
        "citationGradeCandidates": { "const": 0 },
        "runtimeEvidenceCandidates": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object" },
        "byFeasibilityStatus": { "type": "object" },
        "strictBlockerSummary": { "type": "object" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": [
        "figureRegionLinkReviewed",
        "figureRegionCitationGradeReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "figureRegionLinkReviewed": { "type": "boolean" },
        "figureRegionCitationGradeReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "decision": { "type": "string", "enum": ["figure_region_link_feasibility_reviewed", "blocked"] },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "auditOnly",
        "figureRegionCandidateOnly",
        "figureRegionEvidenceCreated",
        "figureRegionLinkVerified",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "reindexOrReembed",
        "answerIntegrationChanged"
      ],
      "properties": {
        "auditOnly": { "const": true },
        "figureRegionCandidateOnly": { "const": true },
        "figureRegionEvidenceCreated": { "const": false },
        "figureRegionLinkVerified": { "const": false },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "audit_id",
          "figure_caption_candidate_id",
          "source_candidate_id",
          "paper_id",
          "candidate_type",
          "candidate_text",
          "caption_source_span_available",
          "normalizer_match",
          "layout_region_candidate_present",
          "region_page_recovered",
          "figure_region_type_verified",
          "figure_region_link_verified",
          "feasibility_status",
          "evidence_tier",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "strict_blockers",
          "non_strict_reason"
        ],
        "properties": {
          "audit_id": { "type": "string" },
          "figure_caption_candidate_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "candidate_type": { "const": "figure_region_link_feasibility_candidate" },
          "source_parser": { "type": "string" },
          "candidate_text": { "type": "string" },
          "figure_label": { "type": "string" },
          "caption_text": { "type": "string" },
          "caption_alignment_status": { "type": "string" },
          "caption_alignment_method": { "type": "string" },
          "caption_chars_start": { "type": ["integer", "null"], "minimum": 0 },
          "caption_chars_end": { "type": ["integer", "null"], "minimum": 0 },
          "caption_page": { "type": ["integer", "null"], "minimum": 1 },
          "sourceContentHash": { "type": "string" },
          "sourceContentHashSource": { "type": "string" },
          "caption_source_span_available": { "type": "boolean" },
          "normalizer_candidate_id": { "type": "string" },
          "normalizer_report_path": { "type": "string" },
          "normalizer_schema": { "type": "string" },
          "normalizer_match": { "type": "boolean" },
          "layout_element_ids": { "type": "array", "items": { "type": "string" } },
          "layout_element_count": { "type": "integer", "minimum": 0 },
          "bbox": {
            "anyOf": [
              {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": { "type": "number" }
              },
              { "type": "null" }
            ]
          },
          "layout_link_reason": { "type": "string" },
          "layout_region_candidate_present": { "type": "boolean" },
          "normalizer_region_page": { "type": ["integer", "null"], "minimum": 1 },
          "region_page_recovered": { "type": "boolean" },
          "caption_page_matches_region_page": { "type": "boolean" },
          "figure_region_type_verified": { "const": false },
          "figure_region_link_verified": { "const": false },
          "feasibility_status": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_tier": { "const": "figure_region_link_feasibility_candidate_only" },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
