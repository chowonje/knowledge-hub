{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-hub.paper.tex-equation-quote-candidate-v2-design.v1",
  "title": "TeX EquationQuoteCandidate v2 Design",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generatedAt",
    "input",
    "counts",
    "gate",
    "policy",
    "designRules",
    "warnings",
    "candidates",
    "heldOut"
  ],
  "properties": {
    "schema": { "const": "knowledge-hub.paper.tex-equation-quote-candidate-v2-design.v1" },
    "status": { "type": "string", "enum": ["ok", "blocked"] },
    "generatedAt": { "type": "string" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pdfRegionAnchorReportPath", "pdfRegionAnchorReportSchema", "paperIds"],
      "properties": {
        "pdfRegionAnchorReportPath": { "type": "string" },
        "pdfRegionAnchorReportSchema": { "type": "string" },
        "paperIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputRows",
        "pdfRegionAnchorRows",
        "uniquePdfRegionAnchorRows",
        "pdfRegionResolvedAmbiguousRows",
        "v2DesignCandidates",
        "heldOutRows",
        "sourceSpanCreatedRows",
        "strictEligibleCandidates",
        "citationGradeCandidates",
        "runtimeEvidenceCandidates",
        "equationRegionVerifiedCandidates",
        "equationSemanticsInterpretedCandidates",
        "schemaViolationCount",
        "byPaper",
        "heldOutByReason"
      ],
      "properties": {
        "inputRows": { "type": "integer", "minimum": 0 },
        "pdfRegionAnchorRows": { "type": "integer", "minimum": 0 },
        "uniquePdfRegionAnchorRows": { "type": "integer", "minimum": 0 },
        "pdfRegionResolvedAmbiguousRows": { "type": "integer", "minimum": 0 },
        "v2DesignCandidates": { "type": "integer", "minimum": 0 },
        "heldOutRows": { "type": "integer", "minimum": 0 },
        "sourceSpanCreatedRows": { "const": 0 },
        "strictEligibleCandidates": { "const": 0 },
        "citationGradeCandidates": { "const": 0 },
        "runtimeEvidenceCandidates": { "const": 0 },
        "equationRegionVerifiedCandidates": { "const": 0 },
        "equationSemanticsInterpretedCandidates": { "const": 0 },
        "schemaViolationCount": { "type": "integer", "minimum": 0 },
        "byPaper": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "heldOutByReason": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "v2DesignReady",
        "sourceSpanCreationReady",
        "strictEvidenceReady",
        "parserRoutingReady",
        "answerIntegrationReady",
        "runtimePromotionAllowed",
        "decision",
        "schemaViolations",
        "recommendedNextTranche"
      ],
      "properties": {
        "v2DesignReady": { "type": "boolean" },
        "sourceSpanCreationReady": { "const": false },
        "strictEvidenceReady": { "const": false },
        "parserRoutingReady": { "const": false },
        "answerIntegrationReady": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "decision": { "type": "string" },
        "schemaViolations": { "type": "array", "items": { "type": "string" } },
        "recommendedNextTranche": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allCandidatesNonStrict",
        "reportOnly",
        "v2DesignOnly",
        "strictEvidenceCreated",
        "runtimePromotionAllowed",
        "parserRoutingChanged",
        "canonicalParsedArtifactsWritten",
        "databaseMutation",
        "vaultScan",
        "reindexOrReembed",
        "answerIntegrationChanged",
        "equationInterpretationAllowed",
        "equationRegionVerificationRequired"
      ],
      "properties": {
        "allCandidatesNonStrict": { "const": true },
        "reportOnly": { "const": true },
        "v2DesignOnly": { "const": true },
        "strictEvidenceCreated": { "const": false },
        "runtimePromotionAllowed": { "const": false },
        "parserRoutingChanged": { "const": false },
        "canonicalParsedArtifactsWritten": { "const": false },
        "databaseMutation": { "const": false },
        "vaultScan": { "const": false },
        "reindexOrReembed": { "const": false },
        "answerIntegrationChanged": { "const": false },
        "equationInterpretationAllowed": { "const": false },
        "equationRegionVerificationRequired": { "const": true }
      }
    },
    "designRules": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "candidate_type",
          "source_pdf_region_anchor_id",
          "source_line_local_anchor_id",
          "source_design_id",
          "source_candidate_id",
          "paper_id",
          "source_parser",
          "source_file",
          "equation_environment",
          "candidate_text",
          "equation_text",
          "equation_label",
          "normalized_terms",
          "canonical_context",
          "pdf_region",
          "source_pdf_path",
          "source_manifest_path",
          "sourceContentHash",
          "sourceContentHashSource",
          "source_hash_agrees_with_input",
          "text_source_authority",
          "location_source_authority",
          "source_span_created",
          "equation_region_verified",
          "equation_semantics_interpreted",
          "evidence_tier",
          "confidence",
          "strict_eligible",
          "citation_grade",
          "runtime_evidence",
          "runtime_promotion_allowed",
          "strict_blockers",
          "non_strict_reason",
          "recommended_action"
        ],
        "properties": {
          "candidate_id": { "type": "string" },
          "candidate_type": { "const": "equation_quote_candidate_v2_design" },
          "source_pdf_region_anchor_id": { "type": "string" },
          "source_line_local_anchor_id": { "type": "string" },
          "source_design_id": { "type": "string" },
          "source_candidate_id": { "type": "string" },
          "paper_id": { "type": "string" },
          "source_parser": { "const": "arxiv_tex+pymupdf_pdf_blocks" },
          "source_file": { "type": "string" },
          "equation_environment": { "type": "string" },
          "candidate_text": { "type": "string" },
          "equation_text": { "type": "string" },
          "equation_label": { "type": "string" },
          "normalized_terms": { "type": "array", "items": { "type": "string" } },
          "canonical_context": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "lineLocalAnchorStatus",
              "lineLocalAnchorMethod",
              "canonicalPageMarkers",
              "normalizedWindowCount",
              "canonicalCharsStart",
              "canonicalCharsEnd",
              "canonicalPage",
              "canonicalSourceSpanCreated"
            ],
            "properties": {
              "lineLocalAnchorStatus": { "type": "string" },
              "lineLocalAnchorMethod": { "type": "string" },
              "canonicalPageMarkers": { "type": "array", "items": { "type": ["integer", "null"] } },
              "normalizedWindowCount": { "type": "integer", "minimum": 0 },
              "canonicalCharsStart": { "type": ["integer", "null"] },
              "canonicalCharsEnd": { "type": ["integer", "null"] },
              "canonicalPage": { "type": ["integer", "null"] },
              "canonicalSourceSpanCreated": { "const": false }
            }
          },
          "pdf_region": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "pdfRegionAnchorStatus",
              "pdfRegionAnchorMethod",
              "page",
              "bbox",
              "blockIndexes",
              "matchedTerms",
              "coverage",
              "formulaScore",
              "equationNumbers",
              "textPreview"
            ],
            "properties": {
              "pdfRegionAnchorStatus": { "type": "string" },
              "pdfRegionAnchorMethod": { "type": "string" },
              "page": { "type": "integer", "minimum": 1 },
              "bbox": { "type": "array", "items": { "type": "number" } },
              "blockIndexes": { "type": "array", "items": { "type": "integer" } },
              "matchedTerms": { "type": "array", "items": { "type": "string" } },
              "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
              "formulaScore": { "type": "number", "minimum": 0 },
              "equationNumbers": { "type": "array", "items": { "type": "string" } },
              "textPreview": { "type": "string" }
            }
          },
          "source_pdf_path": { "type": "string" },
          "source_manifest_path": { "type": "string" },
          "sourceContentHash": { "type": "string", "minLength": 1 },
          "sourceContentHashSource": { "type": "string" },
          "source_hash_agrees_with_input": { "type": "boolean" },
          "text_source_authority": { "const": "arxiv_tex_equation_environment" },
          "location_source_authority": { "const": "pymupdf_pdf_region_bbox_candidate" },
          "source_span_created": { "const": false },
          "equation_region_verified": { "const": false },
          "equation_semantics_interpreted": { "const": false },
          "evidence_tier": { "const": "equation_quote_candidate_v2_design_only" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "strict_eligible": { "const": false },
          "citation_grade": { "const": false },
          "runtime_evidence": { "const": false },
          "runtime_promotion_allowed": { "const": false },
          "strict_blockers": { "type": "array", "items": { "type": "string" } },
          "non_strict_reason": { "type": "array", "items": { "type": "string" } },
          "recommended_action": { "type": "string" }
        }
      }
    },
    "heldOut": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourcePdfRegionAnchorId",
          "sourceLineLocalAnchorId",
          "paperId",
          "candidateText",
          "pdfRegionAnchorStatus",
          "lineLocalAnchorStatus",
          "pdfRegionCandidateCount",
          "selectedPdfRegionPage",
          "selectedPdfRegionBbox",
          "reason",
          "strictEligible",
          "citationGrade",
          "runtimeEvidence"
        ],
        "properties": {
          "sourcePdfRegionAnchorId": { "type": "string" },
          "sourceLineLocalAnchorId": { "type": "string" },
          "paperId": { "type": "string" },
          "candidateText": { "type": "string" },
          "pdfRegionAnchorStatus": { "type": "string" },
          "lineLocalAnchorStatus": { "type": "string" },
          "pdfRegionCandidateCount": { "type": "integer", "minimum": 0 },
          "selectedPdfRegionPage": { "type": ["integer", "null"] },
          "selectedPdfRegionBbox": { "type": "array", "items": { "type": "number" } },
          "reason": { "type": "string" },
          "strictEligible": { "const": false },
          "citationGrade": { "const": false },
          "runtimeEvidence": { "const": false }
        }
      }
    }
  }
}
