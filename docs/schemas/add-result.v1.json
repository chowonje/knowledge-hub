{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-hub.local/schemas/add-result.v1.json",
  "title": "knowledge-hub add result v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "source",
    "sourceType",
    "sourceId",
    "canonicalUrl",
    "canonicalPath",
    "title",
    "contentHash",
    "stored",
    "indexed",
    "route",
    "routeReason",
    "topic",
    "index",
    "obsidianStage",
    "warnings",
    "upstream",
    "nextActions",
    "nextCommands"
  ],
  "properties": {
    "schema": {
      "const": "knowledge-hub.add.result.v1"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "sourceType": {
      "type": "string",
      "enum": ["web", "youtube", "paper", "pdf"]
    },
    "sourceId": {
      "type": "string"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "canonicalPath": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "contentHash": {
      "type": "string"
    },
    "stored": {
      "type": "boolean"
    },
    "indexed": {
      "type": "boolean"
    },
    "route": {
      "type": "string",
      "enum": ["crawl_ingest", "crawl_youtube_ingest", "paper_import", "discover"]
    },
    "routeReason": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string"
    },
    "index": {
      "type": "boolean"
    },
    "upstream": {
      "type": "object"
    },
    "obsidianStage": {
      "type": "object",
      "required": ["requested", "status", "runId", "staged", "applied", "applyRequested", "applySkipped"],
      "properties": {
        "requested": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "staged": {
          "type": "integer",
          "minimum": 0
        },
        "applied": {
          "type": "integer",
          "minimum": 0
        },
        "applyRequested": {
          "type": "boolean"
        },
        "applySkipped": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nextCommands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "schemaErrors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
