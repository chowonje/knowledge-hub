  "cases": [
    {
      "id": "detected-p0-agent-verify",
      "action": "agent_verify",
      "resourceType": "artifact",
      "resourceId": "fixture-p0-detected",
      "classification": "P2",
      "payload": {
        "classification": "P2",
        "jsonContent": "password: fixture-only"
      },
      "expected": {
        "allowed": false,
        "classification": "P0",
        "tsPolicyCode": "AGENT_VERIFY_P0_DENY"
      }
    },
