{
  "schema": "knowledge-hub.live-compare-quality-eval.cases.v1",
  "cases": [
    {
      "case_id": "paper_compare_known_conflict",
      "template": true,
      "query": "replace with a local paper comparison query that should surface a conflict",
      "source": "paper",
      "top_k": 8,
      "mode": "hybrid",
      "expected_source_ids": ["<paper-a-arxiv-id-or-title-or-slug>", "<paper-b-arxiv-id-or-title-or-slug>"],
      "expected_dimension_terms": ["metric or method term expected in compare dimensions"],
      "expected_statuses": ["conflict"],
      "expected_min_supporting_span_count": 2,
      "expected_min_strict_span_count": 2,
      "expected_min_strict_source_coverage": 1.0,
      "corpusRequirements": [
        {
          "artifactId": "<artifact-id-from-eval-knowledgeos-fixtures-corpus-manifest>",
          "corpusTier": "local_corpus",
          "minOffsetsRequired": true
        }
      ],
      "forbidden_non_evidence_support": true,
      "require_trace_citations": true,
      "expected_answerable": true,
      "allow_external": false
    },
